        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-04-20T12:38:01Z</dcterms:created>
        <rdfs:label xml:lang="en">results in susceptibility to</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://haddenindustries.com/ontology/iso/31073/ed-1/statesOverallIntentionsAndDirectionOf -->

    <owl:ObjectProperty rdf:about="https://haddenindustries.com/ontology/iso/31073/ed-1/statesOverallIntentionsAndDirectionOf">
        <rdfs:domain rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/term/RiskManagementPolicy"/>
        <rdfs:range rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/term/Organization"/>
        <dc:creator rdf:resource="https://orcid.org/0000-0001-8017-8797"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-04-20T12:20:57Z</dcterms:created>
        <rdfs:label xml:lang="en">states overall intentions and direction of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://haddenindustries.com/ontology/iso/31073/ed-1/wantsToAchieve -->

    <owl:ObjectProperty rdf:about="https://haddenindustries.com/ontology/iso/31073/ed-1/wantsToAchieve">
        <rdfs:domain rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/term/Organization"/>
        <rdfs:range rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/term/Objective"/>
        <dc:creator rdf:resource="https://orcid.org/0000-0001-8017-8797"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-04-20T08:36:19Z</dcterms:created>
        <rdfs:label xml:lang="en">wants to achieve</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://haddenindustries.com/ontology/iso/31073/ed-1/willinglyHeldBy -->

    <owl:ObjectProperty rdf:about="https://haddenindustries.com/ontology/iso/31073/ed-1/willinglyHeldBy">
        <rdfs:domain rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/term/RiskAppetite"/>
        <rdfs:range rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/term/Organization"/>
        <dc:creator rdf:resource="https://orcid.org/0000-0001-8017-8797"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-04-20T12:48:24Z</dcterms:created>
        <rdfs:label xml:lang="en">willingly held by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- https://haddenindustries.com/ontology/iso/31073/ed-1/term/Consequence -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/iso/31073/ed-1/term/Consequence">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/affects"/>
                <owl:someValuesFrom rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/term/Objective"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/resultsFrom"/>
                <owl:someValuesFrom rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/term/Event"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dc:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-04-20T08:04:46Z</dcterms:created>
        <dcterms:description xml:lang="en">outcome of an event (3.3.11) affecting objectives (3.1.2)</dcterms:description>
        <dcterms:identifier rdf:resource="urn:uuid:9b69e28e-02c0-465a-96f9-4749f0c8c0cb"/>
        <dcterms:source rdf:resource="urn:iso:std:iso:31073:ed-1:v1:term:3.3.18"/>
        <dcterms:subject xml:lang="en">risk management process</dcterms:subject>
        <rdfs:comment xml:lang="en">Note 1 to entry: A consequence can have positive or negative, direct or indirect, effects on objectives.
Note 2 to entry: Consequences can be expressed qualitatively or quantitatively.
Note 3 to entry: Any consequence can escalate through cascading and cumulative effects.</rdfs:comment>
        <rdfs:label xml:lang="en">consequence</rdfs:label>
    </owl:Class>
    


    <!-- https://haddenindustries.com/ontology/iso/31073/ed-1/term/Event -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/iso/31073/ed-1/term/Event">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/canBe"/>
                <owl:someValuesFrom rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/term/RiskSource"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dc:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-04-20T08:04:46Z</dcterms:created>
        <dcterms:description xml:lang="en">occurrence or change of a particular set of circumstances</dcterms:description>
        <dcterms:identifier rdf:resource="urn:uuid:558ea383-5f79-41da-be94-11bf5f775004"/>
        <dcterms:source rdf:resource="urn:iso:std:iso:31073:ed-1:v1:term:3.3.11"/>
        <dcterms:subject xml:lang="en">risk management process</dcterms:subject>
        <rdfs:comment xml:lang="en">Note 1 to entry: An event can have one or more occurrences, and can have several causes and several consequences (3.3.18).
Note 2 to entry: An event can also be something that is expected which does not happen, or something that is not expected which does happen.
Note 3 to entry: An event can be a risk source (3.3.10).</rdfs:comment>
        <rdfs:label xml:lang="en">event</rdfs:label>
    </owl:Class>
    


    <!-- https://haddenindustries.com/ontology/iso/31073/ed-1/term/Exposure -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/iso/31073/ed-1/term/Exposure">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/isSubjectTo"/>
                <owl:someValuesFrom rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/term/Event"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dc:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-04-20T08:04:46Z</dcterms:created>
        <dcterms:description xml:lang="en">extent to which an organization (3.3.7) and/or interested party (3.3.2) is subject to an event (3.3.11)</dcterms:description>
        <dcterms:identifier rdf:resource="urn:uuid:7e81d3f3-42e5-4447-9c2c-acd79d571e70"/>
        <dcterms:source rdf:resource="urn:iso:std:iso:31073:ed-1:v1:term:3.3.17"/>
        <dcterms:subject xml:lang="en">risk management process</dcterms:subject>
        <rdfs:comment xml:lang="en">[SOURCE:ISO Guide 73:2009, 3.6.1.2, modified — “interested party” has replaced “stakeholder”.]</rdfs:comment>
        <rdfs:label xml:lang="en">exposure</rdfs:label>
    </owl:Class>
    


    <!-- https://haddenindustries.com/ontology/iso/31073/ed-1/term/ExternalContext -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/iso/31073/ed-1/term/ExternalContext">
        <owl:disjointWith rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/term/InternalContext"/>
        <dc:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-04-20T08:04:46Z</dcterms:created>
        <dcterms:description xml:lang="en">external environment in which the organization (3.3.7) seeks to achieve its objectives (3.1.2)</dcterms:description>
        <dcterms:identifier rdf:resource="urn:uuid:2234782a-7a38-49e9-b723-d7bb2a9f3026"/>
        <dcterms:source rdf:resource="urn:iso:std:iso:31073:ed-1:v1:term:3.3.4"/>
        <dcterms:subject xml:lang="en">risk management process</dcterms:subject>
        <rdfs:comment xml:lang="en">Note 1 to entry: External context can include:
— the cultural, social, political, legal, regulatory, financial, technological, economic, natural and competitive environment, whether international, national, regional or local;
— key drivers and trends having impact on the objectives of the organization; and
— relationships with, and perceptions and values of, external interested parties (3.3.2).</rdfs:comment>
        <rdfs:label xml:lang="en">external context</rdfs:label>
    </owl:Class>
    


    <!-- https://haddenindustries.com/ontology/iso/31073/ed-1/term/Frequency -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/iso/31073/ed-1/term/Frequency">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/isNumberOf"/>
                <owl:someValuesFrom rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/term/Event"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dc:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-04-20T08:04:46Z</dcterms:created>
        <dcterms:description xml:lang="en">number of events (3.3.11) or outcomes per defined unit of time</dcterms:description>
        <dcterms:identifier rdf:resource="urn:uuid:4c7102d1-f44d-40f7-ac8c-f507b3d98b44"/>
        <dcterms:source rdf:resource="urn:iso:std:iso:31073:ed-1:v1:term:3.3.20"/>
        <dcterms:subject xml:lang="en">risk management process</dcterms:subject>
        <rdfs:comment xml:lang="en">Note 1 to entry: Frequency can be applied to past events or to potential future events, where it can be used as a measure of likelihood (3.3.16)/probability (3.3.19).
[SOURCE:ISO Guide 73:2009, 3.6.1.5]</rdfs:comment>
        <rdfs:label xml:lang="en">frequency</rdfs:label>
    </owl:Class>
    


    <!-- https://haddenindustries.com/ontology/iso/31073/ed-1/term/Hazard -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/iso/31073/ed-1/term/Hazard">
        <rdfs:subClassOf rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/term/Threat"/>
        <dc:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-04-20T08:04:46Z</dcterms:created>
        <dcterms:description xml:lang="en">source of potential harm</dcterms:description>
        <dcterms:identifier rdf:resource="urn:uuid:44d632ec-ef07-41b6-baaa-0fbad7109776"/>
        <dcterms:source rdf:resource="urn:iso:std:iso:31073:ed-1:v1:term:3.3.12"/>
        <dcterms:subject xml:lang="en">risk management process</dcterms:subject>
        <rdfs:comment xml:lang="en">Note 1 to entry: Hazard can be a risk source (3.3.10).
[SOURCE:ISO Guide 73:2009, 3.5.1.4]</rdfs:comment>
        <rdfs:label xml:lang="en">hazard</rdfs:label>
    </owl:Class>
    


    <!-- https://haddenindustries.com/ontology/iso/31073/ed-1/term/InternalContext -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/iso/31073/ed-1/term/InternalContext">
        <dc:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-04-20T08:04:46Z</dcterms:created>
        <dcterms:description xml:lang="en">internal environment in which the organization (3.3.7) seeks to achieve its objectives (3.1.2)</dcterms:description>
        <dcterms:identifier rdf:resource="urn:uuid:7c9b353c-19d3-4af4-9a76-e502b703f3d5"/>
        <dcterms:source rdf:resource="urn:iso:std:iso:31073:ed-1:v1:term:3.3.5"/>
        <dcterms:subject xml:lang="en">risk management process</dcterms:subject>
        <rdfs:comment xml:lang="en">Note 1 to entry: Internal context can include:
— governance, organizational structure, roles and accountabilities;
— policies, objectives, and the strategies that are in place to achieve them;
— the capabilities, understood in terms of resources and knowledge (e.g. capital, time, people, processes, systems and technologies);
— information systems, information flows and decision-making processes (both formal and informal);
— relationships with, and perceptions and values of, internal interested parties (3.3.2);
— the organization’s culture;
— standards, guidelines and models adopted by the organization; and
— form and extent of contractual relationships.
[SOURCE:ISO Guide 73:2009, 3.3.1.2, modified — “interested parties” has replaced “stakeholders”.]</rdfs:comment>
        <rdfs:label xml:lang="en">internal context</rdfs:label>
    </owl:Class>
    


    <!-- https://haddenindustries.com/ontology/iso/31073/ed-1/term/LevelOfRisk -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/iso/31073/ed-1/term/LevelOfRisk">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/isExpressedInTermsOf"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://haddenindustries.com/ontology/iso/31073/ed-1/term/Consequence"/>
                            <rdf:Description rdf:about="https://haddenindustries.com/ontology/iso/31073/ed-1/term/Likelihood"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/isMagnitudeOf"/>
                <owl:someValuesFrom rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/term/Risk"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dc:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-04-20T08:04:46Z</dcterms:created>
        <dcterms:description xml:lang="en">magnitude of a risk (3.1.1) or combination of risks, expressed in terms of the combination of consequences (3.3.18) and their likelihood (3.3.16)</dcterms:description>
        <dcterms:identifier rdf:resource="urn:uuid:eacee9a6-3849-4eed-9f38-82cc281f991a"/>
        <dcterms:source rdf:resource="urn:iso:std:iso:31073:ed-1:v1:term:3.3.22"/>
        <dcterms:subject xml:lang="en">risk management process</dcterms:subject>
        <rdfs:comment xml:lang="en">[SOURCE:ISO Guide 73:2009, 3.6.1.8]</rdfs:comment>
        <rdfs:label xml:lang="en">level of risk</rdfs:label>
    </owl:Class>
    


    <!-- https://haddenindustries.com/ontology/iso/31073/ed-1/term/Likelihood -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/iso/31073/ed-1/term/Likelihood">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/isDescribedBy"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://haddenindustries.com/ontology/iso/31073/ed-1/term/Frequency"/>
                            <rdf:Description rdf:about="https://haddenindustries.com/ontology/iso/31073/ed-1/term/Probability"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dc:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-04-20T08:04:46Z</dcterms:created>
        <dcterms:description xml:lang="en">chance of something happening</dcterms:description>
        <dcterms:identifier rdf:resource="urn:uuid:dba4794d-5594-4734-a733-34196f289098"/>
        <dcterms:source rdf:resource="urn:iso:std:iso:31073:ed-1:v1:term:3.3.16"/>
        <dcterms:subject xml:lang="en">risk management process</dcterms:subject>
        <rdfs:comment xml:lang="en">Note 1 to entry: In risk management terminology, the word “likelihood” is used to refer to the chance of something happening, whether defined, measured or determined objectively or subjectively, qualitatively or quantitatively, and described using general terms or mathematically [such as a probability (3.3.19) or a frequency (3.3.20)].
Note 2 to entry: The English term “likelihood” does not have a direct equivalent in some languages; instead, the equivalent of the term “probability” is often used. However, in English, “probability” is often narrowly interpreted as a mathematical term. Therefore, in risk management terminology, “likelihood” is used with the intent that it should have the same broad interpretation as the term “probability” has in many languages other than English.</rdfs:comment>
        <rdfs:label xml:lang="en">likelihood</rdfs:label>
    </owl:Class>
    


    <!-- https://haddenindustries.com/ontology/iso/31073/ed-1/term/Monitoring -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/iso/31073/ed-1/term/Monitoring">
        <rdfs:subClassOf rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/term/RiskManagementProcess"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/canBeAppliedTo"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://haddenindustries.com/ontology/iso/31073/ed-1/term/Risk"/>
                            <rdf:Description rdf:about="https://haddenindustries.com/ontology/iso/31073/ed-1/term/RiskControl"/>
                            <rdf:Description rdf:about="https://haddenindustries.com/ontology/iso/31073/ed-1/term/RiskManagementProcess"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dc:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-04-20T08:04:46Z</dcterms:created>
        <dcterms:description xml:lang="en">continual checking, supervising, critically observing or determining the status in order to identify change from the performance level required or expected</dcterms:description>
        <dcterms:identifier rdf:resource="urn:uuid:b1ee29a3-54dc-4ece-9130-f56588081d41"/>
        <dcterms:source rdf:resource="urn:iso:std:iso:31073:ed-1:v1:term:3.3.40"/>
        <dcterms:subject xml:lang="en">risk management process</dcterms:subject>
        <rdfs:comment xml:lang="en">Note 1 to entry: Monitoring can be applied to a risk management framework, risk management process (3.3.1), risk (3.1.1) or risk control (3.3.33).
[SOURCE:ISO Guide 73:2009, 3.8.2.1, modified — “risk control” has replaced “control” in Note 1 to entry.]</rdfs:comment>
        <rdfs:label xml:lang="en">monitoring</rdfs:label>
    </owl:Class>
    


    <!-- https://haddenindustries.com/ontology/iso/31073/ed-1/term/Objective -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/iso/31073/ed-1/term/Objective">
        <dc:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-04-20T08:04:46Z</dcterms:created>
        <dcterms:description xml:lang="en">result to be achieved</dcterms:description>
        <dcterms:identifier rdf:resource="urn:uuid:80987a46-8560-4fb8-a764-61255cc917e9"/>
        <dcterms:source rdf:resource="urn:iso:std:iso:31073:ed-1:v1:term:3.1.2"/>
        <dcterms:subject xml:lang="en">risk</dcterms:subject>
        <rdfs:comment xml:lang="en">Note 1 to entry: An objective can be strategic, tactical or operational.
Note 2 to entry: Objectives can relate to different disciplines (such as financial, health and safety, and environmental goals) and can apply at different levels (such as strategic, organization-wide, project, product and process).
Note 3 to entry: An objective can be expressed in other ways, e.g. as an intended outcome, a purpose, an operational criterion, as a management system objective, or by the use of other words with similar meaning (e.g. aim, goal, target).</rdfs:comment>
        <rdfs:label xml:lang="en">objective</rdfs:label>
    </owl:Class>
    


    <!-- https://haddenindustries.com/ontology/iso/31073/ed-1/term/Opportunity -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/iso/31073/ed-1/term/Opportunity">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/isFavourableTo"/>
                <owl:someValuesFrom rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/term/Objective"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dc:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-04-20T08:04:46Z</dcterms:created>
        <dcterms:description xml:lang="en">combination of circumstances expected to be favourable to objectives (3.1.2)</dcterms:description>
        <dcterms:identifier rdf:resource="urn:uuid:bab49423-d96d-41a7-8452-9aff91dcfccb"/>
        <dcterms:source rdf:resource="urn:iso:std:iso:31073:ed-1:v1:term:3.3.23"/>
        <dcterms:subject xml:lang="en">risk management process</dcterms:subject>
        <rdfs:comment xml:lang="en">Note 1 to entry: An opportunity is a positive situation in which gain is likely and over which one has a fair level of control.
Note 2 to entry: An opportunity to one party may pose a threat (3.3.13) to another.
Note 3 to entry: Taking or not taking an opportunity are both sources of risk (3.1.1).
[SOURCE:IEC 31010:2019, 3.2]</rdfs:comment>
        <rdfs:label xml:lang="en">opportunity</rdfs:label>
    </owl:Class>
    


    <!-- https://haddenindustries.com/ontology/iso/31073/ed-1/term/Organization -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/iso/31073/ed-1/term/Organization">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/hasApproach"/>
                <owl:someValuesFrom rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/term/RiskAttitude"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/isExposedTo"/>
                <owl:someValuesFrom rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/term/Exposure"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/operatesIn"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://haddenindustries.com/ontology/iso/31073/ed-1/term/ExternalContext"/>
                            <rdf:Description rdf:about="https://haddenindustries.com/ontology/iso/31073/ed-1/term/InternalContext"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/wantsToAchieve"/>
                <owl:someValuesFrom rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/term/Objective"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dc:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-04-20T08:04:46Z</dcterms:created>
        <dcterms:description xml:lang="en">person or group of people that has its own functions with responsibilities, authorities and relationships to achieve its objectives (3.1.2)</dcterms:description>
        <dcterms:identifier rdf:resource="urn:uuid:95f3deb1-6535-4537-883b-4416f01029f7"/>
        <dcterms:source rdf:resource="urn:iso:std:iso:31073:ed-1:v1:term:3.3.7"/>
        <dcterms:subject xml:lang="en">risk management process</dcterms:subject>
        <rdfs:comment xml:lang="en">Note 1 to entry: The concept of organization includes, but is not limited to, sole-trader, company, corporation, firm, enterprise, authority, partnership, charity or institution, or part or combination thereof, whether incorporated or not, public or private.</rdfs:comment>
        <rdfs:label xml:lang="en">organization</rdfs:label>
    </owl:Class>
    


    <!-- https://haddenindustries.com/ontology/iso/31073/ed-1/term/Probability -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/iso/31073/ed-1/term/Probability">
        <dc:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-04-20T08:04:46Z</dcterms:created>
        <dcterms:description xml:lang="en">measure of the chance of occurrence expressed as a number from 0 to 1, where 0 is impossibility and 1 is absolute certainty</dcterms:description>
        <dcterms:identifier rdf:resource="urn:uuid:9894a103-50bb-4608-bcc3-9b4e9ae75bfd"/>
        <dcterms:source rdf:resource="urn:iso:std:iso:31073:ed-1:v1:term:3.3.19"/>
        <dcterms:subject xml:lang="en">risk management process</dcterms:subject>
        <rdfs:comment xml:lang="en">Note 1 to entry: See 3.3.16, Note 2 to entry.
[SOURCE:IEC 31010:2019, 3.3, modified — The definition has been modified.]</rdfs:comment>
        <rdfs:label xml:lang="en">probability</rdfs:label>
    </owl:Class>
    


    <!-- https://haddenindustries.com/ontology/iso/31073/ed-1/term/ResidualRisk -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/iso/31073/ed-1/term/ResidualRisk">
        <rdfs:subClassOf rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/term/Risk"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/remainsAfter"/>
                <owl:someValuesFrom rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/term/RiskTreatment"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dc:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-04-20T08:04:46Z</dcterms:created>
        <dcterms:description xml:lang="en">risk (3.1.1) remaining after risk treatment (3.3.32)</dcterms:description>
        <dcterms:identifier rdf:resource="urn:uuid:ea319a1f-5124-4638-97ee-9578ad62e254"/>
        <dcterms:source rdf:resource="urn:iso:std:iso:31073:ed-1:v1:term:3.3.38"/>
        <dcterms:subject xml:lang="en">risk management process</dcterms:subject>
        <rdfs:comment xml:lang="en">Note 1 to entry: Residual risk can contain unidentified risk.
Note 2 to entry: Residual risk can also be known as “retained risk”.
[SOURCE:ISO Guide 73:2009, 3.8.1.6]</rdfs:comment>
        <rdfs:label xml:lang="en">residual risk</rdfs:label>
    </owl:Class>
    


    <!-- https://haddenindustries.com/ontology/iso/31073/ed-1/term/Resilience -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/iso/31073/ed-1/term/Resilience">
