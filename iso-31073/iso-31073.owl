        <dcterms:source rdf:resource="urn:iso:std:iso:31073:ed-1:v1:term:3.3.27"/>
        <dcterms:subject xml:lang="en">risk management process</dcterms:subject>
        <rdfs:comment xml:lang="en">[SOURCE:ISO Guide 73:2009, 3.7.1.2]</rdfs:comment>
        <rdfs:label xml:lang="en">risk appetite</rdfs:label>
    </owl:Class>
    


