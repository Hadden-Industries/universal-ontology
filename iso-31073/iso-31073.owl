    <!-- https://haddenindustries.com/ontology/iso/31073/ed-1/term/RiskAvoidance -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/iso/31073/ed-1/term/RiskAvoidance">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/avoids"/>
                <owl:someValuesFrom rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/term/Risk"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dc:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-04-20T08:04:46Z</dcterms:created>
        <dcterms:description xml:lang="en">informed decision not to be involved in, or to withdraw from, an activity in order not to be exposed to a particular risk (3.1.1)</dcterms:description>
        <dcterms:identifier rdf:resource="urn:uuid:ec095286-2fc1-4f34-83d0-269356b46435"/>
        <dcterms:source rdf:resource="urn:iso:std:iso:31073:ed-1:v1:term:3.3.34"/>
        <dcterms:subject xml:lang="en">risk management process</dcterms:subject>
        <rdfs:comment xml:lang="en">Note 1 to entry: Risk avoidance can be based on the result of risk evaluation (3.3.25) and/or legal and regulatory obligations.
[SOURCE:ISO Guide 73:2009, 3.8.1.2]</rdfs:comment>
        <rdfs:label xml:lang="en">risk avoidance</rdfs:label>
    </owl:Class>
    


    <!-- https://haddenindustries.com/ontology/iso/31073/ed-1/term/RiskControl -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/iso/31073/ed-1/term/RiskControl">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/maintainsAndOrModifies"/>
                <owl:someValuesFrom rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/term/Risk"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dc:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-04-20T08:04:46Z</dcterms:created>
        <dcterms:description xml:lang="en">measure that maintains and/or modifies risk (3.1.1)</dcterms:description>
        <dcterms:identifier rdf:resource="urn:uuid:384c3e40-d883-44de-8127-6ce75272e9af"/>
        <dcterms:source rdf:resource="urn:iso:std:iso:31073:ed-1:v1:term:3.3.33"/>
        <dcterms:subject xml:lang="en">risk management process</dcterms:subject>
        <rdfs:comment xml:lang="en">Note 1 to entry: Risk controls include, but are not limited to, any process, policy, device, practice, or other conditions and/or actions which maintain and/or modify risk.
Note 2 to entry: Risk controls do not always exert the intended or assumed modifying effect.</rdfs:comment>
        <rdfs:label xml:lang="en">risk control</rdfs:label>
    </owl:Class>
    


    <!-- https://haddenindustries.com/ontology/iso/31073/ed-1/term/RiskCriteria -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/iso/31073/ed-1/term/RiskCriteria">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/evalutesSignificanceOf"/>
                <owl:someValuesFrom rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/term/Risk"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dc:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-04-20T08:04:46Z</dcterms:created>
        <dcterms:description xml:lang="en">terms of reference against which the significance of risk (3.1.1) is evaluated</dcterms:description>
        <dcterms:identifier rdf:resource="urn:uuid:23a2d9fa-f29c-4aa1-8dee-769d35fdf83a"/>
        <dcterms:source rdf:resource="urn:iso:std:iso:31073:ed-1:v1:term:3.3.6"/>
        <dcterms:subject xml:lang="en">risk management process</dcterms:subject>
        <rdfs:comment xml:lang="en">Note 1 to entry: Risk criteria are based on organizational objectives (3.1.2), and external (3.3.4) and internal context (3.3.5).
Note 2 to entry: Risk criteria can be derived from standards, laws, policies and other requirements.
[SOURCE:ISO Guide 73:2009, 3.3.1.3, modified — “risk” has replaced “a risk” in the definition.]</rdfs:comment>
        <rdfs:label xml:lang="en">risk criteria</rdfs:label>
    </owl:Class>
    


    <!-- https://haddenindustries.com/ontology/iso/31073/ed-1/term/RiskDriver -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/iso/31073/ed-1/term/RiskDriver">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/influences"/>
                <owl:someValuesFrom rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/term/Risk"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dc:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-04-20T08:04:46Z</dcterms:created>
        <dcterms:description xml:lang="en">factor that has a major influence on risk (3.1.1)</dcterms:description>
        <dcterms:identifier rdf:resource="urn:uuid:2632cf37-2fd4-41d5-a422-3700ed10e28c"/>
        <dcterms:source rdf:resource="urn:iso:std:iso:31073:ed-1:v1:term:3.3.24"/>
        <dcterms:subject xml:lang="en">risk management process</dcterms:subject>
        <rdfs:comment xml:lang="en">[SOURCE:IEC 31010:2019, 3.4]</rdfs:comment>
        <rdfs:label xml:lang="en">risk driver</rdfs:label>
    </owl:Class>
    


    <!-- https://haddenindustries.com/ontology/iso/31073/ed-1/term/RiskEvaluation -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/iso/31073/ed-1/term/RiskEvaluation">
        <rdfs:subClassOf rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/term/RiskManagementProcess"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/comparesAgainst"/>
                <owl:someValuesFrom rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/term/RiskCriteria"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/comparesResultsOf"/>
                <owl:someValuesFrom rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/term/RiskAnalysis"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dc:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-04-20T08:04:46Z</dcterms:created>
        <dcterms:description xml:lang="en">process of comparing the results of risk analysis (3.3.15) with risk criteria (3.3.6) to determine whether the risk (3.1.1) is acceptable or tolerable</dcterms:description>
        <dcterms:identifier rdf:resource="urn:uuid:7ca768fb-0d20-43f4-9994-c6149d511fc6"/>
        <dcterms:source rdf:resource="urn:iso:std:iso:31073:ed-1:v1:term:3.3.25"/>
        <dcterms:subject xml:lang="en">risk management process</dcterms:subject>
        <rdfs:comment xml:lang="en">Note 1 to entry: Risk evaluation assists in the decision about risk treatment (3.3.32).
[SOURCE:ISO Guide 73:2009, 3.7.1, modified — “and/or its magnitude” has been deleted from the definition.]</rdfs:comment>
        <rdfs:label xml:lang="en">risk evaluation</rdfs:label>
    </owl:Class>
    


    <!-- https://haddenindustries.com/ontology/iso/31073/ed-1/term/RiskFinancing -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/iso/31073/ed-1/term/RiskFinancing">
        <rdfs:subClassOf rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/term/RiskTreatment"/>
