        <dcterms:description xml:lang="en">statement of the overall intentions and direction of an organization (3.3.7) related to risk management (3.2.1)</dcterms:description>
        <dcterms:identifier rdf:resource="urn:uuid:53e2872c-3627-4e08-ae31-852f85d2b775"/>
        <dcterms:source rdf:resource="urn:iso:std:iso:31073:ed-1:v1:term:3.2.2"/>
        <dcterms:subject xml:lang="en">risk management</dcterms:subject>
        <rdfs:comment xml:lang="en">[SOURCE:ISO Guide 73:2009, 2.1.2]</rdfs:comment>
        <rdfs:label xml:lang="en">risk management policy</rdfs:label>
    </owl:Class>
    


    <!-- https://haddenindustries.com/ontology/iso/31073/ed-1/term/RiskManagementProcess -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/iso/31073/ed-1/term/RiskManagementProcess">
        <dc:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-04-20T08:04:46Z</dcterms:created>
        <dcterms:description xml:lang="en">systematic application of management policies, procedures and practices to the activities of communicating, consulting, establishing the context, and identifying, analysing, evaluating, treating, monitoring (3.3.40) and reviewing risk (3.1.1)</dcterms:description>
        <dcterms:identifier rdf:resource="urn:uuid:bbfab9e5-34c5-4c3e-9a5d-a99b9fa360a7"/>
        <dcterms:source rdf:resource="urn:iso:std:iso:31073:ed-1:v1:term:3.3.1"/>
        <dcterms:subject xml:lang="en">risk management process</dcterms:subject>
        <rdfs:comment xml:lang="en">[SOURCE:ISO Guide 73:2009, 3.3.1.1, modified — “interested parties” has replaced “stakeholders”.]
[SOURCE:ISO Guide 73:2009, 3.1]</rdfs:comment>
        <rdfs:label xml:lang="en">risk management process</rdfs:label>
    </owl:Class>
    


    <!-- https://haddenindustries.com/ontology/iso/31073/ed-1/term/RiskOwner -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/iso/31073/ed-1/term/RiskOwner">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/RiskOwner_manages"/>
                <owl:someValuesFrom rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/term/Risk"/>
            </owl:Restriction>
        </rdfs:subClassOf>
