            <owl:Restriction>
                <owl:onProperty rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/comprehendsTheNatureOf"/>
                <owl:someValuesFrom rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/term/Risk"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/determines"/>
                <owl:someValuesFrom rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/term/LevelOfRisk"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dc:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-04-20T08:04:46Z</dcterms:created>
        <dcterms:description xml:lang="en">process to comprehend the nature of risk (3.1.1) and to determine the level of risk (3.3.22)</dcterms:description>
        <dcterms:identifier rdf:resource="urn:uuid:9bbf8f0b-4010-4ce5-8b6f-7385404f9ea2"/>
        <dcterms:source rdf:resource="urn:iso:std:iso:31073:ed-1:v1:term:3.3.15"/>
        <dcterms:subject xml:lang="en">risk management process</dcterms:subject>
        <rdfs:comment xml:lang="en">Note 1 to entry: Risk analysis provides the basis for risk evaluation (3.3.25) and decisions about risk treatment (3.3.32).
[SOURCE:ISO Guide 73:2009, 3.6.1, modified —Note 2 to entry has been deleted.]</rdfs:comment>
        <rdfs:label xml:lang="en">risk analysis</rdfs:label>
    </owl:Class>
    


