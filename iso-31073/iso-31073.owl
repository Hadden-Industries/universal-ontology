        <dcterms:description xml:lang="en">adaptive capacity of an organization (3.3.7) in a complex and changing environment</dcterms:description>
        <dcterms:identifier rdf:resource="urn:uuid:480918d7-659f-4522-a335-542e5f2b34f2"/>
        <dcterms:source rdf:resource="urn:iso:std:iso:31073:ed-1:v1:term:3.3.39"/>
        <dcterms:subject xml:lang="en">risk management process</dcterms:subject>
        <rdfs:comment xml:lang="en">[SOURCE:ISO Guide 73:2009, 3.8.1.7]</rdfs:comment>
        <rdfs:label xml:lang="en">resilience</rdfs:label>
    </owl:Class>
    


    <!-- https://haddenindustries.com/ontology/iso/31073/ed-1/term/Review -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/iso/31073/ed-1/term/Review">
        <rdfs:subClassOf rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/term/RiskManagementProcess"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/determinesQualityOfTheSubjectMatterToAchieveEstablished"/>
                <owl:someValuesFrom rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/term/Objective"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dc:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-04-20T08:04:46Z</dcterms:created>
        <dcterms:description xml:lang="en">activity undertaken to determine the suitability, adequacy and effectiveness of the subject matter to achieve established objectives (3.1.2)</dcterms:description>
        <dcterms:identifier rdf:resource="urn:uuid:db4bd0f4-9223-4500-a392-dd5942f25312"/>
        <dcterms:source rdf:resource="urn:iso:std:iso:31073:ed-1:v1:term:3.3.41"/>
        <dcterms:subject xml:lang="en">risk management process</dcterms:subject>
        <rdfs:comment xml:lang="en">Note 1 to entry: Review can be applied to a risk management framework, risk management process (3.3.1), risk (3.1.1) or risk control (3.3.33).
[SOURCE:ISO Guide 73:2009, 3.8.2.2, modified — “risk control” has replaced “control” in Note 1 to entry.]</rdfs:comment>
        <rdfs:label xml:lang="en">review</rdfs:label>
    </owl:Class>
    


    <!-- https://haddenindustries.com/ontology/iso/31073/ed-1/term/Risk -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/iso/31073/ed-1/term/Risk">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/hasEffectOn"/>
                <owl:someValuesFrom rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/term/Objective"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/isEffectOf"/>
                <owl:someValuesFrom rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/term/Uncertainty"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dc:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-04-20T08:04:46Z</dcterms:created>
        <dcterms:description xml:lang="en">effect of uncertainty (3.1.3) on objectives (3.1.2)</dcterms:description>
        <dcterms:identifier rdf:resource="urn:uuid:d501ae7c-bb44-4eb2-b0fc-2f59eb5b3afe"/>
        <dcterms:source rdf:resource="urn:iso:std:iso:31073:ed-1:v1:term:3.1.1"/>
        <dcterms:subject xml:lang="en">risk</dcterms:subject>
        <rdfs:comment xml:lang="en">Note 1 to entry: An effect is a deviation from the expected. It can be positive, negative or both, and can address, create or result in opportunities (3.3.23) and threats (3.3.13).
Note 2 to entry: Objectives can have different aspects and categories, and can be applied at different levels.
Note 3 to entry: Risk is usually expressed in terms of risk sources (3.3.10), potential events (3.3.11), their consequences (3.3.18) and their likelihood (3.3.16).</rdfs:comment>
        <rdfs:label xml:lang="en">risk</rdfs:label>
    </owl:Class>
    


    <!-- https://haddenindustries.com/ontology/iso/31073/ed-1/term/RiskAcceptance -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/iso/31073/ed-1/term/RiskAcceptance">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/accepts"/>
                <owl:someValuesFrom rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/term/Risk"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/term/RiskAvoidance"/>
        <dc:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-04-20T08:04:46Z</dcterms:created>
        <dcterms:description xml:lang="en">informed decision to take a particular risk (3.1.1)</dcterms:description>
        <dcterms:identifier rdf:resource="urn:uuid:b01e128a-fd97-48fe-8caa-d0b5d648f33b"/>
        <dcterms:source rdf:resource="urn:iso:std:iso:31073:ed-1:v1:term:3.3.31"/>
        <dcterms:subject xml:lang="en">risk management process</dcterms:subject>
        <rdfs:comment xml:lang="en">Note 1 to entry: Risk acceptance can occur without risk treatment (3.3.32) or during the process of risk treatment.
Note 2 to entry: Accepted risks are subject to monitoring (3.3.40) and review (3.3.41).
[SOURCE:ISO Guide 73:2009, 3.7.1.6]</rdfs:comment>
        <rdfs:label xml:lang="en">risk acceptance</rdfs:label>
    </owl:Class>
    


    <!-- https://haddenindustries.com/ontology/iso/31073/ed-1/term/RiskAggregation -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/iso/31073/ed-1/term/RiskAggregation">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/combinesANumberOf"/>
                <owl:someValuesFrom rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/term/Risk"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/combinesInto"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/term/Risk"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dc:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-04-20T08:04:46Z</dcterms:created>
        <dcterms:description xml:lang="en">combination of a number of risks (3.1.1) into one risk to develop a more complete understanding of the overall risk</dcterms:description>
        <dcterms:identifier rdf:resource="urn:uuid:cf738e41-f669-4ed0-95c2-25e91e21956b"/>
        <dcterms:source rdf:resource="urn:iso:std:iso:31073:ed-1:v1:term:3.3.30"/>
        <dcterms:subject xml:lang="en">risk management process</dcterms:subject>
        <rdfs:comment xml:lang="en">[SOURCE:ISO Guide 73:2009, 3.7.1.5]</rdfs:comment>
        <rdfs:label xml:lang="en">risk aggregation</rdfs:label>
    </owl:Class>
    


    <!-- https://haddenindustries.com/ontology/iso/31073/ed-1/term/RiskAnalysis -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/iso/31073/ed-1/term/RiskAnalysis">
        <rdfs:subClassOf rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/term/RiskManagementProcess"/>
