        <dcterms:description xml:lang="en">coordinated activities to direct and control an organization (3.3.7) with regard to risk (3.1.1)</dcterms:description>
        <dcterms:identifier rdf:resource="urn:uuid:930d4063-18f2-4e18-aec6-bf95aacab77b"/>
        <dcterms:source rdf:resource="urn:iso:std:iso:31073:ed-1:v1:term:3.2.1"/>
        <dcterms:subject xml:lang="en">risk management</dcterms:subject>
        <rdfs:label xml:lang="en">risk management</rdfs:label>
    </owl:Class>
    


    <!-- https://haddenindustries.com/ontology/iso/31073/ed-1/term/RiskManagementAudit -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/iso/31073/ed-1/term/RiskManagementAudit">
        <rdfs:subClassOf rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/term/RiskManagementProcess"/>
        <dc:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-04-20T08:04:46Z</dcterms:created>
        <dcterms:description xml:lang="en">systematic, independent and documented process for obtaining evidence and evaluating it objectively in order to determine the extent to which the risk management framework, or any selected part of it, is adequate and effective</dcterms:description>
        <dcterms:identifier rdf:resource="urn:uuid:987c5970-71fa-43f6-a102-7e9995cc4f01"/>
        <dcterms:source rdf:resource="urn:iso:std:iso:31073:ed-1:v1:term:3.3.43"/>
        <dcterms:subject xml:lang="en">risk management process</dcterms:subject>
        <rdfs:comment xml:lang="en">[SOURCE:ISO Guide 73:2009, 3.8.2.6]</rdfs:comment>
        <rdfs:label xml:lang="en">risk management audit</rdfs:label>
    </owl:Class>
    


    <!-- https://haddenindustries.com/ontology/iso/31073/ed-1/term/RiskManagementPlan -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/iso/31073/ed-1/term/RiskManagementPlan">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/isAppliedTo"/>
                <owl:someValuesFrom rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/term/RiskManagement"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dc:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-04-20T08:04:46Z</dcterms:created>
        <dcterms:description xml:lang="en">scheme within the risk management framework specifying the approach, the management components and resources to be applied to the management of risk (3.1.1)</dcterms:description>
        <dcterms:identifier rdf:resource="urn:uuid:315d0faa-b940-4625-9bee-ffea9929e851"/>
        <dcterms:source rdf:resource="urn:iso:std:iso:31073:ed-1:v1:term:3.2.3"/>
        <dcterms:subject xml:lang="en">risk management</dcterms:subject>
        <rdfs:comment xml:lang="en">Note 1 to entry: Management components typically include procedures, practices, assignment of responsibilities, sequence and timing of activities.
Note 2 to entry: The risk management plan can be applied to a particular product, process and project, and part or whole of the organization (3.3.7).
[SOURCE:ISO Guide 73:2009, 2.1.3]</rdfs:comment>
        <rdfs:label xml:lang="en">risk management plan</rdfs:label>
    </owl:Class>
    


    <!-- https://haddenindustries.com/ontology/iso/31073/ed-1/term/RiskManagementPolicy -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/iso/31073/ed-1/term/RiskManagementPolicy">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/relatesTo"/>
                <owl:someValuesFrom rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/term/RiskManagement"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/statesOverallIntentionsAndDirectionOf"/>
                <owl:someValuesFrom rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/term/Organization"/>
            </owl:Restriction>
        </rdfs:subClassOf>
