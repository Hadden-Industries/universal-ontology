    </owl:Class>
    


    <!-- https://haddenindustries.com/ontology/iso/31073/ed-1/term/RiskIdentification -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/iso/31073/ed-1/term/RiskIdentification">
        <rdfs:subClassOf rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/term/RiskManagementProcess"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/findsRecognisesDescribes"/>
                <owl:someValuesFrom rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/term/Risk"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dc:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-04-20T08:04:46Z</dcterms:created>
        <dcterms:description xml:lang="en">process of finding, recognizing and describing risks (3.1.1)</dcterms:description>
        <dcterms:identifier rdf:resource="urn:uuid:ddd065ca-b3b0-40d7-a077-140055db1b38"/>
        <dcterms:source rdf:resource="urn:iso:std:iso:31073:ed-1:v1:term:3.3.9"/>
        <dcterms:subject xml:lang="en">risk management process</dcterms:subject>
        <rdfs:comment xml:lang="en">Note 1 to entry: Risk identification involves the identification of risk sources (3.3.10), events (3.3.11), their causes and their potential consequences (3.3.18).
Note 2 to entry: Risk identification can involve historical data, theoretical analysis, informed and expert opinions, and interested party’s (3.3.2) needs.
[SOURCE:ISO Guide 73:2009, 3.5.1, modified — “interested party” has replaced “stakeholder”.]</rdfs:comment>
        <rdfs:label xml:lang="en">risk identification</rdfs:label>
    </owl:Class>
    


    <!-- https://haddenindustries.com/ontology/iso/31073/ed-1/term/RiskManagement -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/iso/31073/ed-1/term/RiskManagement">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/directsAndControls"/>
                <owl:someValuesFrom rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/term/Organization"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://haddenindustries.com/ontology/iso/31073/ed-1/manages"/>
