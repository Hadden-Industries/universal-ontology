        <dcterms:identifier rdf:resource="urn:uuid:afc4b62e-ba03-4ef8-aa9a-8e66be1fba7b"/>
        <dcterms:source rdf:resource="urn:iso:std:iso:31073:ed-1:v1:term:3.3.8"/>
        <dcterms:subject xml:lang="en">risk management process</dcterms:subject>
        <rdfs:comment xml:lang="en">[SOURCE:ISO Guide 73:2009, 3.4.1]</rdfs:comment>
        <rdfs:label xml:lang="en">risk assessment</rdfs:label>
    </owl:Class>
    


    <!-- https://haddenindustries.com/ontology/iso/31073/ed-1/term/RiskAttitude -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/iso/31073/ed-1/term/RiskAttitude">
