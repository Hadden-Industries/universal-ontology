    <rdfs:label xml:lang="en">Data Element</rdfs:label>
    <skos:definition xml:lang="en">unit of data (3.2.29) that is considered in context to be indivisible</skos:definition>
    <skos:example xml:lang="en">The data element “age of a person” with values consisting of all combinations of 3 decimal digits</skos:example>
