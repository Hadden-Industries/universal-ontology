    <dcterms:identifier rdf:resource="urn:uuid:9dd7c0c6-05a6-46b1-8b52-9fdd8d8c9c80"/>
    <rdfs:label xml:lang="en">Postal_Address</rdfs:label>
    <skos:definition xml:lang="en">datatype that denotes a postal address. A postal address enables the unambiguous determination of an actual or potential delivery point, usually combined with the specification of an addressee or a mailee. The data structure of Postal_Address may conform to ISO/IEC 19773[30] Module 16: Data Structure for UPU postal data[38].</skos:definition>
    <skos:scopeNote xml:lang="en">ISO/IEC 19773 is referenced but not required</skos:scopeNote>
  </rdfs:Datatype>
