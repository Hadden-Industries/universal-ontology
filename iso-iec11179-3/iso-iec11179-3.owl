    </owl:DatatypeProperty>
    


    <!-- https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/Slot_name -->

    <owl:DatatypeProperty rdf:about="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/Slot_name">
        <rdfs:domain rdf:resource="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/term/Slot"/>
        <rdfs:range rdf:resource="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/stringDatatype"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-04-04T13:17:17Z</dcterms:created>
        <dcterms:creator rdf:resource="https://orcid.org/0000-0001-8017-8797"/>
        <dcterms:source rdf:resource="urn:iso:std:iso-iec:11179:-3:ed-4:v1:clause:6.4.2.4.3"/>
        <rdfs:label xml:lang="en">name</rdfs:label>
        <skos:definition xml:lang="en">name of the slot</skos:definition>
        <skos:note xml:lang="en">Constraint: All Slot instances associated with a particular Item instance shall have a distinct name to allow each Slot instance to be unambiguously identified</skos:note>
        <skos:prefLabel xml:lang="en">name</skos:prefLabel>
    </owl:DatatypeProperty>
    


    <!-- https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/Slot_type -->

