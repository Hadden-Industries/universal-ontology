        <rdfs:label xml:lang="en">Naming Convention</rdfs:label>
        <skos:definition xml:lang="en">specification of how signs (3.2.10) of designations (3.2.11), scoped identifiers (3.2.62) or both are formulated</skos:definition>
        <skos:prefLabel xml:lang="en">Naming Convention</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A naming convention can apply to scoped identifiers when they are included in the associated namespace (3.2.13)</skos:scopeNote>
    </owl:Class>
