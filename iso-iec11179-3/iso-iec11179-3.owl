    <!-- https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/Role_role_name -->

    <owl:DatatypeProperty rdf:about="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/Role_role_name">
        <rdfs:domain rdf:resource="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/term/Role"/>
