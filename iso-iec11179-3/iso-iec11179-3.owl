            </owl:Restriction>
        </rdfs:subClassOf>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2020-05-21T11:45:06Z</dcterms:created>
        <dcterms:creator rdf:resource="https://orcid.org/0000-0001-8017-8797"/>
        <dcterms:identifier rdf:resource="urn:iso:std:iso-iec:11179:-3:ed-4:v1:term:3.2.43"/>
        <dcterms:identifier rdf:resource="urn:uuid:0c2bc95b-f121-4aff-bc5a-f7849f589373"/>
        <dcterms:source rdf:resource="urn:iso:std:iso-iec:2382:ed-1:v2:term:2121599"/>
        <dcterms:subject xml:lang="en-us">organization of data</dcterms:subject>
        <rdfs:label xml:lang="en">Data Element</rdfs:label>
        <skos:definition xml:lang="en">unit of data (3.2.29) that is considered in context to be indivisible</skos:definition>
        <skos:example xml:lang="en">The data element “age of a person” with values consisting of all combinations of 3 decimal digits</skos:example>
        <skos:prefLabel xml:lang="en">Data Element</skos:prefLabel>
        <skos:scopeNote xml:lang="en">The definition states that a data element is “indivisible” in some context. This means that it is possible that a data element considered indivisible in one context (e.g. telephone number) can be divisible in another context, (e.g. country code, area code, local number).</skos:scopeNote>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/term/DataElement"/>
        <owl:annotatedProperty rdf:resource="http://purl.org/dc/terms/source"/>
        <owl:annotatedTarget rdf:resource="urn:iso:std:iso-iec:2382:ed-1:v2:term:2121599"/>
        <skos:note xml:lang="en">modified — Note 1 to entry label removed from the example. Note 2 to entry replaced and renumbered as Note 1, Note 3 to entry deleted.</skos:note>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/term/DataElement"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#scopeNote"/>
        <owl:annotatedTarget xml:lang="en">The definition states that a data element is “indivisible” in some context. This means that it is possible that a data element considered indivisible in one context (e.g. telephone number) can be divisible in another context, (e.g. country code, area code, local number).</owl:annotatedTarget>
        <schema:position rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</schema:position>
    </owl:Axiom>
    


