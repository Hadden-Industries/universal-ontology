        <rdfs:label xml:lang="en">Namespace</rdfs:label>
        <skos:definition xml:lang="en">set of designations (3.2.11), scoped identifiers (3.2.62) or both for a particular business need</skos:definition>
        <skos:prefLabel xml:lang="en">Namespace</skos:prefLabel>
        <skos:scopeNote xml:lang="en">The term namespace is used in this document because it is in common use, even though the concept is being applied to identifiers as well as names</skos:scopeNote>
