        <rdfs:label xml:lang="en">effective_date</rdfs:label>
        <skos:definition xml:lang="en">date and time the administered item that is the subject of the registration with this registration status became or becomes available to registry users</skos:definition>
        <skos:prefLabel xml:lang="en">effective_date</skos:prefLabel>
    </owl:DatatypeProperty>
    


    <!-- https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/RegistrationState_unresolved_issue -->

    <owl:DatatypeProperty rdf:about="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/RegistrationState_unresolved_issue">
        <rdfs:domain rdf:resource="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/term/RegistrationState"/>
        <rdfs:range rdf:resource="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/textDatatype"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-04T08:51:16Z</dcterms:created>
        <dcterms:creator rdf:resource="https://orcid.org/0000-0001-8017-8797"/>
        <dcterms:source rdf:resource="urn:iso:std:iso-iec:11179:-3:ed-4:v1:clause:9.4.4.3"/>
        <rdfs:label xml:lang="en">unresolved_issue</rdfs:label>
        <skos:definition xml:lang="en">any problem(s) that remains unresolved regarding proper documentation of the administered item that is the subject of the registration with this registration status</skos:definition>
        <skos:prefLabel xml:lang="en">unresolved_issue</skos:prefLabel>
    </owl:DatatypeProperty>
    


    <!-- https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/RegistrationState_until_date -->

    <owl:DatatypeProperty rdf:about="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/RegistrationState_until_date">
        <rdfs:domain rdf:resource="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/term/RegistrationState"/>
        <rdfs:range rdf:resource="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/datetimeDatatype"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-04T08:47:52Z</dcterms:created>
        <dcterms:creator rdf:resource="https://orcid.org/0000-0001-8017-8797"/>
        <dcterms:source rdf:resource="urn:iso:std:iso-iec:11179:-3:ed-4:v1:clause:9.4.4.3"/>
        <rdfs:label xml:lang="en">until_date</rdfs:label>
        <skos:definition xml:lang="en">date and time the registration by the registration authority in the registry of the administered item that is the subject of the registration with this registration status was, or will be, no longer effective</skos:definition>
        <skos:prefLabel xml:lang="en">until_date</skos:prefLabel>
    </owl:DatatypeProperty>
    


    <!-- https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/RegistrySpecification_character_repertoire -->

    <owl:DatatypeProperty rdf:about="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/RegistrySpecification_character_repertoire">
        <rdfs:domain rdf:resource="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/term/RegistrySpecification"/>
        <rdfs:range rdf:resource="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/stringDatatype"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-04-19T17:53:30Z</dcterms:created>
        <dcterms:creator rdf:resource="https://orcid.org/0000-0001-8017-8797"/>
        <dcterms:source rdf:resource="urn:iso:std:iso-iec:11179:-3:ed-4:v1:clause:9.4.10.3"/>
        <rdfs:label xml:lang="en">character_repertoire</rdfs:label>
        <skos:definition xml:lang="en">The character repertoire that is used by the registry for internal operation</skos:definition>
        <skos:example xml:lang="en">ISO/IEC 646[3] or ISO/IEC 10646[10]</skos:example>
        <skos:prefLabel xml:lang="en">character_repertoire</skos:prefLabel>
    </owl:DatatypeProperty>
    


    <!-- https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/RegistrySpecification_comment -->

    <owl:DatatypeProperty rdf:about="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/RegistrySpecification_comment">
