    <!-- https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/booleanDatatype -->

    <rdfs:Datatype rdf:about="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/booleanDatatype">
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2020-07-09T17:14:23Z</dcterms:created>
        <dcterms:creator rdf:resource="https://orcid.org/0000-0001-8017-8797"/>
        <dcterms:identifier rdf:resource="urn:iso:std:iso-iec:11179:-3:ed-4:v1:clause:6.2.2"/>
        <dcterms:identifier rdf:resource="urn:uuid:179b1e5e-e9bf-4ac2-a8ae-fa7af316158c"/>
        <rdfs:label xml:lang="en">Boolean</rdfs:label>
        <skos:definition xml:lang="en">mathematical datatype associated with two-valued logic.
The notation and semantics for Boolean shall be in accordance with ISO/IEC 11404:2007, 8.1.1 Boolean.</skos:definition>
    </rdfs:Datatype>
    


    <!-- https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/dateDatatype -->

    <rdfs:Datatype rdf:about="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/dateDatatype">
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2020-07-09T17:14:32Z</dcterms:created>
        <dcterms:creator rdf:resource="https://orcid.org/0000-0001-8017-8797"/>
        <dcterms:identifier rdf:resource="urn:iso:std:iso-iec:11179:-3:ed-4:v1:clause:6.2.4"/>
        <dcterms:identifier rdf:resource="urn:uuid:af371ad6-417f-45a4-a36c-6d989fbb81f4"/>
        <rdfs:label xml:lang="en">Date</rdfs:label>
        <skos:definition xml:lang="en">datatype whose values are points in time to the resolution: year, month and day.
The notation and semantics for Date shall be in accordance with ISO/IEC 11404:2007, 8.1.6 Date-and-Time.</skos:definition>
    </rdfs:Datatype>
    


    <!-- https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/datetimeDatatype -->

    <rdfs:Datatype rdf:about="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/datetimeDatatype">
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2020-07-09T17:15:29Z</dcterms:created>
        <dcterms:creator rdf:resource="https://orcid.org/0000-0001-8017-8797"/>
        <dcterms:identifier rdf:resource="urn:iso:std:iso-iec:11179:-3:ed-4:v1:clause:6.2.3"/>
        <dcterms:identifier rdf:resource="urn:uuid:77f4ed9f-2a88-40dc-bd13-0e755618cc83"/>
        <rdfs:label xml:lang="en">Datetime</rdfs:label>
        <skos:definition xml:lang="en">datatype whose values are points in time to the resolution: year, month, day, hour, minute, second and optionally fractions of seconds.
The notation and semantics for Datetime shall be in accordance with ISO/IEC 11404:2007, 8.1.6 Date-and-Time, with the addition of a timezone specification as per ISO 8601 basic format.</skos:definition>
    </rdfs:Datatype>
    


    <!-- https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/integerDatatype -->

    <rdfs:Datatype rdf:about="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/integerDatatype">
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2020-07-09T17:15:43Z</dcterms:created>
        <dcterms:creator rdf:resource="https://orcid.org/0000-0001-8017-8797"/>
        <dcterms:identifier rdf:resource="urn:iso:std:iso-iec:11179:-3:ed-4:v1:clause:6.2.5"/>
        <dcterms:identifier rdf:resource="urn:uuid:88855b10-ba39-40b6-a4d0-2b38f00becf2"/>
        <rdfs:label xml:lang="en">Integer</rdfs:label>
        <skos:definition xml:lang="en">mathematical datatype comprising the exact integral values.
The notation and semantics for Integer shall be in accordance with ISO/IEC 11404:2007, 8.1.7 Integer.</skos:definition>
    </rdfs:Datatype>
    


    <!-- https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/natural_RangeDatatype -->

    <rdfs:Datatype rdf:about="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/natural_RangeDatatype">
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2020-07-09T17:16:26Z</dcterms:created>
        <dcterms:creator rdf:resource="https://orcid.org/0000-0001-8017-8797"/>
        <dcterms:identifier rdf:resource="urn:iso:std:iso-iec:11179:-3:ed-4:v1:clause:6.2.6"/>
        <dcterms:identifier rdf:resource="urn:uuid:ee2305b1-8272-4324-89b2-431289df2d0d"/>
        <rdfs:label xml:lang="en">Natural_Range</rdfs:label>
        <skos:definition xml:lang="en">datatype comprising a range of “natural numbers”, i.e. the positive integers, including zero. Any instance of Natural_Range is one of:
— a constant non-negative integer;
— a bounded range of non-negative integers defined by a minimum and a (strictly larger) maximum value;
— an unbounded range defined by only a non-negative minimum (e.g. 0..*, 1..*, 2..*).</skos:definition>
    </rdfs:Datatype>
    


    <!-- https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/notationDatatype -->

    <rdfs:Datatype rdf:about="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/notationDatatype">
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2020-07-09T17:17:09Z</dcterms:created>
        <dcterms:creator rdf:resource="https://orcid.org/0000-0001-8017-8797"/>
        <dcterms:identifier rdf:resource="urn:iso:std:iso-iec:11179:-3:ed-4:v1:clause:6.2.7"/>
        <dcterms:identifier rdf:resource="urn:uuid:2fe3f5bf-4dba-4902-abb0-399a1c4dbb28"/>
        <rdfs:label xml:lang="en">Notation</rdfs:label>
        <skos:definition xml:lang="en">datatype that denotes a notation defined elsewhere but used by an item within the registry. A notation defines a formal syntax and semantics, meant for machine processing. In this metamodel, Notation is used by Reference_Document (6.3.8).</skos:definition>
        <skos:example xml:lang="en">XCL Common Logic (ISO/IEC 24707[31]) or OWL-DL XML notation</skos:example>
    </rdfs:Datatype>
    


    <!-- https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/phone_NumberDatatype -->

    <rdfs:Datatype rdf:about="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/phone_NumberDatatype">
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2020-07-09T17:18:08Z</dcterms:created>
        <dcterms:creator rdf:resource="https://orcid.org/0000-0001-8017-8797"/>
        <dcterms:identifier rdf:resource="urn:iso:std:iso-iec:11179:-3:ed-4:v1:clause:6.2.8"/>
        <dcterms:identifier rdf:resource="urn:uuid:b48d17cf-d0ba-4278-b154-a581a8d32334"/>
        <rdfs:label xml:lang="en">Phone_Number</rdfs:label>
        <skos:definition xml:lang="en">datatype that denotes a phone number. A phone number uniquely identifies a telephone line within a telephone network. The data structure of the Phone_Number datatype shall conform to ITU-T Recommendation E 164[35] and may conform to ISO/IEC 19773[30] Module 17: Data structure for ITU-T E.164 phone number data.</skos:definition>
        <skos:scopeNote xml:lang="en">ISO/IEC 19773 is referenced but not required</skos:scopeNote>
    </rdfs:Datatype>
    


    <!-- https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/postal_AddressDatatype -->

    <rdfs:Datatype rdf:about="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/postal_AddressDatatype">
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2020-07-09T17:19:01Z</dcterms:created>
        <dcterms:creator rdf:resource="https://orcid.org/0000-0001-8017-8797"/>
        <dcterms:identifier rdf:resource="urn:iso:std:iso-iec:11179:-3:ed-4:v1:clause:6.2.9"/>
        <dcterms:identifier rdf:resource="urn:uuid:9dd7c0c6-05a6-46b1-8b52-9fdd8d8c9c80"/>
        <rdfs:label xml:lang="en">Postal_Address</rdfs:label>
        <skos:definition xml:lang="en">datatype that denotes a postal address. A postal address enables the unambiguous determination of an actual or potential delivery point, usually combined with the specification of an addressee or a mailee. The data structure of Postal_Address may conform to ISO/IEC 19773[30] Module 16: Data Structure for UPU postal data[38].</skos:definition>
        <skos:scopeNote xml:lang="en">ISO/IEC 19773 is referenced but not required</skos:scopeNote>
    </rdfs:Datatype>
    


    <!-- https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/signDatatype -->

    <rdfs:Datatype rdf:about="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/signDatatype">
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2020-07-09T17:19:15Z</dcterms:created>
        <dcterms:creator rdf:resource="https://orcid.org/0000-0001-8017-8797"/>
        <dcterms:identifier rdf:resource="urn:iso:std:iso-iec:11179:-3:ed-4:v1:clause:6.2.10"/>
        <dcterms:identifier rdf:resource="urn:uuid:4172bcd9-7a2b-467f-8aaa-c97d16d6d2b5"/>
        <rdfs:label xml:lang="en">Sign</rdfs:label>
        <skos:definition xml:lang="en">datatype that denotes a sign. A sign can be a character string, graphic image, sound clip or other symbol that can be used to denote or designate a concept. The Sign datatype can be implemented using the Reflit(of_type) data structure of ISO/IEC 19773:2011[30], 10.4.2, where the list of supported types is implementation defined. At a minimum, datatype String (6.2.11) shall be supported.</skos:definition>
        <skos:scopeNote xml:lang="en">ISO/IEC 19773 is referenced but not required</skos:scopeNote>
    </rdfs:Datatype>
    


    <!-- https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/stringDatatype -->

    <rdfs:Datatype rdf:about="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/stringDatatype">
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2020-07-09T17:14:03Z</dcterms:created>
        <dcterms:creator rdf:resource="https://orcid.org/0000-0001-8017-8797"/>
        <dcterms:identifier rdf:resource="urn:iso:std:iso-iec:11179:-3:ed-4:v1:clause:6.2.11"/>
        <dcterms:identifier rdf:resource="urn:uuid:df76d502-234d-46d5-9245-4d5717173b14"/>
        <rdfs:label xml:lang="en">String</rdfs:label>
        <skos:definition xml:lang="en">family of datatypes which represent strings of symbols from standard character-sets. The syntax and semantics of the String datatype are as defined in ISO/IEC 11404:2007, 10.1.5 Character String.</skos:definition>
    </rdfs:Datatype>
    


    <!-- https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/textDatatype -->

    <rdfs:Datatype rdf:about="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/textDatatype">
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2020-07-09T17:13:54Z</dcterms:created>
        <dcterms:creator rdf:resource="https://orcid.org/0000-0001-8017-8797"/>
        <dcterms:identifier rdf:resource="urn:iso:std:iso-iec:11179:-3:ed-4:v1:clause:6.2.12"/>
        <dcterms:identifier rdf:resource="urn:uuid:e9310294-bf96-420d-a7d4-3310acbd0c97"/>
        <rdfs:label xml:lang="en">Text</rdfs:label>
        <skos:definition xml:lang="en">datatype that denotes text, data in the form of characters, symbols, words, phrases, paragraphs, sentences, tables, or other character arrangements, intended to convey a meaning, and whose interpretation is essentially based upon the reader&apos;s knowledge of some natural language or artificial language.
Where multilingual text is required, the Text datatype can be implemented using the multitext data structure of ISO/IEC 19773:2011, 12.3.3[30].</skos:definition>
        <skos:example xml:lang="en">A business letter printed on paper or displayed on a screen</skos:example>
        <skos:scopeNote xml:lang="en">ISO/IEC 19773 is referenced but not required</skos:scopeNote>
    </rdfs:Datatype>
    


    <!-- https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/valueDatatype -->

    <rdfs:Datatype rdf:about="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/valueDatatype">
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2020-07-09T17:19:57Z</dcterms:created>
        <dcterms:creator rdf:resource="https://orcid.org/0000-0001-8017-8797"/>
        <dcterms:identifier rdf:resource="urn:iso:std:iso-iec:11179:-3:ed-4:v1:clause:6.2.13"/>
        <dcterms:identifier rdf:resource="urn:uuid:6ce690e1-6800-4bcd-a6e0-52b400dfb695"/>
        <rdfs:label xml:lang="en">Value</rdfs:label>
        <skos:definition xml:lang="en">datatype that represents any instance of any other datatype</skos:definition>
    </rdfs:Datatype>
    


