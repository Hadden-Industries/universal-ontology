        <rdfs:label xml:lang="en">Item Mapping Degree</rdfs:label>
        <skos:definition xml:lang="en">an enumerated datatype with values as shown in Table 35</skos:definition>
        <skos:prefLabel xml:lang="en">Item Mapping Degree</skos:prefLabel>
