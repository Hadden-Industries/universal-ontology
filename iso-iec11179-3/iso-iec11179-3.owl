        <rdfs:label xml:lang="en">Identifier</rdfs:label>
        <skos:definition xml:lang="en">sequence of characters, capable of uniquely identifying that with which it is associated, within a specified context (3.2.15)</skos:definition>
        <skos:prefLabel xml:lang="en">Identifier</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Unlike a name (3.2.12), an identifier is linguistically neutral</skos:scopeNote>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/term/Identifier"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#scopeNote"/>
        <owl:annotatedTarget xml:lang="en">Unlike a name (3.2.12), an identifier is linguistically neutral</owl:annotatedTarget>
        <schema:position rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</schema:position>
    </owl:Axiom>
    


