    </owl:DatatypeProperty>
    


    <!-- https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/extension_identifier -->

    <owl:DatatypeProperty rdf:about="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/extension_identifier">
        <rdfs:domain rdf:resource="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/term/LanguageIdentification"/>
        <rdfs:range rdf:resource="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/stringDatatype"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2020-05-21T17:47:49Z</dcterms:created>
        <dcterms:creator rdf:resource="https://orcid.org/0000-0001-8017-8797"/>
        <dcterms:source rdf:resource="urn:iso:std:iso-iec:11179:-3:ed-4:v1:clause:6.3.7.2"/>
        <rdfs:label xml:lang="en">extension_identifier</rdfs:label>
        <skos:definition xml:lang="en">identifier for an extension to a language_identifier</skos:definition>
        <skos:note xml:lang="en">Recommendation: Use of RFC 5646[33] is recommended but not required.
Constraint: In RFC 5646, extension identifiers are ordered and consist of key-value pairs, separated by the EQUALS SIGN (=). The values shall be alphanumeric with no embedded whitespace. Whitespace separates the identifiers.</skos:note>
        <skos:note xml:lang="en">The u- extension is defined in RFC 6067[34], which points to the Unicode Consortium&apos;s Common Locale Data Repository (CLDR) for details on the subtags that follow it</skos:note>
        <skos:prefLabel xml:lang="en">extension_identifier</skos:prefLabel>
    </owl:DatatypeProperty>
    


    <!-- https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/full_expansion -->

    <owl:DatatypeProperty rdf:about="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/full_expansion">
        <rdfs:domain rdf:resource="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/term/ScopedIdentifier"/>
        <rdfs:range rdf:resource="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/stringDatatype"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2020-05-21T18:02:36Z</dcterms:created>
        <dcterms:creator rdf:resource="https://orcid.org/0000-0001-8017-8797"/>
        <dcterms:source rdf:resource="urn:iso:std:iso-iec:11179:-3:ed-4:v1:clause:7.3.2.3"/>
        <rdfs:label xml:lang="en">full_expansion</rdfs:label>
        <skos:definition xml:lang="en">string providing a representation of this scoped identifier, in which the unique identifier of the linked namespace is combined in some way with the identifier of this scoped identifier to fully specify the scope</skos:definition>
        <skos:note xml:lang="en">Conditional, derived.
Condition: full_expansion is defined only when Namespace has exactly one identifier.
Derivation: The precise manner of derivation can vary depending on the type of namespace.</skos:note>
        <skos:prefLabel xml:lang="en">full_expansion</skos:prefLabel>
    </owl:DatatypeProperty>
    


    <!-- https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/geopolitical_territory_identifier -->

    <owl:DatatypeProperty rdf:about="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/geopolitical_territory_identifier">
        <rdfs:domain rdf:resource="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/term/LanguageIdentification"/>
        <rdfs:range rdf:resource="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/stringDatatype"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2020-05-21T17:47:33Z</dcterms:created>
        <dcterms:creator rdf:resource="https://orcid.org/0000-0001-8017-8797"/>
        <dcterms:source rdf:resource="urn:iso:std:iso-iec:11179:-3:ed-4:v1:clause:6.3.7.2"/>
        <rdfs:label xml:lang="en">geopolitical_territory_identifier</rdfs:label>
        <skos:definition xml:lang="en">identifier for a specific country, territory or region whose linguistic variations apply</skos:definition>
        <skos:note xml:lang="en">Recommendation: Use of the three-digit numeric codes from ISO 3166-1[6], with extensions if needed, is recommended but not required.</skos:note>
        <skos:prefLabel xml:lang="en">geopolitical_territory_identifier</skos:prefLabel>
    </owl:DatatypeProperty>
    


    <!-- https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/hierarchy_level -->

