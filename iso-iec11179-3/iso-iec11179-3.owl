        <rdfs:label xml:lang="en">subtype of</rdfs:label>
        <skos:definition xml:lang="en">Indicates that the creator of the mapping has asserted the object item(s) are an implementation of the subject item(s) and additionally that the subject item(s) satisfy requirements for participating in computing operation(s) in some framework which will also compute on the object item(s). Inverse of “supertype of”.</skos:definition>
        <skos:prefLabel xml:lang="en">subtype of</skos:prefLabel>
    </owl:NamedIndividual>
    


