    <!-- https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/ScopedIdentifier_identifier -->

    <owl:DatatypeProperty rdf:about="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/ScopedIdentifier_identifier">
        <rdfs:domain rdf:resource="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/term/ScopedIdentifier"/>
        <rdfs:range rdf:resource="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/stringDatatype"/>
