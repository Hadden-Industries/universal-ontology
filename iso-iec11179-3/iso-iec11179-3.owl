        <rdfs:label xml:lang="en">DEC</rdfs:label>
        <rdfs:label xml:lang="en">Data Element Concept</rdfs:label>
        <skos:definition xml:lang="en">concept (3.2.7) that can be represented in the form of a data element (3.2.43), described independently of any particular representation</skos:definition>
        <skos:prefLabel xml:lang="en">Data Element Concept</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A data element concept is implicitly associated with both the property and the object class whose combination it expresses</skos:scopeNote>
