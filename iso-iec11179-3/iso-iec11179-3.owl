    <!-- https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/term/Notation -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/term/Notation">
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2020-07-09T10:54:26Z</dcterms:created>
        <dcterms:creator rdf:resource="https://orcid.org/0000-0001-8017-8797"/>
        <dcterms:identifier rdf:resource="urn:iso:std:iso-iec:11179:-3:ed-4:v1:term:3.2.36"/>
        <dcterms:identifier rdf:resource="urn:uuid:1feddf09-d992-4cb4-93f9-5a29bc616769"/>
        <rdfs:label xml:lang="en">Notation</rdfs:label>
        <skos:definition xml:lang="en">formal syntax and associated semantics for the representation of information</skos:definition>
        <skos:example xml:lang="en">UML, MOF, OCL, OWL/RDF, SKOS, CGIF, XCL, XTM or ISO/IEC 11404</skos:example>
        <skos:prefLabel xml:lang="en">Notation</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A formal syntax consists of a set of symbols and the rules for their use</skos:scopeNote>
        <skos:scopeNote xml:lang="en">A formal syntax is often intended for machine processing</skos:scopeNote>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/term/Notation"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#scopeNote"/>
        <owl:annotatedTarget xml:lang="en">A formal syntax consists of a set of symbols and the rules for their use</owl:annotatedTarget>
        <schema:position rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</schema:position>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/term/Notation"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#scopeNote"/>
        <owl:annotatedTarget xml:lang="en">A formal syntax is often intended for machine processing</owl:annotatedTarget>
        <schema:position rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</schema:position>
    </owl:Axiom>
    


    <!-- https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/term/Object -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/term/Object">
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2020-05-21T12:11:44Z</dcterms:created>
        <dcterms:creator rdf:resource="https://orcid.org/0000-0001-8017-8797"/>
        <dcterms:identifier rdf:resource="urn:iso:std:iso-iec:11179:-3:ed-4:v1:term:3.2.1"/>
        <dcterms:identifier rdf:resource="urn:uuid:542ced23-e605-484d-b603-e8bcfffd5d49"/>
        <dcterms:source rdf:resource="urn:iso:std:iso:1087:ed-2:v1:term:3.1.1"/>
        <rdfs:label xml:lang="en">Object</rdfs:label>
        <skos:definition xml:lang="en">anything perceivable or conceivable</skos:definition>
        <skos:prefLabel xml:lang="en">Object</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Objects can be material (e.g. &apos;engine&apos;, &apos;sheet of paper&apos;, &apos;diamond&apos;), immaterial (e.g. &apos;conversion ratio&apos;, &apos;project plan&apos;) or imagined (e.g. &apos;unicorn&apos;, &apos;scientific hypothesis&apos;)</skos:scopeNote>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/term/Object"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#scopeNote"/>
        <owl:annotatedTarget xml:lang="en">Objects can be material (e.g. &apos;engine&apos;, &apos;sheet of paper&apos;, &apos;diamond&apos;), immaterial (e.g. &apos;conversion ratio&apos;, &apos;project plan&apos;) or imagined (e.g. &apos;unicorn&apos;, &apos;scientific hypothesis&apos;)</owl:annotatedTarget>
        <schema:position rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</schema:position>
    </owl:Axiom>
    


