        <dcterms:source rdf:resource="urn:iso:std:iso-iec:11179:-3:ed-4:v1:clause:9.4.10.3"/>
        <rdfs:label xml:lang="en">comment</rdfs:label>
        <skos:definition xml:lang="en">any comment that should be noted about the registry</skos:definition>
        <skos:prefLabel xml:lang="en">comment</skos:prefLabel>
    </owl:DatatypeProperty>
    


    <!-- https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/RegistrySpecification_conformance_label -->

    <owl:DatatypeProperty rdf:about="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/RegistrySpecification_conformance_label">
        <rdfs:domain rdf:resource="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/term/RegistrySpecification"/>
        <rdfs:range rdf:resource="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/stringDatatype"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-04-19T17:54:15Z</dcterms:created>
        <dcterms:creator rdf:resource="https://orcid.org/0000-0001-8017-8797"/>
        <dcterms:source rdf:resource="urn:iso:std:iso-iec:11179:-3:ed-4:v1:clause:9.4.10.3"/>
        <rdfs:label xml:lang="en">conformance_label</rdfs:label>
        <skos:definition xml:lang="en">The conformance label of the registry as described in the standard
Condition: applies only if standard is specified, and the specified standard uses conformance labels.</skos:definition>
        <skos:example xml:lang="en">ISO/IEC 11179-3:2023 Basic Registry (see 4.4.3)</skos:example>
        <skos:prefLabel xml:lang="en">conformance_label</skos:prefLabel>
    </owl:DatatypeProperty>
    


    <!-- https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/RegistrySpecification_conformance_level -->

    <owl:DatatypeProperty rdf:about="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/RegistrySpecification_conformance_level">
        <rdfs:domain rdf:resource="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/term/RegistrySpecification"/>
        <rdfs:range rdf:resource="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/stringDatatype"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-04-19T17:54:06Z</dcterms:created>
        <dcterms:creator rdf:resource="https://orcid.org/0000-0001-8017-8797"/>
        <dcterms:source rdf:resource="urn:iso:std:iso-iec:11179:-3:ed-4:v1:clause:9.4.10.3"/>
        <rdfs:label xml:lang="en">conformance_level</rdfs:label>
        <skos:definition xml:lang="en">The conformance level of the registry as described in the standard
Condition: applies only if standard is specified, and the specified standard uses conformance levels.</skos:definition>
        <skos:example xml:lang="en">Conformance Level 2 (where standard is specified as ISO/IEC 11179-3:2003)</skos:example>
        <skos:note xml:lang="en">This document specifies conformance labels instead of conformance levels</skos:note>
        <skos:prefLabel xml:lang="en">conformance_level</skos:prefLabel>
    </owl:DatatypeProperty>
    


    <!-- https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/RegistrySpecification_default_time_zone -->

    <owl:DatatypeProperty rdf:about="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/RegistrySpecification_default_time_zone">
        <rdfs:domain rdf:resource="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/term/RegistrySpecification"/>
        <rdfs:range rdf:resource="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/datetimeDatatype"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-04-19T17:54:52Z</dcterms:created>
        <dcterms:creator rdf:resource="https://orcid.org/0000-0001-8017-8797"/>
        <dcterms:source rdf:resource="urn:iso:std:iso-iec:11179:-3:ed-4:v1:clause:9.4.10.3"/>
        <rdfs:label xml:lang="en">default_time_zone</rdfs:label>
        <skos:definition xml:lang="en">time zone to be assumed for any datetime instance that does not explicitly specify its own time zone.
Specified as the number of hours offset from UTC, with no separator between hours and minutes, with a leading zero if the hour is less then 9, and a leading minus sign if applicable.</skos:definition>
        <skos:example xml:lang="en">For Newfoundland Daylight Time: -0230</skos:example>
        <skos:prefLabel xml:lang="en">default_time_zone</skos:prefLabel>
    </owl:DatatypeProperty>
    


    <!-- https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/RegistrySpecification_excluded_features -->

    <owl:DatatypeProperty rdf:about="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/RegistrySpecification_excluded_features">
        <rdfs:domain rdf:resource="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/term/RegistrySpecification"/>
        <rdfs:range rdf:resource="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/stringDatatype"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-04-19T17:54:31Z</dcterms:created>
        <dcterms:creator rdf:resource="https://orcid.org/0000-0001-8017-8797"/>
        <dcterms:source rdf:resource="urn:iso:std:iso-iec:11179:-3:ed-4:v1:clause:9.4.10.3"/>
        <rdfs:label xml:lang="en">excluded_features</rdfs:label>
        <skos:definition xml:lang="en">Freeform specification of the features of the standard that this implementation does not support.
Condition: applies only if standard is specified, and the specified standard allows conformance by feature (see 4.3).</skos:definition>
        <skos:prefLabel xml:lang="en">excluded_features</skos:prefLabel>
    </owl:DatatypeProperty>
    


    <!-- https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/RegistrySpecification_included_features -->

    <owl:DatatypeProperty rdf:about="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/RegistrySpecification_included_features">
        <rdfs:domain rdf:resource="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/term/RegistrySpecification"/>
        <rdfs:range rdf:resource="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/stringDatatype"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-04-19T17:54:23Z</dcterms:created>
        <dcterms:creator rdf:resource="https://orcid.org/0000-0001-8017-8797"/>
        <dcterms:source rdf:resource="urn:iso:std:iso-iec:11179:-3:ed-4:v1:clause:9.4.10.3"/>
        <rdfs:label xml:lang="en">included_features</rdfs:label>
        <skos:definition xml:lang="en">Freeform specification of the features of the standard that this implementation supports.
Condition: applies only if standard is specified, and the specified standard allows conformance by feature (see 4.3).</skos:definition>
        <skos:prefLabel xml:lang="en">included_features</skos:prefLabel>
    </owl:DatatypeProperty>
    


    <!-- https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/RegistrySpecification_name -->

    <owl:DatatypeProperty rdf:about="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/RegistrySpecification_name">
        <rdfs:domain rdf:resource="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/term/RegistrySpecification"/>
        <rdfs:range rdf:resource="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/signDatatype"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-04-19T17:52:55Z</dcterms:created>
        <dcterms:creator rdf:resource="https://orcid.org/0000-0001-8017-8797"/>
        <dcterms:source rdf:resource="urn:iso:std:iso-iec:11179:-3:ed-4:v1:clause:9.4.10.3"/>
        <rdfs:label xml:lang="en">name</rdfs:label>
        <skos:definition xml:lang="en">name by which the registry is commonly known</skos:definition>
        <skos:example xml:lang="en">Australian Institute of Health and Welfare (AIHW) Metadata Online Registry (METeOR)[39]</skos:example>
        <skos:prefLabel xml:lang="en">name</skos:prefLabel>
    </owl:DatatypeProperty>
    


    <!-- https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/RegistrySpecification_reference_document_identifier_kind -->

    <owl:DatatypeProperty rdf:about="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/RegistrySpecification_reference_document_identifier_kind">
        <rdfs:domain rdf:resource="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/term/RegistrySpecification"/>
        <rdfs:range rdf:resource="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/stringDatatype"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-04-19T17:53:40Z</dcterms:created>
        <dcterms:creator rdf:resource="https://orcid.org/0000-0001-8017-8797"/>
        <dcterms:source rdf:resource="urn:iso:std:iso-iec:11179:-3:ed-4:v1:clause:9.4.10.3"/>
        <rdfs:label xml:lang="en">reference_document_identifier_kind</rdfs:label>
        <skos:definition xml:lang="en">Specification of the kind of identifier used for identifying reference documents in the registry</skos:definition>
        <skos:example xml:lang="en">Some registries use URIs. Other registries use an external document management system which provides unstructured, opaque identifiers. Yet other registries define a structured identifier form which embeds an identifier type within each identifier in the registry. This attribute specifies the form of identifiers used for reference documents in this particular registry.</skos:example>
        <skos:prefLabel xml:lang="en">reference_document_identifier_kind</skos:prefLabel>
    </owl:DatatypeProperty>
    


    <!-- https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/RegistrySpecification_representation_class_scheme_id -->

    <owl:DatatypeProperty rdf:about="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/RegistrySpecification_representation_class_scheme_id">
        <rdfs:domain rdf:resource="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/term/RegistrySpecification"/>
        <rdfs:range rdf:resource="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/stringDatatype"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-04-19T17:53:49Z</dcterms:created>
        <dcterms:creator rdf:resource="https://orcid.org/0000-0001-8017-8797"/>
        <dcterms:source rdf:resource="urn:iso:std:iso-iec:11179:-3:ed-4:v1:clause:9.4.10.3"/>
        <rdfs:label xml:lang="en">representation_class_scheme_id</rdfs:label>
        <skos:changeNote xml:lang="en">Edition 2 (ISO/IEC 11179-3:2003[12]) had a separate structure to record “representation classes”. In edition 3 (ISO/IEC 11179-3:2013[13]) and edition 4 (this document), these are considered to be just another classification scheme, which in edition 3 was considered a kind of concept system. This document has restored a Classification_Scheme class independent of the Concept_System class specified in ISO/IEC 11179-32. This attribute allows the registration authority to specify which classification scheme is used for this purpose. This document uses just the identifier of the classification scheme for this attribute. Edition 3 embedded a whole concept system.</skos:changeNote>
        <skos:definition xml:lang="en">identifier of the classification scheme used by the registry to capture representation classes</skos:definition>
        <skos:prefLabel xml:lang="en">representation_class_scheme_id</skos:prefLabel>
    </owl:DatatypeProperty>
    


    <!-- https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/RegistrySpecification_standard -->

    <owl:DatatypeProperty rdf:about="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/RegistrySpecification_standard">
        <rdfs:domain rdf:resource="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/term/RegistrySpecification"/>
        <rdfs:range rdf:resource="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/stringDatatype"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-04-19T17:53:58Z</dcterms:created>
        <dcterms:creator rdf:resource="https://orcid.org/0000-0001-8017-8797"/>
        <dcterms:source rdf:resource="urn:iso:std:iso-iec:11179:-3:ed-4:v1:clause:9.4.10.3"/>
        <rdfs:label xml:lang="en">standard</rdfs:label>
        <skos:definition xml:lang="en">Identifier for the standard to which this registry complies</skos:definition>
        <skos:example xml:lang="en">ISO/IEC 11179-3:2023</skos:example>
        <skos:prefLabel xml:lang="en">standard</skos:prefLabel>
    </owl:DatatypeProperty>
    


