        <rdfs:label xml:lang="en">hierarchy_level</rdfs:label>
        <skos:definition xml:lang="en">level of this classification scheme item in the hierarchy of the classification scheme, where the top level is level 1 and each lower level increments by 1 (2, 3, etc)”</skos:definition>
        <skos:prefLabel xml:lang="en">hierarchy_level</skos:prefLabel>
    </owl:DatatypeProperty>
    


    <!-- https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/item_shall_be_classified_indicator -->

    <owl:DatatypeProperty rdf:about="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/item_shall_be_classified_indicator">
        <rdfs:domain rdf:resource="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/term/ConstraintSet"/>
        <rdfs:range rdf:resource="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/booleanDatatype"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-04-15T13:23:49Z</dcterms:created>
        <dcterms:creator rdf:resource="https://orcid.org/0000-0001-8017-8797"/>
        <dcterms:source rdf:resource="urn:iso:std:iso-iec:11179:-3:ed-4:v1:clause:9.4.5.4"/>
        <rdfs:label xml:lang="en">item_shall_be_classified_indicator</rdfs:label>
        <skos:definition xml:lang="en">indicator as to whether the linked registered item is required to be a classified item when its registration status is ‘Recorded’ or higher. That is, whether the parent instance of the Item (8.2.1) class has a linked instance of the Classification_Scheme_Item (10.3.2) class via the item_classification (10.4.1) association when the value of the Registration_State.registration_status (9.4.4.3) is ‘Recorded’ or higher.</skos:definition>
        <skos:prefLabel xml:lang="en">item_shall_be_classified_indicator</skos:prefLabel>
    </owl:DatatypeProperty>
    


    <!-- https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/item_shall_be_defined_indicator -->

    <owl:DatatypeProperty rdf:about="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/item_shall_be_defined_indicator">
        <rdfs:domain rdf:resource="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/term/ConstraintSet"/>
        <rdfs:range rdf:resource="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/booleanDatatype"/>
