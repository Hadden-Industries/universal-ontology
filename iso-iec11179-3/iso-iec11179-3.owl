    <!-- https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/term/ConceptualDataModel -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/term/ConceptualDataModel">
        <rdfs:subClassOf rdf:resource="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/term/DataModel"/>
