        <rdfs:label xml:lang="en">Conceptual Data Model</rdfs:label>
        <skos:definition xml:lang="en">data model (3.2.32) that represents an abstract view of the real world</skos:definition>
        <skos:prefLabel xml:lang="en">Conceptual Data Model</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A conceptual model represents the human understanding of a system, which can be anywhere from a paper-based system to a complex database in an IT system</skos:scopeNote>
    </owl:Class>
