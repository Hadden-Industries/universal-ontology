    <!-- https://haddenindustries.com/ontology/universal/extended/ProgrammingFunction -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/universal/extended/ProgrammingFunction">
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-08-26T17:17:51Z</dcterms:created>
        <dcterms:creator rdf:resource="https://orcid.org/0000-0001-8017-8797"/>
        <dcterms:identifier rdf:resource="urn:uuid:3672a1ae-7e21-4948-a9e8-f2852cba4132"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-26T22:28:00Z</dcterms:modified>
        <dcterms:source rdf:resource="urn:iso:std:iso-iec:2382:ed-1:v1:term:2122457"/>
        <dcterms:source xml:lang="en">ISO-IEC-2382-15 * 1999 * * * </dcterms:source>
        <rdfs:label xml:lang="en">Programming Function</rdfs:label>
        <skos:definition xml:lang="en">Subprogram, usually with formal parameters, that produces a data value which it returns to the place of the invocation</skos:definition>
        <skos:prefLabel xml:lang="en">Programming Function</skos:prefLabel>
        <skos:scopeNote xml:lang="en">15.06.12 (2382)</skos:scopeNote>
        <skos:scopeNote xml:lang="en">A function may also produce other changes through the use of parameters.</skos:scopeNote>
        <skos:scopeNote xml:lang="en">function: term and definition standardized by ISO/IEC [ISO/IEC 2382-15:1999].</skos:scopeNote>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/extended/ProgrammingFunction"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#scopeNote"/>
        <owl:annotatedTarget xml:lang="en">15.06.12 (2382)</owl:annotatedTarget>
        <schema:position rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</schema:position>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/extended/ProgrammingFunction"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#scopeNote"/>
        <owl:annotatedTarget xml:lang="en">A function may also produce other changes through the use of parameters.</owl:annotatedTarget>
        <schema:position rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</schema:position>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/extended/ProgrammingFunction"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#scopeNote"/>
        <owl:annotatedTarget xml:lang="en">function: term and definition standardized by ISO/IEC [ISO/IEC 2382-15:1999].</owl:annotatedTarget>
        <schema:position rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</schema:position>
    </owl:Axiom>
    


    <!-- https://haddenindustries.com/ontology/universal/extended/Project -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/universal/extended/Project">
        <rdfs:subClassOf rdf:resource="https://haddenindustries.com/ontology/universal/core/Process"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-04-23T11:10:34Z</dcterms:created>
        <dcterms:creator rdf:resource="https://orcid.org/0000-0001-8017-8797"/>
        <dcterms:identifier rdf:resource="urn:uuid:855405e5-3a53-4758-a7a0-261cfa1454e0"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-26T22:03:32Z</dcterms:modified>
        <dcterms:source rdf:resource="urn:iso:std:iso:9000:ed-4:v1:term:3.4.2"/>
        <dcterms:source xml:lang="en">ISO 10006:2003, 3.5</dcterms:source>
        <rdfs:label xml:lang="en">Project</rdfs:label>
        <skos:definition xml:lang="en">Unique process, consisting of a set of coordinated and controlled activities with start and finish dates, undertaken to achieve an objective conforming to specific requirements, including the constraints of time, cost and resources</skos:definition>
        <skos:prefLabel xml:lang="en">Project</skos:prefLabel>
        <skos:scopeNote xml:lang="en">An individual project can form part of a larger project structure and generally has a defined start and finish date</skos:scopeNote>
        <skos:scopeNote xml:lang="en">In some projects the objectives and scope are updated and the product or service characteristics defined progressively as the project proceeds</skos:scopeNote>
        <skos:scopeNote xml:lang="en">The complexity of the interactions among project activities is not necessarily related to the project size</skos:scopeNote>
        <skos:scopeNote xml:lang="en">The output of a project can be one or several units of product or service</skos:scopeNote>
        <skos:scopeNote xml:lang="en-gb">The project’s organisation is normally temporary and established for the lifetime of the project</skos:scopeNote>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/extended/Project"/>
        <owl:annotatedProperty rdf:resource="http://purl.org/dc/terms/source"/>
        <owl:annotatedTarget xml:lang="en">ISO 10006:2003, 3.5</owl:annotatedTarget>
        <skos:note xml:lang="en">modified — Notes 1 to 3 have been modified</skos:note>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/extended/Project"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#scopeNote"/>
        <owl:annotatedTarget xml:lang="en">An individual project can form part of a larger project structure and generally has a defined start and finish date</owl:annotatedTarget>
        <schema:position rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</schema:position>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/extended/Project"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#scopeNote"/>
        <owl:annotatedTarget xml:lang="en">In some projects the objectives and scope are updated and the product or service characteristics defined progressively as the project proceeds</owl:annotatedTarget>
        <schema:position rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</schema:position>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/extended/Project"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#scopeNote"/>
        <owl:annotatedTarget xml:lang="en">The complexity of the interactions among project activities is not necessarily related to the project size</owl:annotatedTarget>
        <schema:position rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">5</schema:position>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/extended/Project"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#scopeNote"/>
        <owl:annotatedTarget xml:lang="en">The output of a project can be one or several units of product or service</owl:annotatedTarget>
        <schema:position rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</schema:position>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/extended/Project"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#scopeNote"/>
        <owl:annotatedTarget xml:lang="en-gb">The project’s organisation is normally temporary and established for the lifetime of the project</owl:annotatedTarget>
        <schema:position rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</schema:position>
    </owl:Axiom>
    


