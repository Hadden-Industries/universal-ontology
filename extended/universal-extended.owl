                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/NominalProperty"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dcterms:creator rdf:resource="https://orcid.org/0000-0001-8017-8797"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2017-04-26T12:54:41Z</dcterms:created>
        <skos:definition xml:lang="en">Action of evaluating or estimating the nature, ability, or quality of a thing</skos:definition>
        <dcterms:identifier rdf:resource="urn:uuid:a131b4f9-e7ca-4329-9e54-340078152dc6"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-26T16:04:00Z</dcterms:modified>
        <dcterms:references rdf:resource="https://www.lexico.com/en/definition/assessment"/>
        <skos:prefLabel xml:lang="en">Assessment</skos:prefLabel>
