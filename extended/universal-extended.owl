        <dcterms:identifier rdf:resource="urn:uuid:824d3ff6-dae5-4745-9724-739e97256c40"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-25T13:11:00Z</dcterms:modified>
        <rdfs:label xml:lang="en">Bank Account Instance</rdfs:label>
        <skos:definition xml:lang="en">Account Instance with a bank to hold money and keep records of transactions</skos:definition>
        <skos:prefLabel xml:lang="en">Bank Account Instance</skos:prefLabel>
    </owl:Class>
    


    <!-- https://haddenindustries.com/ontology/universal/extended/BankStatement -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/universal/extended/BankStatement">
        <rdfs:subClassOf rdf:resource="https://haddenindustries.com/ontology/universal/core/Document"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2022-11-22T14:22:10Z</dcterms:created>
        <dcterms:creator rdf:resource="https://orcid.org/0000-0001-8017-8797"/>
        <dcterms:identifier rdf:resource="urn:uuid:ef4bea6b-e9e1-42cb-9dd9-5065594e8130"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-26T22:10:30Z</dcterms:modified>
        <rdfs:label xml:lang="en">Bank Statement</rdfs:label>
        <skos:definition xml:lang="en">Statement of transactions in a bank account, especially one of a series sent at regular intervals to the depositor</skos:definition>
        <skos:prefLabel xml:lang="en">Bank Statement</skos:prefLabel>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/extended/BankStatement"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#definition"/>
        <owl:annotatedTarget xml:lang="en">Statement of transactions in a bank account, especially one of a series sent at regular intervals to the depositor</owl:annotatedTarget>
        <dcterms:source rdf:resource="https://www.dictionary.com/browse/bank-statement"/>
    </owl:Axiom>
    


    <!-- https://haddenindustries.com/ontology/universal/extended/BaptismCertificate -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/universal/extended/BaptismCertificate">
        <rdfs:subClassOf rdf:resource="https://haddenindustries.com/ontology/universal/core/Document"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-02-11T12:44:13Z</dcterms:created>
        <dcterms:creator rdf:resource="https://orcid.org/0000-0001-8017-8797"/>
        <dcterms:identifier rdf:resource="urn:uuid:447d4cf1-aa08-484c-a714-432e6e90de02"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-26T22:10:43Z</dcterms:modified>
        <rdfs:label xml:lang="en">Baptism Certificate</rdfs:label>
        <skos:altLabel xml:lang="en">Baptismal Certificate</skos:altLabel>
        <skos:definition xml:lang="en">Document that states the date and place a natural person underwent the Christian religious rite of sprinkling water on to their forehead or of immersing them in water, symbolising purification or regeneration and admission to the Christian Church</skos:definition>
        <skos:prefLabel xml:lang="en">Baptism Certificate</skos:prefLabel>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/extended/BaptismCertificate"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#definition"/>
        <owl:annotatedTarget xml:lang="en">Document that states the date and place a natural person underwent the Christian religious rite of sprinkling water on to their forehead or of immersing them in water, symbolising purification or regeneration and admission to the Christian Church</owl:annotatedTarget>
        <dcterms:source rdf:resource="https://www.lexico.com/definition/baptism"/>
    </owl:Axiom>
    


    <!-- https://haddenindustries.com/ontology/universal/extended/Barcode -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/universal/extended/Barcode">
        <rdfs:subClassOf rdf:resource="https://haddenindustries.com/ontology/universal/extended/Label"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://haddenindustries.com/ontology/universal/extended/Barcode_hasBarcodeSymbology"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/BarcodeSymbology"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2016-09-30T12:00:00Z</dcterms:created>
        <dcterms:creator rdf:resource="https://orcid.org/0000-0001-8017-8797"/>
        <dcterms:identifier rdf:resource="urn:uuid:55b42f3a-29ad-415b-b07a-e3f0994eb549"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-26T21:33:00Z</dcterms:modified>
        <dcterms:source rdf:resource="urn:iso:std:iso:ts:16791:ed-2:v1:term:3.1.9"/>
        <rdfs:label xml:lang="en">Barcode</rdfs:label>
        <skos:altLabel xml:lang="en">Bar Code</skos:altLabel>
        <skos:definition xml:lang="en">Optical machine-readable representation of data, showing data about the object to which it attaches</skos:definition>
        <skos:prefLabel xml:lang="en">Barcode</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Originally, barcodes represented data by varying the widths and spacings of parallel lines, and can be referred to as linear or one-dimensional (1D). Later they evolved into rectangles, dots, hexagons, and other geometric patterns in two dimensions (2D). Although 2D systems use a variety of symbols, they are generally referred to as barcodes as well.</skos:scopeNote>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/extended/Barcode"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#scopeNote"/>
        <owl:annotatedTarget xml:lang="en">Originally, barcodes represented data by varying the widths and spacings of parallel lines, and can be referred to as linear or one-dimensional (1D). Later they evolved into rectangles, dots, hexagons, and other geometric patterns in two dimensions (2D). Although 2D systems use a variety of symbols, they are generally referred to as barcodes as well.</owl:annotatedTarget>
        <schema:position rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</schema:position>
    </owl:Axiom>
    


