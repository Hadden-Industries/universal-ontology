    <!-- https://haddenindustries.com/ontology/universal/extended/Asset -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/universal/extended/Asset">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://haddenindustries.com/ontology/universal/extended/hasAssetType"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/AssetType"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-09-02T09:06:08Z</dcterms:created>
        <dcterms:creator rdf:resource="https://orcid.org/0000-0001-8017-8797"/>
        <dcterms:identifier rdf:resource="urn:uuid:a964d2a7-6e00-4f98-8017-24df3b45e2f1"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-26T22:28:00Z</dcterms:modified>
        <dcterms:source rdf:resource="urn:iso:std:iso:55000:ed-1:v2:term:3.2.1"/>
        <rdfs:label xml:lang="en">Asset</rdfs:label>
        <skos:definition xml:lang="en">Item, thing or entity that has potential or actual value to an organisation</skos:definition>
        <skos:prefLabel xml:lang="en">Asset</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A grouping of assets referred to as an asset system (3.2.5) could also be considered as an asset.</skos:scopeNote>
        <skos:scopeNote xml:lang="en">Physical assets usually refer to equipment, inventory and properties owned by the organization. Physical assets are the opposite of intangible assets, which are non-physical assets such as leases, brands, digital assets, use rights, licences, intellectual property rights, reputation or agreements.</skos:scopeNote>
        <skos:scopeNote xml:lang="en">Value can be tangible or intangible, financial or non-financial, and includes consideration of risks (3.1.21) and liabilities. It can be positive or negative at different stages of the asset life (3.2.2).</skos:scopeNote>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/extended/Asset"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#scopeNote"/>
        <owl:annotatedTarget xml:lang="en">A grouping of assets referred to as an asset system (3.2.5) could also be considered as an asset.</owl:annotatedTarget>
        <schema:position rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</schema:position>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/extended/Asset"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#scopeNote"/>
        <owl:annotatedTarget xml:lang="en">Physical assets usually refer to equipment, inventory and properties owned by the organization. Physical assets are the opposite of intangible assets, which are non-physical assets such as leases, brands, digital assets, use rights, licences, intellectual property rights, reputation or agreements.</owl:annotatedTarget>
        <schema:position rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</schema:position>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/extended/Asset"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#scopeNote"/>
        <owl:annotatedTarget xml:lang="en">Value can be tangible or intangible, financial or non-financial, and includes consideration of risks (3.1.21) and liabilities. It can be positive or negative at different stages of the asset life (3.2.2).</owl:annotatedTarget>
        <schema:position rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</schema:position>
    </owl:Axiom>
    


    <!-- https://haddenindustries.com/ontology/universal/extended/AudioRecording -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/universal/extended/AudioRecording">
        <rdfs:subClassOf rdf:resource="https://haddenindustries.com/ontology/universal/extended/AudiovisualDocument"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2020-04-24T15:13:02Z</dcterms:created>
        <dcterms:creator rdf:resource="https://orcid.org/0000-0001-8017-8797"/>
        <dcterms:identifier rdf:resource="urn:uuid:4232ff73-aa4f-4763-8934-10aeabeae5c1"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-26T21:22:00Z</dcterms:modified>
        <dcterms:source rdf:resource="urn:iso:std:iso:5127:ed-2:v1:en:term:3.3.3.19"/>
        <dcterms:source xml:lang="en">ISO 3901:2001, definition 3.3</dcterms:source>
        <rdfs:label xml:lang="en">Audio Recording</rdfs:label>
        <rdfs:seeAlso rdf:resource="http://schema.org/MusicRecording"/>
        <skos:definition xml:lang="en">Result of an audio recording process independent of the type and number of audio carriers and technology used</skos:definition>
        <skos:prefLabel xml:lang="en">Audio Recording</skos:prefLabel>
        <skos:scopeNote xml:lang="en">See also “recorded information” (3.1.8.26) and “to write” (3.1.11.01).</skos:scopeNote>
        <skos:scopeNote xml:lang="en">The term “recording” applies to each recorded item which may be used as a separate unit regardless of whether it is issued as part of a larger recorded work (e.g. each separate track (2) &lt;recording&gt;  (3.5.8.49) on an album (3.4.5.5.04) of audio recordings).</skos:scopeNote>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/extended/AudioRecording"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#scopeNote"/>
        <owl:annotatedTarget xml:lang="en">See also “recorded information” (3.1.8.26) and “to write” (3.1.11.01).</owl:annotatedTarget>
        <schema:position rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</schema:position>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/extended/AudioRecording"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#scopeNote"/>
        <owl:annotatedTarget xml:lang="en">The term “recording” applies to each recorded item which may be used as a separate unit regardless of whether it is issued as part of a larger recorded work (e.g. each separate track (2) &lt;recording&gt;  (3.5.8.49) on an album (3.4.5.5.04) of audio recordings).</owl:annotatedTarget>
        <schema:position rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</schema:position>
    </owl:Axiom>
    


    <!-- https://haddenindustries.com/ontology/universal/extended/AudioTranscript -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/universal/extended/AudioTranscript">
