    <!-- https://haddenindustries.com/ontology/universal/extended/Asset -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/universal/extended/Asset">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://haddenindustries.com/ontology/universal/extended/hasAssetType"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/AssetType"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dcterms:creator rdf:resource="https://orcid.org/0000-0001-8017-8797"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-09-02T09:06:08Z</dcterms:created>
        <skos:definition xml:lang="en">Item, thing or entity that has potential or actual value to an organisation</skos:definition>
        <dcterms:identifier rdf:resource="urn:uuid:a964d2a7-6e00-4f98-8017-24df3b45e2f1"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-26T16:04:00Z</dcterms:modified>
        <dcterms:references rdf:resource="urn:iso:std:iso:55000:ed-1:v2:en:term:3.2.1"/>
        <skos:prefLabel xml:lang="en">Asset</skos:prefLabel>
        <rdfs:comment xml:lang="en">Note 1 to entry: Value can be tangible or intangible, financial or non-financial, and includes consideration of risks (3.1.21) and liabilities. It can be positive or negative at different stages of the asset life (3.2.2).
Note 2 to entry: Physical assets usually refer to equipment, inventory and properties owned by the organization. Physical assets are the opposite of intangible assets, which are non-physical assets such as leases, brands, digital assets, use rights, licences, intellectual property rights, reputation or agreements.
Note 3 to entry: A grouping of assets referred to as an asset system (3.2.5) could also be considered as an asset.</rdfs:comment>
        <rdfs:label xml:lang="en">Asset</rdfs:label>
    </owl:Class>
    


    <!-- https://haddenindustries.com/ontology/universal/extended/AudioRecording -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/universal/extended/AudioRecording">
        <rdfs:subClassOf rdf:resource="https://haddenindustries.com/ontology/universal/extended/AudiovisualDocument"/>
        <dcterms:creator rdf:resource="https://orcid.org/0000-0001-8017-8797"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2020-04-24T15:13:02Z</dcterms:created>
        <skos:definition xml:lang="en">Result of an audio recording process independent of the type and number of audio carriers and technology used</skos:definition>
        <dcterms:identifier rdf:resource="urn:uuid:4232ff73-aa4f-4763-8934-10aeabeae5c1"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-25T13:11:00Z</dcterms:modified>
        <dcterms:source rdf:resource="urn:iso:std:iso:5127:ed-2:v1:en:term:3.3.3.19"/>
        <skos:prefLabel xml:lang="en">Audio Recording</skos:prefLabel>
        <rdfs:comment xml:lang="en">Note 1 to entry: The term “recording” applies to each recorded item which may be used as a separate unit regardless of whether it is issued as part of a larger recorded work (e.g. each separate track (2) &lt;recording&gt;  (3.5.8.49) on an album (3.4.5.5.04) of audio recordings).
[SOURCE:ISO 3901:2001, definition 3.3]
Note 2 to entry: See also “recorded information” (3.1.8.26) and “to write” (3.1.11.01).</rdfs:comment>
        <rdfs:label xml:lang="en">Audio Recording</rdfs:label>
        <rdfs:seeAlso rdf:resource="http://schema.org/MusicRecording"/>
    </owl:Class>
    


    <!-- https://haddenindustries.com/ontology/universal/extended/AudioTranscript -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/universal/extended/AudioTranscript">
        <rdfs:subClassOf rdf:resource="https://haddenindustries.com/ontology/universal/core/Document"/>
        <dcterms:creator rdf:resource="https://orcid.org/0000-0001-8017-8797"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-02-16T11:52:23Z</dcterms:created>
        <skos:definition xml:lang="en">Written or printed version of material originally presented in the audio medium</skos:definition>
        <dcterms:identifier rdf:resource="urn:uuid:d0269fbf-3e03-4dea-9206-0064175c5fe8"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-25T13:11:00Z</dcterms:modified>
        <skos:prefLabel xml:lang="en">Audio Transcript</skos:prefLabel>
        <rdfs:label xml:lang="en">Audio Transcript</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/extended/AudioTranscript"/>
        <owl:annotatedProperty rdf:resource="http://purl.org/dc/terms/description"/>
        <owl:annotatedTarget xml:lang="en">Written or printed version of material originally presented in the audio medium</owl:annotatedTarget>
        <dcterms:source rdf:resource="https://www.lexico.com/definition/transcript"/>
    </owl:Axiom>
    


    <!-- https://haddenindustries.com/ontology/universal/extended/AudiovisualDocument -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/universal/extended/AudiovisualDocument">
        <rdfs:subClassOf rdf:resource="https://haddenindustries.com/ontology/universal/core/Document"/>
        <dcterms:creator rdf:resource="https://orcid.org/0000-0001-8017-8797"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2023-02-10T15:11:13Z</dcterms:created>
        <skos:definition xml:lang="en">Document in which sound and/or pictures are prominent, and which requires the use of special equipment to be seen and/or heard</skos:definition>
        <dcterms:identifier rdf:resource="urn:uuid:58e12116-b2ae-4d1f-b3de-4e629b227559"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-25T13:11:00Z</dcterms:modified>
        <dcterms:source rdf:resource="urn:iso:std:iso:5127:ed-2:v1:en:term:3.3.3.07"/>
        <skos:prefLabel xml:lang="en">Audiovisual Document</skos:prefLabel>
        <rdfs:comment xml:lang="en">For library (3.2.3.02) and museum (3.2.3.06) statistics purposes, microforms (3.4.5.1.03) are excluded</rdfs:comment>
        <rdfs:comment xml:lang="en">ISO 18461:2016, definition 2.5.5, modified</rdfs:comment>
        <rdfs:comment xml:lang="en">This includes audio documents such as phonographic records, tapes, cassettes, audio compact discs, DVDs, files of digital audio recordings; visual documents such as slides, transparencies; and combined audiovisual documents, such as motion pictures, video recordings, computer games, etc.</rdfs:comment>
        <rdfs:label xml:lang="en">Audiovisual Document</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/extended/AudiovisualDocument"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#comment"/>
        <owl:annotatedTarget xml:lang="en">For library (3.2.3.02) and museum (3.2.3.06) statistics purposes, microforms (3.4.5.1.03) are excluded</owl:annotatedTarget>
        <rdfs:comment xml:lang="en">Note 2 to entry</rdfs:comment>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/extended/AudiovisualDocument"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#comment"/>
        <owl:annotatedTarget xml:lang="en">ISO 18461:2016, definition 2.5.5, modified</owl:annotatedTarget>
        <rdfs:comment xml:lang="en">SOURCE</rdfs:comment>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/extended/AudiovisualDocument"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#comment"/>
        <owl:annotatedTarget xml:lang="en">This includes audio documents such as phonographic records, tapes, cassettes, audio compact discs, DVDs, files of digital audio recordings; visual documents such as slides, transparencies; and combined audiovisual documents, such as motion pictures, video recordings, computer games, etc.</owl:annotatedTarget>
        <rdfs:comment xml:lang="en">Note 1 to entry</rdfs:comment>
    </owl:Axiom>
    


