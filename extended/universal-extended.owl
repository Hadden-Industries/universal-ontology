        <rdfs:label xml:lang="en">Assessed Nominal Property Value</rdfs:label>
        <skos:definition xml:lang="en">Nominal Property Value representing an Assessment Result</skos:definition>
        <skos:prefLabel xml:lang="en">Assessed Nominal Property Value</skos:prefLabel>
    </owl:Class>
    


