        <dcterms:description xml:lang="en">Any self-propelled vehicle designed and constructed to be used on the road and having at least two wheels or any non-self propelled vehicle, which is designed and constructed to be towed by a power driven vehicle</dcterms:description>
        <dcterms:identifier rdf:resource="urn:uuid:65e9a74c-d519-42e3-a54e-50b5f23bb388"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-26T22:03:50Z</dcterms:modified>
