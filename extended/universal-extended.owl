        <skos:scopeNote xml:lang="en">01.01.08 (2382)</skos:scopeNote>
        <skos:scopeNote xml:lang="en">Software is an intellectual creation that is independent of the medium on which it is recorded.</skos:scopeNote>
        <skos:scopeNote xml:lang="en">software : term and definition standardized by ISO/IEC [ISO/IEC 2382-1:1993].</skos:scopeNote>
    </owl:Class>
