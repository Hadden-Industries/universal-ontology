                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/GeographicFeature"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2023-02-21T12:29:52Z</dcterms:created>
        <dcterms:creator rdf:resource="https://orcid.org/0000-0001-8017-8797"/>
        <dcterms:identifier rdf:resource="urn:uuid:669594b9-164b-4ea6-809d-368a0c76baba"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-26T22:13:39Z</dcterms:modified>
        <rdfs:label xml:lang="en">Territorial Jurisdiction Clause</rdfs:label>
        <skos:definition xml:lang="en">Particular part of a written contract setting out the territory within which a court or government agency may properly exercise its power</skos:definition>
        <skos:prefLabel xml:lang="en">Territorial Jurisdiction Clause</skos:prefLabel>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/extended/TerritorialJurisdictionClause"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#definition"/>
        <owl:annotatedTarget xml:lang="en">Particular part of a written contract setting out the territory within which a court or government agency may properly exercise its power</owl:annotatedTarget>
        <dcterms:source rdf:resource="https://dictionary.cambridge.org/dictionary/english/clause"/>
        <dcterms:source rdf:resource="https://www.law.cornell.edu/wex/jurisdiction"/>
    </owl:Axiom>
    


