    <!-- https://haddenindustries.com/ontology/universal/extended/InternalControl -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/universal/extended/InternalControl">
        <dcterms:creator rdf:resource="https://orcid.org/0000-0001-8017-8797"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-05-08T17:20:49Z</dcterms:created>
        <skos:definition xml:lang="en">One of the policies, processes, tasks, behaviours and other aspects of a company that, taken together:

Facilitate its effective and efficient operation by enabling it to respond appropriately to significant business, operational, financial, compliance and other risks to achieving the company’s objectives. This includes the safeguarding of assets from inappropriate use or from loss and fraud, and ensuring that liabilities are identified and managed;

Help ensure the quality of internal and external reporting. This requires the maintenance of proper records and processes that generate a flow of timely, relevant and reliable information from within and outside the organisation;

Help ensure compliance with applicable laws and regulations, and also with internal policies with respect to the conduct of business</skos:definition>
        <dcterms:identifier rdf:resource="urn:uuid:2c4597b0-3a7e-4ffd-b116-9b743c9e3a9f"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-25T13:11:00Z</dcterms:modified>
        <dcterms:references rdf:resource="urn:isbn:1841520101"/>
        <skos:prefLabel xml:lang="en">Internal Control</skos:prefLabel>
        <rdfs:label xml:lang="en">Internal Control</rdfs:label>
    </owl:Class>
    


