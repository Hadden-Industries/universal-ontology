        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-02-16T11:52:23Z</dcterms:created>
        <dcterms:creator rdf:resource="https://orcid.org/0000-0001-8017-8797"/>
        <dcterms:description xml:lang="en">Written or printed version of material originally presented in the audio medium</dcterms:description>
        <dcterms:identifier rdf:resource="urn:uuid:d0269fbf-3e03-4dea-9206-0064175c5fe8"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-25T13:11:00Z</dcterms:modified>
        <rdfs:label xml:lang="en">Audio Transcript</rdfs:label>
        <skos:definition xml:lang="en">Written or printed version of material originally presented in the audio medium</skos:definition>
        <skos:prefLabel xml:lang="en">Audio Transcript</skos:prefLabel>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/extended/AudioTranscript"/>
        <owl:annotatedProperty rdf:resource="http://purl.org/dc/terms/description"/>
        <owl:annotatedTarget xml:lang="en">Written or printed version of material originally presented in the audio medium</owl:annotatedTarget>
        <dcterms:source rdf:resource="https://www.lexico.com/definition/transcript"/>
    </owl:Axiom>
    


    <!-- https://haddenindustries.com/ontology/universal/extended/AudiovisualDocument -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/universal/extended/AudiovisualDocument">
        <rdfs:subClassOf rdf:resource="https://haddenindustries.com/ontology/universal/core/Document"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2023-02-10T15:11:13Z</dcterms:created>
        <dcterms:creator rdf:resource="https://orcid.org/0000-0001-8017-8797"/>
        <dcterms:identifier rdf:resource="urn:uuid:58e12116-b2ae-4d1f-b3de-4e629b227559"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-26T21:40:29Z</dcterms:modified>
        <dcterms:source rdf:resource="urn:iso:std:iso:5127:ed-2:v1:en:term:3.3.3.07"/>
        <dcterms:source xml:lang="en">ISO 18461:2016, definition 2.5.5</dcterms:source>
        <rdfs:label xml:lang="en">Audiovisual Document</rdfs:label>
        <skos:definition xml:lang="en">Document in which sound and/or pictures are prominent, and which requires the use of special equipment to be seen and/or heard</skos:definition>
        <skos:prefLabel xml:lang="en">Audiovisual Document</skos:prefLabel>
        <skos:scopeNote xml:lang="en">For library (3.2.3.02) and museum (3.2.3.06) statistics purposes, microforms (3.4.5.1.03) are excluded</skos:scopeNote>
        <skos:scopeNote xml:lang="en">This includes audio documents such as phonographic records, tapes, cassettes, audio compact discs, DVDs, files of digital audio recordings; visual documents such as slides, transparencies; and combined audiovisual documents, such as motion pictures, video recordings, computer games, etc.</skos:scopeNote>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/extended/AudiovisualDocument"/>
        <owl:annotatedProperty rdf:resource="http://purl.org/dc/terms/source"/>
        <owl:annotatedTarget xml:lang="en">ISO 18461:2016, definition 2.5.5</owl:annotatedTarget>
        <skos:note xml:lang="en">modified</skos:note>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/extended/AudiovisualDocument"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#scopeNote"/>
        <owl:annotatedTarget xml:lang="en">For library (3.2.3.02) and museum (3.2.3.06) statistics purposes, microforms (3.4.5.1.03) are excluded</owl:annotatedTarget>
        <schema:position rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</schema:position>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/extended/AudiovisualDocument"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#scopeNote"/>
        <owl:annotatedTarget xml:lang="en">This includes audio documents such as phonographic records, tapes, cassettes, audio compact discs, DVDs, files of digital audio recordings; visual documents such as slides, transparencies; and combined audiovisual documents, such as motion pictures, video recordings, computer games, etc.</owl:annotatedTarget>
        <schema:position rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</schema:position>
    </owl:Axiom>
    


    <!-- https://haddenindustries.com/ontology/universal/extended/BankAccountInstance -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/universal/extended/BankAccountInstance">
