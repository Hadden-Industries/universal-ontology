        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-25T13:11:00Z</dcterms:modified>
        <rdfs:label xml:lang="en">Transport Network</rdfs:label>
        <skos:definition xml:lang="en">Realisation of a geometric graph, composed of Transport Nodes connected by Transport Links</skos:definition>
        <skos:prefLabel xml:lang="en">Transport Network</skos:prefLabel>
    </owl:Class>
    


