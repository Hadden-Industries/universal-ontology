    <!-- https://haddenindustries.com/ontology/universal/extended/VirtualVisit -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/universal/extended/VirtualVisit">
        <rdfs:subClassOf rdf:resource="https://haddenindustries.com/ontology/universal/core/Event"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-08-26T15:38:28Z</dcterms:created>
        <dcterms:creator rdf:resource="https://orcid.org/0000-0001-8017-8797"/>
        <dcterms:identifier rdf:resource="urn:uuid:8bbf8c68-920b-4f6b-9914-b6b55011e513"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-26T22:28:00Z</dcterms:modified>
        <dcterms:source rdf:resource="urn:iso:std:iso:5127:ed-2:v1:term:3.11.1.22"/>
        <dcterms:source xml:lang="en">ISO 2789:2013, definition 2.2.39, modified</dcterms:source>
        <rdfs:label xml:lang="en">Virtual Visit</rdfs:label>
        <skos:definition xml:lang="en">One continuous cycle of user activities on the website of an information and documentation organisation by users from outside the organisation&apos;s Internet Protocol address space (usually off the premises), regardless of the number of webpages or elements viewed</skos:definition>
        <skos:prefLabel xml:lang="en">Virtual Visit</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A virtual visit typically starts when a user accesses (3.11.1.01) the organization’s website after visiting an external webpage, and ends if no activity has been recorded for a defined period of time. Another access after a longer interval initiates a new visit.</skos:scopeNote>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/extended/VirtualVisit"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#scopeNote"/>
        <owl:annotatedTarget xml:lang="en">A virtual visit typically starts when a user accesses (3.11.1.01) the organization’s website after visiting an external webpage, and ends if no activity has been recorded for a defined period of time. Another access after a longer interval initiates a new visit.</owl:annotatedTarget>
        <schema:position rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</schema:position>
    </owl:Axiom>
    


