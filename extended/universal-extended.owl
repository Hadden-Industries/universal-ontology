    <!-- https://haddenindustries.com/ontology/universal/extended/BaptismCertificate -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/universal/extended/BaptismCertificate">
        <rdfs:subClassOf rdf:resource="https://haddenindustries.com/ontology/universal/core/Document"/>
        <dcterms:creator rdf:resource="https://orcid.org/0000-0001-8017-8797"/>
