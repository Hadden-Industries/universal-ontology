    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/extended/CustomerFeedback"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#prefLabel"/>
        <owl:annotatedTarget xml:lang="en">Customer Feedback</owl:annotatedTarget>
        <rdfs:comment xml:lang="en">&apos;Customer&apos; qualifier term added</rdfs:comment>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/extended/CustomerFeedback"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#comment"/>
        <owl:annotatedTarget xml:lang="en-gb">Feedback can be given in relation to other processes where the organisation interacts with the customer</owl:annotatedTarget>
        <rdfs:comment xml:lang="en">Note 1 to entry</rdfs:comment>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/extended/CustomerFeedback"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#comment"/>
        <owl:annotatedTarget xml:lang="en">ISO 9000:2015, 3.9.1, modified — Note 1 to entry has been added</owl:annotatedTarget>
        <rdfs:comment xml:lang="en">SOURCE</rdfs:comment>
