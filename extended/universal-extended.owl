    <!-- https://haddenindustries.com/ontology/universal/extended/VirtualVisit -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/universal/extended/VirtualVisit">
        <rdfs:subClassOf rdf:resource="https://haddenindustries.com/ontology/universal/core/Event"/>
        <dcterms:creator rdf:resource="https://orcid.org/0000-0001-8017-8797"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-08-26T15:38:28Z</dcterms:created>
        <skos:definition xml:lang="en">One continuous cycle of user activities on the website of an information and documentation organisation by users from outside the organisation&apos;s Internet Protocol address space (usually off the premises), regardless of the number of webpages or elements viewed</skos:definition>
        <dcterms:identifier rdf:resource="urn:uuid:8bbf8c68-920b-4f6b-9914-b6b55011e513"/>
        <dcterms:references rdf:resource="urn:iso:std:iso:5127:ed-2:v1:en:term:3.11.1.22"/>
        <skos:prefLabel xml:lang="en">Virtual Visit</skos:prefLabel>
        <rdfs:comment xml:lang="en">Note 1 to entry: A virtual visit typically starts when a user accesses (3.11.1.01) the organization’s website after visiting an external webpage, and ends if no activity has been recorded for a defined period of time. Another access after a longer interval initiates a new visit.
[SOURCE: ISO 2789:2013, definition 2.2.39, modified]</rdfs:comment>
        <rdfs:label xml:lang="en">Virtual Visit</rdfs:label>
	<dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-25T13:11:00Z</dcterms:modified>
    </owl:Class>
    


