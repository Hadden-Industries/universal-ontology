    <!-- https://haddenindustries.com/ontology/universal/extended/PredictiveMeasurement -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/universal/extended/PredictiveMeasurement">
        <rdfs:subClassOf rdf:resource="https://haddenindustries.com/ontology/universal/core/Measurement"/>
        <dcterms:creator rdf:resource="https://orcid.org/0000-0001-8017-8797"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-01-09T19:58:32Z</dcterms:created>
        <skos:definition xml:lang="en">Process of determining a quantity value attributed to a future or inaccessible state of a phenomenon, body, or substance, based on a measurement model using experimentally obtained input quantity values from the current or past states</skos:definition>
        <dcterms:identifier rdf:resource="urn:uuid:29547b6d-bf00-40db-8784-963b05ec4cba"/>
        <skos:prefLabel xml:lang="en">Predictive Measurement</skos:prefLabel>
        <rdfs:comment xml:lang="en">Note 1: Predictive measurement relies on a temporal or functional extrapolation provided by the measurement model.
Note 2: The measurement uncertainty of a predictive measurement includes components arising from the input quantities and components arising from the predictive model (model uncertainty).
Note 3: Unlike a forecast, a predictive measurement requires metrological traceability for both its input quantities and the validation of its measurement model.</rdfs:comment>
        <rdfs:label xml:lang="en">Predictive Measurement</rdfs:label>
	<dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-25T13:11:00Z</dcterms:modified>
    </owl:Class>
    


