        <skos:prefLabel xml:lang="en">Vehicle</skos:prefLabel>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/extended/Vehicle"/>
