        <skos:altLabel xml:lang="en">Network link</skos:altLabel>
        <skos:definition xml:lang="en">Way connecting Transport Nodes to one another</skos:definition>
        <skos:prefLabel xml:lang="en">Transport Link</skos:prefLabel>
    </owl:Class>
    


