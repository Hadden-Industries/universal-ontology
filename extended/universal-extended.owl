                <owl:onProperty rdf:resource="https://haddenindustries.com/ontology/universal/extended/AssessedNominalPropertyValue_hasNominalPropertyValue"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/NominalPropertyValue"/>
            </owl:Restriction>
        </rdfs:subClassOf>
