    <!-- https://haddenindustries.com/ontology/universal/extended/BrandToOfferingRelationship -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/universal/extended/BrandToOfferingRelationship">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://haddenindustries.com/ontology/universal/extended/BrandToOfferingRelationship_hasBrand"/>
