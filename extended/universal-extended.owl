        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#definition"/>
        <owl:annotatedTarget xml:lang="en">Product Or Service offered by the Post to users, where a service results from the completion, in a logical sequence, of a series of postal operations</owl:annotatedTarget>
        <dcterms:source rdf:resource="https://upu-mt.sdlmultitrans.com/MultiTransWeb/Term.mvc/Display?termGroupId=37196"/>
    </owl:Axiom>
    


    <!-- https://haddenindustries.com/ontology/universal/extended/PredictiveMeasurement -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/universal/extended/PredictiveMeasurement">
        <rdfs:subClassOf rdf:resource="https://haddenindustries.com/ontology/universal/core/Measurement"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-01-09T19:58:32Z</dcterms:created>
        <dcterms:creator rdf:resource="https://orcid.org/0000-0001-8017-8797"/>
        <dcterms:identifier rdf:resource="urn:uuid:29547b6d-bf00-40db-8784-963b05ec4cba"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-26T21:57:28Z</dcterms:modified>
        <rdfs:label xml:lang="en">Predictive Measurement</rdfs:label>
        <skos:definition xml:lang="en">Process of determining a quantity value attributed to a future or inaccessible state of a phenomenon, body, or substance, based on a measurement model using experimentally obtained input quantity values from the current or past states</skos:definition>
        <skos:prefLabel xml:lang="en">Predictive Measurement</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Predictive measurement relies on a temporal or functional extrapolation provided by the measurement model</skos:scopeNote>
        <skos:scopeNote xml:lang="en">The measurement uncertainty of a predictive measurement includes components arising from the input quantities and components arising from the predictive model (model uncertainty)</skos:scopeNote>
        <skos:scopeNote xml:lang="en">Unlike a forecast, a predictive measurement requires metrological traceability for both its input quantities and the validation of its measurement model</skos:scopeNote>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/extended/PredictiveMeasurement"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#scopeNote"/>
        <owl:annotatedTarget xml:lang="en">Predictive measurement relies on a temporal or functional extrapolation provided by the measurement model</owl:annotatedTarget>
        <schema:position rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</schema:position>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/extended/PredictiveMeasurement"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#scopeNote"/>
        <owl:annotatedTarget xml:lang="en">The measurement uncertainty of a predictive measurement includes components arising from the input quantities and components arising from the predictive model (model uncertainty)</owl:annotatedTarget>
        <schema:position rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</schema:position>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/extended/PredictiveMeasurement"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#scopeNote"/>
        <owl:annotatedTarget xml:lang="en">Unlike a forecast, a predictive measurement requires metrological traceability for both its input quantities and the validation of its measurement model</owl:annotatedTarget>
        <schema:position rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</schema:position>
    </owl:Axiom>
    


