        <skos:definition xml:lang="en">Product Or Service offered by the Post to users, where a service results from the completion, in a logical sequence, of a series of postal operations</skos:definition>
        <skos:prefLabel xml:lang="en">Postal Service</skos:prefLabel>
    </owl:Class>
    <owl:Axiom>
