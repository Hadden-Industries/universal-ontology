        <skos:altLabel xml:lang="en">Baptismal Certificate</skos:altLabel>
	<dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-25T13:11:00Z</dcterms:modified>
    </owl:Class>
    


    <!-- https://haddenindustries.com/ontology/universal/extended/Barcode -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/universal/extended/Barcode">
        <rdfs:subClassOf rdf:resource="https://haddenindustries.com/ontology/universal/extended/Label"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://haddenindustries.com/ontology/universal/extended/Barcode_hasBarcodeSymbology"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/BarcodeSymbology"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dcterms:creator rdf:resource="https://orcid.org/0000-0001-8017-8797"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2016-09-30T12:00:00Z</dcterms:created>
        <skos:definition xml:lang="en">Optical machine-readable representation of data, showing data about the object to which it attaches</skos:definition>
        <dcterms:identifier rdf:resource="urn:uuid:55b42f3a-29ad-415b-b07a-e3f0994eb549"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-26T16:04:00Z</dcterms:modified>
        <dcterms:source rdf:resource="urn:iso:std:iso:ts:16791:ed-2:v1:term:3.1.9"/>
        <skos:prefLabel xml:lang="en">Barcode</skos:prefLabel>
        <rdfs:comment xml:lang="en">Originally, barcodes represented data by varying the widths and spacings of parallel lines, and can be referred to as linear or one-dimensional (1D). Later they evolved into rectangles, dots, hexagons, and other geometric patterns in two dimensions (2D). Although 2D systems use a variety of symbols, they are generally referred to as barcodes as well.</rdfs:comment>
        <rdfs:label xml:lang="en">Barcode</rdfs:label>
        <skos:altLabel xml:lang="en">Bar Code</skos:altLabel>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/extended/Barcode"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#comment"/>
        <owl:annotatedTarget xml:lang="en">Originally, barcodes represented data by varying the widths and spacings of parallel lines, and can be referred to as linear or one-dimensional (1D). Later they evolved into rectangles, dots, hexagons, and other geometric patterns in two dimensions (2D). Although 2D systems use a variety of symbols, they are generally referred to as barcodes as well.</owl:annotatedTarget>
        <rdfs:comment xml:lang="en">Note 1 to entry</rdfs:comment>
    </owl:Axiom>
    


