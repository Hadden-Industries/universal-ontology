    <!-- https://haddenindustries.com/ontology/universal/extended/InternetProtocolAddressAssignment -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/universal/extended/InternetProtocolAddressAssignment">
        <rdfs:subClassOf rdf:resource="https://haddenindustries.com/ontology/universal/core/ProductOrService"/>
        <dcterms:creator rdf:resource="https://orcid.org/0000-0001-8017-8797"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2017-10-26T11:51:41Z</dcterms:created>
        <skos:definition xml:lang="en">Product Or Service for the allocation of a unique numerical identifier to a device that is connected to a computer network and uses the Internet Protocol for communication</skos:definition>
        <dcterms:identifier rdf:resource="urn:uuid:009d67de-2f51-4e76-b5ae-042707635966"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-25T13:11:00Z</dcterms:modified>
        <skos:prefLabel xml:lang="en">Internet Protocol Address Assignment</skos:prefLabel>
        <rdfs:label xml:lang="en">Internet Protocol Address Assignment</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/extended/InternetProtocolAddressAssignment"/>
        <owl:annotatedProperty rdf:resource="http://purl.org/dc/terms/description"/>
        <owl:annotatedTarget xml:lang="en">Product Or Service for the allocation of a unique numerical identifier to a device that is connected to a computer network and uses the Internet Protocol for communication</owl:annotatedTarget>
        <dcterms:source rdf:resource="https://www.law.cornell.edu/wex/ip_address"/>
