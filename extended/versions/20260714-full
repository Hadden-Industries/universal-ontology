  <owl:Class rdf:about="https://haddenindustries.com/ontology/universal/extended/PredictiveMeasurement">
    <rdfs:subClassOf rdf:resource="https://haddenindustries.com/ontology/universal/core/Measurement"/>
    <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-01-09T19:58:32+00:00</dcterms:created>
    <dcterms:creator rdf:resource="https://orcid.org/0000-0001-8017-8797"/>
