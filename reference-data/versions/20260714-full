    <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-10-08T07:01:36+00:00</dcterms:created>
    <dcterms:creator rdf:resource="https://orcid.org/0000-0001-8017-8797"/>
    <dcterms:identifier rdf:resource="urn:uuid:7d240c6b-5e75-4395-9e52-8f8465fb4184"/>
    <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-23T07:54:00+00:00</dcterms:modified>
    <dcterms:source rdf:resource="https://jcgm.bipm.org/vim/en/1.30.html"/>
    <rdfs:label xml:lang="en">Nominal Property</rdfs:label>
    <skos:definition xml:lang="en">Property of a phenomenon, body, or substance, where the property has no magnitude</skos:definition>
    <skos:example xml:lang="en">Colour of a paint sample</skos:example>
    <skos:example xml:lang="en">Colour of a spot test in chemistry</skos:example>
    <skos:example xml:lang="en">ISO two-letter country code</skos:example>
    <skos:example xml:lang="en">Sequence of amino acids in a polypeptide</skos:example>
    <skos:example xml:lang="en">Sex of a human being</skos:example>
    <skos:note xml:lang="en">Nominal properties are distinguished from quantities, which are properties that have a magnitude, that is, they can be compared in terms of greater or lesser</skos:note>
    <skos:note xml:lang="en">While colour of a paint sample is sometimes considered to be a nominal property, it is also recognized that a pure colour can be characterized by the wavelength of electromagnetic radiation, which is a quantity that can be measured</skos:note>
    <skos:prefLabel xml:lang="en">Nominal Property</skos:prefLabel>
    <skos:scopeNote xml:lang="en">'Nominal property value' is not to be confused with nominal quantity value</skos:scopeNote>
    <skos:scopeNote xml:lang="en">A nominal property has a value, which can be expressed in words, by alphanumerical codes, or by other means</skos:scopeNote>
  </owl:Class>
