        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-05-04T16:03:02Z</dcterms:modified>
        <rdfs:label xml:lang="en">Product Or Service Relationship Type</rdfs:label>
