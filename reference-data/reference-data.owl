    <!-- https://haddenindustries.com/ontology/universal/reference-data/Offence -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/universal/reference-data/Offence">
        <dc:creator rdf:resource="https://orcid.org/0000-0001-8017-8797"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-04-11T16:21:36Z</dcterms:created>
        <dcterms:identifier rdf:resource="urn:uuid:65232c93-cfc3-416d-8a16-dea0bc0cd7d2"/>
        <rdfs:label xml:lang="en">Offence</rdfs:label>
        <skos:definition xml:lang="en">Act, omission, or formal application that constitutes a violation of criminal, civil, or administrative law, or establishes a statutory cause of action requiring processing, recording, or adjudication by the justice system</skos:definition>
        <skos:prefLabel xml:lang="en">Offence</skos:prefLabel>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/Offence"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#definition"/>
        <owl:annotatedTarget xml:lang="en">Act, omission, or formal application that constitutes a violation of criminal, civil, or administrative law, or establishes a statutory cause of action requiring processing, recording, or adjudication by the justice system</owl:annotatedTarget>
        <dcterms:source rdf:resource="https://gemini.google.com/app/45ec130e0fb5fc8d"/>
    </owl:Axiom>
    


