        <skos:definition xml:lang="en">Postcode that corresponds to a location</skos:definition>
        <skos:prefLabel xml:lang="en">Geographic Postcode</skos:prefLabel>
    </owl:Class>
    


    <!-- https://haddenindustries.com/ontology/universal/reference-data/GlobalIndustryClassificationStandard -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/universal/reference-data/GlobalIndustryClassificationStandard">
        <rdfs:subClassOf rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/EconomicActivityClassificationScheme"/>
        <dc:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2022-04-17T13:08:42Z</dcterms:created>
        <dcterms:identifier rdf:resource="urn:uuid:0d414aa4-5c6a-4b0f-ad60-22389167b474"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-04-29T15:47:00Z</dcterms:modified>
        <dcterms:references rdf:resource="https://www.msci.com/index/methodology/latest/GICS"/>
        <rdfs:label xml:lang="en">Global Industry Classification Standard</rdfs:label>
        <rdfs:seeAlso rdf:resource="http://www.msci.com/gics"/>
        <skos:definition xml:lang="en">Four-tiered, hierarchical Economic Activity Classification Scheme developed in 1999 by MSCI and S&amp;P Dow Jones Indices, seeking to offer an efficient investment tool to capture the breadth, depth and evolution of industry sectors</skos:definition>
        <skos:prefLabel xml:lang="en">Global Industry Classification Standard</skos:prefLabel>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/GlobalIndustryClassificationStandard"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#prefLabel"/>
        <owl:annotatedTarget xml:lang="en">Global Industry Classification Standard</owl:annotatedTarget>
        <dcterms:alternative xml:lang="en">GICS</dcterms:alternative>
    </owl:Axiom>
    


    <!-- https://haddenindustries.com/ontology/universal/reference-data/GrammaticalGender -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/universal/reference-data/GrammaticalGender">
        <rdfs:subClassOf rdf:resource="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/term/ClassificationSchemeItem"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/GrammaticalGender_hasSex"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">0</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/Sex"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/GrammaticalGender_hasSex"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/Sex"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dc:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-06-06T17:59:20Z</dcterms:created>
        <dcterms:identifier rdf:resource="urn:uuid:a9769fdf-e69e-4f47-8e9c-0136444663d2"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-04-29T15:16:00Z</dcterms:modified>
        <rdfs:label xml:lang="en">Grammatical Gender</rdfs:label>
        <rdfs:seeAlso rdf:resource="http://datcatinfo.termweb.eu/datcat/DC-0245"/>
        <skos:definition xml:lang="en">Gender based on arbitrary assignment, without regard to the referent of a noun, as in French le livre (masculine), “the book,” and German das Mädchen (neuter), “the girl”</skos:definition>
        <skos:prefLabel xml:lang="en">Grammatical Gender</skos:prefLabel>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/GrammaticalGender"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#definition"/>
        <owl:annotatedTarget xml:lang="en">Gender based on arbitrary assignment, without regard to the referent of a noun, as in French le livre (masculine), “the book,” and German das Mädchen (neuter), “the girl”</owl:annotatedTarget>
        <dcterms:source rdf:resource="https://www.collinsdictionary.com/dictionary/english/grammatical-gender"/>
    </owl:Axiom>
    


    <!-- https://haddenindustries.com/ontology/universal/reference-data/GrammaticalNumber -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/universal/reference-data/GrammaticalNumber">
        <rdfs:subClassOf rdf:resource="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/term/ClassificationSchemeItem"/>
        <dc:creator rdf:resource="https://orcid.org/0000-0001-8017-8797"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-04-29T16:48:18Z</dcterms:created>
        <dcterms:identifier rdf:resource="urn:uuid:b9330dd2-7d1b-4486-8776-98d7474bc111"/>
        <dcterms:source rdf:resource="http://datcatinfo.termweb.eu/datcat/DC-1298"/>
        <rdfs:label xml:lang="en">Grammatical Number</rdfs:label>
        <skos:definition xml:lang="en">Grammatical category for the variation in form of nouns, pronouns, and any words agreeing with them, depending on how many persons or things are referred to</skos:definition>
        <skos:prefLabel xml:lang="en">Grammatical Number</skos:prefLabel>
    </owl:Class>
    


    <!-- https://haddenindustries.com/ontology/universal/reference-data/GrammaticalPerson -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/universal/reference-data/GrammaticalPerson">
        <dc:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-06-06T12:07:02Z</dcterms:created>
        <dcterms:identifier rdf:resource="urn:uuid:15f64ed7-4124-450a-85b0-a24cbcda73af"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-05-04T15:07:34Z</dcterms:modified>
        <rdfs:label xml:lang="en">Grammatical Person</rdfs:label>
        <skos:definition xml:lang="en">Linguistic category used to distinguish between the speaker of an utterance and those to whom or about whom he is referring; implemented in most languages by a variety of pronouns, and in inflected languages by variation in word endings</skos:definition>
        <skos:prefLabel xml:lang="en">Grammatical Person</skos:prefLabel>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/GrammaticalPerson"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#definition"/>
        <owl:annotatedTarget xml:lang="en">Linguistic category used to distinguish between the speaker of an utterance and those to whom or about whom he is referring; implemented in most languages by a variety of pronouns, and in inflected languages by variation in word endings</owl:annotatedTarget>
        <dcterms:source rdf:resource="https://en.wiktionary.org/wiki/grammatical_person"/>
    </owl:Axiom>
    


    <!-- https://haddenindustries.com/ontology/universal/reference-data/HairColourClass -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/universal/reference-data/HairColourClass">
