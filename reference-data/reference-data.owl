        <owl:annotatedTarget xml:lang="en">Horizontal Direction towards the point of the horizon where the sun sets at the equinoxes, on the left-hand side of a person facing north, or the part of the horizon lying in this direction</owl:annotatedTarget>
        <dcterms:source rdf:resource="https://www.lexico.com/definition/west"/>
    </owl:Axiom>
