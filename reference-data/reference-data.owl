        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-09-23T08:37:36Z</dcterms:created>
        <dcterms:identifier rdf:resource="urn:uuid:156baf58-210f-448a-b039-495dad05d530"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-05-04T16:03:12Z</dcterms:modified>
        <rdfs:label xml:lang="en">Product Or Service Property Operating Range Type</rdfs:label>
        <skos:definition xml:lang="en">Set of qualified values, such as minimum, maximum, and typical, to define the limits of a characteristic for a product or service to function as specified</skos:definition>
        <skos:prefLabel xml:lang="en">Product Or Service Property Operating Range Type</skos:prefLabel>
    </owl:Class>
    


