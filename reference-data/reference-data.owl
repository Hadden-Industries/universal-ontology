    <!-- https://haddenindustries.com/ontology/universal/reference-data/LanguageScript -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/universal/reference-data/LanguageScript">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/hasLanguage"/>
                <owl:someValuesFrom rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/Language"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dc:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2020-03-30T13:34:37Z</dcterms:created>
        <dcterms:identifier rdf:resource="urn:uuid:6b38ee2a-65c8-4302-866c-a0a3bc9e33d7"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-23T07:37:20Z</dcterms:modified>
        <dcterms:source rdf:resource="urn:iso:std:iso:15924:ed-2:v1:term:3.7"/>
        <dcterms:source xml:lang="en">ISO/IEC 10646:2020, 3.48</dcterms:source>
        <rdfs:comment xml:lang="en">A script, as opposed to an arbitrary subset of characters, is defined in distinction to other scripts; in general, readers of one script may be unable to read another script easily, even where there is a historic relation between them (see 3.9)</rdfs:comment>
        <rdfs:comment xml:lang="en">In certain cases, ISO 15924 provides codes which are not subsumed under this definition. Examples: the codes for aliases and the variant codes</rdfs:comment>
        <rdfs:label xml:lang="en">Language Script</rdfs:label>
        <rdfs:label xml:lang="en">Script</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://unicode.org/iso15924/codelists.html"/>
        <skos:definition xml:lang="en">Set of graphic characters used for the written form of one or more languages</skos:definition>
        <skos:prefLabel xml:lang="en">Language Script</skos:prefLabel>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/LanguageScript"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#comment"/>
        <owl:annotatedTarget xml:lang="en">A script, as opposed to an arbitrary subset of characters, is defined in distinction to other scripts; in general, readers of one script may be unable to read another script easily, even where there is a historic relation between them (see 3.9)</owl:annotatedTarget>
        <rdfs:comment xml:lang="en">Note 1 to entry</rdfs:comment>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/LanguageScript"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#comment"/>
        <owl:annotatedTarget xml:lang="en">In certain cases, ISO 15924 provides codes which are not subsumed under this definition. Examples: the codes for aliases and the variant codes</owl:annotatedTarget>
        <rdfs:comment xml:lang="en">Note 2 to entry</rdfs:comment>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/LanguageScript"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#label"/>
        <owl:annotatedTarget xml:lang="en">Language Script</owl:annotatedTarget>
        <skos:note xml:lang="en">Not specified in ISO 15924:2022</skos:note>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/LanguageScript"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#label"/>
        <owl:annotatedTarget xml:lang="en">Script</owl:annotatedTarget>
        <skos:note xml:lang="en">This is the preferred label in ISO 15924:2022</skos:note>
    </owl:Axiom>
    


