        <dcterms:source rdf:resource="urn:iso:std:iso:1087:ed-2:v1:term:3.4.23"/>
        <rdfs:comment xml:lang="en">Designations in the relation of synonymy are called “synonyms”</rdfs:comment>
        <rdfs:label xml:lang="en">Synonymy</rdfs:label>
        <skos:definition xml:lang="en">Relation between designations in a given natural language representing the same concept</skos:definition>
        <skos:example xml:lang="en">Synonymy exists between “deuterium” and “heavy hydrogen”, between “United Nations” and “UN”</skos:example>
        <skos:prefLabel xml:lang="en">Synonymy</skos:prefLabel>
    </owl:NamedIndividual>
