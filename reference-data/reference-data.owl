        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/DatabaseManagementSystem"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#comment"/>
        <owl:annotatedTarget xml:lang="en">17.01.03 (2382)</owl:annotatedTarget>
