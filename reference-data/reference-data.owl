        <rdfs:label xml:lang="en">West</rdfs:label>
        <skos:definition xml:lang="en">Horizontal Direction towards the point of the horizon where the sun sets at the equinoxes, on the left-hand side of a person facing north, or the part of the horizon lying in this direction</skos:definition>
        <skos:prefLabel xml:lang="en">West</skos:prefLabel>
