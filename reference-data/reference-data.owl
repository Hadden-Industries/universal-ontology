        <rdfs:label xml:lang="en">Transliteration System</rdfs:label>
        <skos:definition xml:lang="en">System of operations which consist of representing the characters of an entirely alphabetical character or alphanumeric character writing system by the characters of the conversion alphabet</skos:definition>
