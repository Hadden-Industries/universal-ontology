        <rdfs:comment xml:lang="en">Title I 8.</rdfs:comment>
    </owl:Axiom>
    


    <!-- https://haddenindustries.com/ontology/universal/reference-data/StandardInternationalTradeClassification -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/universal/reference-data/StandardInternationalTradeClassification">
