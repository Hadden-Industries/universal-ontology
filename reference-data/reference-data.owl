    <!-- https://haddenindustries.com/ontology/universal/reference-data/Equivalence -->

    <owl:NamedIndividual rdf:about="https://haddenindustries.com/ontology/universal/reference-data/Equivalence">
        <rdf:type rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/DesignationRelationshipType"/>
        <dc:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2023-02-18T14:56:24Z</dcterms:created>
        <dcterms:identifier rdf:resource="urn:uuid:6043a082-0e0d-4911-bbeb-b6f87d1d74ee"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-23T08:32:04Z</dcterms:modified>
        <dcterms:source rdf:resource="urn:iso:std:iso:1087:ed-2:v1:term:3.4.24"/>
        <rdfs:comment xml:lang="en">Designations in the relation of equivalence are called “equivalents”</rdfs:comment>
        <rdfs:label xml:lang="en">Equivalence</rdfs:label>
        <skos:definition xml:lang="en">Relation between designations in different natural languages representing the same concept</skos:definition>
        <skos:example xml:lang="en">The French term (3.4.2) “ordinateur” is an equivalent of the English term “computer”</skos:example>
        <skos:prefLabel xml:lang="en">Equivalence</skos:prefLabel>
    </owl:NamedIndividual>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/Equivalence"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#comment"/>
        <owl:annotatedTarget xml:lang="en">Designations in the relation of equivalence are called “equivalents”</owl:annotatedTarget>
        <rdfs:comment xml:lang="en">Note 1 to entry</rdfs:comment>
    </owl:Axiom>
    


