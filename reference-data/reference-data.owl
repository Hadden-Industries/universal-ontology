    <owl:Class rdf:about="https://haddenindustries.com/ontology/universal/reference-data/GS1GlobalProductClassification">
        <rdfs:subClassOf rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/ProductOrServiceClassificationScheme"/>
        <dc:creator rdf:resource="https://orcid.org/0000-0001-8017-8797"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-09-22T13:28:38Z</dcterms:created>
        <dcterms:identifier rdf:resource="urn:uuid:6e9e5604-ac56-463c-b4c4-fa1f23ee97f9"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-05-04T16:04:58Z</dcterms:modified>
        <rdfs:label xml:lang="en">GS1 Global Product Classification</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://gpc-browser.gs1.org/"/>
        <skos:definition xml:lang="en">Rules-based standard that provides a universal system for grouping products into a four-tier hierarchy, establishing a common language to ensure that trade items are categorised uniformly by trading partners across the global supply chain</skos:definition>
        <skos:prefLabel xml:lang="en">GS1 Global Product Classification</skos:prefLabel>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/GS1GlobalProductClassification"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#prefLabel"/>
        <owl:annotatedTarget xml:lang="en">GS1 Global Product Classification</owl:annotatedTarget>
        <dcterms:alternative xml:lang="en">GPC</dcterms:alternative>
    </owl:Axiom>
    


