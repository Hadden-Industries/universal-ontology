        <rdfs:label xml:lang="en-us">Hair Color Class</rdfs:label>
        <rdfs:label xml:lang="en-gb">Hair Colour Class</rdfs:label>
        <skos:definition xml:lang="en">Concept defining a set of perceived perceived hues of the epidermal keratinous filaments, based on specific shared characteristics and rules</skos:definition>
        <skos:prefLabel xml:lang="en-us">Hair Color Class</skos:prefLabel>
        <skos:prefLabel xml:lang="en-gb">Hair Colour Class</skos:prefLabel>
