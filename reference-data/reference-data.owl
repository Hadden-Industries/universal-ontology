    <owl:Class rdf:about="https://haddenindustries.com/ontology/universal/reference-data/TimeZone">
        <dc:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2020-03-30T13:07:33Z</dcterms:created>
        <dcterms:identifier rdf:resource="urn:uuid:42139aa3-d058-41c5-8957-72928febfb46"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-05-04T20:58:56Z</dcterms:modified>
        <rdfs:label xml:lang="en">Time Zone</rdfs:label>
        <rdfs:seeAlso rdf:resource="http://schema.org/broadcastTimezone"/>
        <rdfs:seeAlso rdf:resource="http://schema.org/scheduleTimezone"/>
        <skos:definition xml:lang="en">One of the areas into which the world is divided where the time is calculated as being a particular number of hours behind or ahead of Greenwich Mean Time</skos:definition>
        <skos:prefLabel xml:lang="en">Time Zone</skos:prefLabel>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/TimeZone"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#definition"/>
        <owl:annotatedTarget xml:lang="en">One of the areas into which the world is divided where the time is calculated as being a particular number of hours behind or ahead of Greenwich Mean Time</owl:annotatedTarget>
        <dcterms:source rdf:resource="https://www.collinsdictionary.com/dictionary/english/time-zone"/>
    </owl:Axiom>
    


