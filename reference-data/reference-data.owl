        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2023-01-23T12:26:36Z</dcterms:created>
        <dcterms:identifier rdf:resource="urn:uuid:a7115360-6ca7-4050-a6f7-ebf9d645ccef"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-05-04T21:10:30Z</dcterms:modified>
        <rdfs:label xml:lang="en">Source Of Funds</rdfs:label>
        <skos:definition xml:lang="en">Origin of the funds involved in a business relationship or occasional transaction. It includes both the activity that generated the funds used in the business relationship, for example the customer’s salary, as well as the means through which the customer’s funds were transferred.</skos:definition>
        <skos:prefLabel xml:lang="en">Source Of Funds</skos:prefLabel>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/SourceOfFunds"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#definition"/>
        <owl:annotatedTarget xml:lang="en">Origin of the funds involved in a business relationship or occasional transaction. It includes both the activity that generated the funds used in the business relationship, for example the customer’s salary, as well as the means through which the customer’s funds were transferred.</owl:annotatedTarget>
        <dcterms:source rdf:resource="https://www.eba.europa.eu/sites/default/files/documents/10180/1240374/c1d03800-2a50-4fbe-bf69-f0018c6e6157/JC%202015%20061%20(Joint%20Draft%20Guidelines%20on%20AML_CFT%20RFWG%20Art%2017%20and%2018).pdf"/>
        <rdfs:comment xml:lang="en">Title I 8.</rdfs:comment>
    </owl:Axiom>
    


