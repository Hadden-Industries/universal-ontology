    <!-- https://haddenindustries.com/ontology/universal/reference-data/Antonymy -->

    <owl:NamedIndividual rdf:about="https://haddenindustries.com/ontology/universal/reference-data/Antonymy">
        <rdf:type rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/DesignationRelationshipType"/>
        <dc:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2023-02-18T14:54:39Z</dcterms:created>
        <dcterms:identifier rdf:resource="urn:uuid:c825c393-d2db-4da1-b684-10f4666fc509"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-23T08:31:29Z</dcterms:modified>
        <dcterms:source rdf:resource="urn:iso:std:iso:1087:ed-2:v1:term:3.4.25"/>
        <rdfs:comment xml:lang="en">Designations (3.4.1) in the relation of antonymy are called “antonyms”.</rdfs:comment>
        <rdfs:label xml:lang="en">Antonymy</rdfs:label>
        <skos:definition xml:lang="en">Relation between two designations representing two coordinate concepts viewed as opposites of each other</skos:definition>
        <skos:example xml:lang="en">Antonymy exists between the terms (3.4.2) “encoding” and “decoding”, “positive” and “negative”</skos:example>
        <skos:prefLabel xml:lang="en">Antonymy</skos:prefLabel>
    </owl:NamedIndividual>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/Antonymy"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#comment"/>
        <owl:annotatedTarget xml:lang="en">Designations (3.4.1) in the relation of antonymy are called “antonyms”.</owl:annotatedTarget>
        <rdfs:comment xml:lang="en">Note 1 to entry</rdfs:comment>
    </owl:Axiom>
    


