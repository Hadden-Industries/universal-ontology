    <!-- https://haddenindustries.com/ontology/universal/reference-data/MarketIndex -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/universal/reference-data/MarketIndex">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/MarketIndex_hasMarket"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/Market"/>
            </owl:Restriction>
        </rdfs:subClassOf>
