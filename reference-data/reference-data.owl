    <!-- https://haddenindustries.com/ontology/universal/reference-data/InterleavedTwoOfFive -->

    <owl:NamedIndividual rdf:about="https://haddenindustries.com/ontology/universal/reference-data/InterleavedTwoOfFive">
        <rdf:type rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/LinearBarcodeSymbology"/>
        <dc:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-08-28T13:13:37Z</dcterms:created>
        <dcterms:identifier rdf:resource="urn:uuid:3d315de8-dfb9-4401-b547-8f090ea8fb48"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-23T07:27:12Z</dcterms:modified>
        <dcterms:source rdf:resource="urn:iso:std:iso:22742:ed-2:v1:term:3.26"/>
        <rdfs:comment xml:lang="en">Each character has two wide elements and three narrow elements for a total of five elements. This is most commonly represented in the GS1 ITF-14. See ISO/IEC 16390 for the Interleaved Two of Five symbology specification.</rdfs:comment>
        <rdfs:label xml:lang="en">Interleaved Two Of Five</rdfs:label>
        <skos:altLabel xml:lang="en">ITF</skos:altLabel>
        <skos:definition xml:lang="en">Bar code symbology where two characters are paired, using bars to represent the first character and the interleaved spaces to represent the second character, encoding the ten digits 0 to 9</skos:definition>
        <skos:prefLabel xml:lang="en">Interleaved Two Of Five</skos:prefLabel>
    </owl:NamedIndividual>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/InterleavedTwoOfFive"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#comment"/>
        <owl:annotatedTarget xml:lang="en">Each character has two wide elements and three narrow elements for a total of five elements. This is most commonly represented in the GS1 ITF-14. See ISO/IEC 16390 for the Interleaved Two of Five symbology specification.</owl:annotatedTarget>
        <rdfs:comment xml:lang="en">Note 1 to entry</rdfs:comment>
    </owl:Axiom>
    


