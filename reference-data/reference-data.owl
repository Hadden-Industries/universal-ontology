        <owl:annotatedTarget xml:lang="en">Category of the way in which two or more products or services are connected, having common characteristics</owl:annotatedTarget>
        <dcterms:source rdf:resource="https://www.lexico.com/definition/relationship"/>
        <dcterms:source rdf:resource="https://www.lexico.com/definition/type"/>
    </owl:Axiom>
    


    <!-- https://haddenindustries.com/ontology/universal/reference-data/ProductOrServiceRiskCategory -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/universal/reference-data/ProductOrServiceRiskCategory">
        <dc:creator rdf:resource="https://orcid.org/0000-0001-8017-8797"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-02-11T11:24:47Z</dcterms:created>
        <dcterms:identifier rdf:resource="urn:uuid:81cf312e-43c3-4801-a015-1fefd3450b6f"/>
        <rdfs:label xml:lang="en">Product Or Service Risk Category</rdfs:label>
        <skos:definition xml:lang="en">Classification of products or services based on the inherent level of risk they pose for being exploited for illicit activities, such as money laundering, terrorist financing, fraud, or other financial crimes</skos:definition>
        <skos:prefLabel xml:lang="en">Product Or Service Risk Category</skos:prefLabel>
    </owl:Class>
    


    <!-- https://haddenindustries.com/ontology/universal/reference-data/ProductOrServiceStatus -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/universal/reference-data/ProductOrServiceStatus">
