    <!-- https://haddenindustries.com/ontology/universal/reference-data/FischerSallerScale -->

    <owl:NamedIndividual rdf:about="https://haddenindustries.com/ontology/universal/reference-data/FischerSallerScale">
        <rdf:type rdf:resource="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/term/ClassificationScheme"/>
        <dc:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
