        <skos:altLabel xml:lang="en">CPC</skos:altLabel>
    </owl:Axiom>
    


    <!-- https://haddenindustries.com/ontology/universal/reference-data/ClassificationByBroadEconomicCategories -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/universal/reference-data/ClassificationByBroadEconomicCategories">
