    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/DocumentType"/>
        <owl:annotatedProperty rdf:resource="http://purl.org/dc/terms/source"/>
        <owl:annotatedTarget xml:lang="en">ISO/IEC TR 29166:2011, definition 3.3</owl:annotatedTarget>
        <skos:note xml:lang="en">modified</skos:note>
    </owl:Axiom>
    <owl:Axiom>
