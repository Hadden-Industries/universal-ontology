        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2022-04-14T17:09:02Z</dcterms:created>
        <dcterms:identifier rdf:resource="urn:uuid:1174a450-dcbb-4907-9346-20a06fc316b8"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-23T07:00:51Z</dcterms:modified>
        <dcterms:source rdf:resource="urn:iso:std:iso:5127:ed-2:v1:term:3.4.1.01"/>
        <dcterms:source xml:lang="en">ISO/IEC TR 29166:2011, definition 3.3</dcterms:source>
        <rdfs:comment xml:lang="en">See also “general material designation” (3.7.2.03), “specific material designation” (3.7.2.04); “special collection” (3.6.1.10); ISO 10209:2012, definition 11.58; ISO 29845:2011, definition 3.1.3; ISAD (G) 1999 (“form”)</rdfs:comment>
