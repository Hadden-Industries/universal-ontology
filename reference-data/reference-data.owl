    <!-- https://haddenindustries.com/ontology/universal/reference-data/AssetType -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/universal/reference-data/AssetType">
        <dc:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-09-02T09:27:23Z</dcterms:created>
        <dcterms:identifier rdf:resource="urn:uuid:53164810-914a-4fc7-9c1f-ec5b19279d69"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-23T07:10:03Z</dcterms:modified>
        <dcterms:source rdf:resource="urn:iso:std:iso:55000:ed-1:v2:term:3.2.6"/>
        <rdfs:label xml:lang="en">Asset Type</rdfs:label>
        <skos:definition xml:lang="en">Grouping of assets having common characteristics that distinguish those assets as a group or class</skos:definition>
        <skos:example xml:lang="en">Physical assets, information assets, intangible assets, critical assets (3.2.7), enabling assets, linear assets, information and communications technology (ICT) assets, infrastructure assets, moveable assets</skos:example>
        <skos:hiddenLabel xml:lang="en">Asset Class</skos:hiddenLabel>
        <skos:prefLabel xml:lang="en">Asset Type</skos:prefLabel>
    </owl:Class>
    


    <!-- https://haddenindustries.com/ontology/universal/reference-data/BarcodeSymbology -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/universal/reference-data/BarcodeSymbology">
        <dc:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2017-05-05T09:41:00Z</dcterms:created>
        <dcterms:identifier rdf:resource="urn:uuid:4bbe9d9a-bfb9-4659-a2f6-69707a9810b1"/>
        <rdfs:label xml:lang="en">Barcode Symbology</rdfs:label>
        <skos:definition xml:lang="en">Specification of how to encode data into a Machine-readable Image</skos:definition>
        <skos:prefLabel xml:lang="en">Barcode Symbology</skos:prefLabel>
    </owl:Class>
    


    <!-- https://haddenindustries.com/ontology/universal/reference-data/BaseRate -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/universal/reference-data/BaseRate">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/BaseRate_hasMonetaryAuthority"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/MonetaryAuthority"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dc:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2022-04-17T13:19:33Z</dcterms:created>
        <dcterms:identifier rdf:resource="urn:uuid:5be1c0c7-99b1-4c40-ac54-d0b87ef3cdfc"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-23T06:44:57Z</dcterms:modified>
        <dcterms:source rdf:resource="https://spec.edmcouncil.org/fibo/ontology/IND/InterestRates/InterestRates/BaseRate"/>
        <rdfs:label xml:lang="en">Base Rate</rdfs:label>
        <skos:altLabel xml:lang="en">BBR</skos:altLabel>
        <skos:altLabel xml:lang="en">Bank Base Rate</skos:altLabel>
        <skos:definition xml:lang="en">Basic rate of interest on which the actual rate a bank charges on loans to its customers is calculated</skos:definition>
        <skos:prefLabel xml:lang="en">Base Rate</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Typically, the bank base rate is a reference rate set by a central bank. Banks that are regulated by a given central bank cannot lend below the base rate to their customers. The bank base rate is determined on an ongoing basis and represents the central bank&apos;s judgement of the price of short-term funds on their interbank market.</skos:scopeNote>
    </owl:Class>
    


    <!-- https://haddenindustries.com/ontology/universal/reference-data/BasicLandAndPropertyUnit -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/universal/reference-data/BasicLandAndPropertyUnit">
        <rdfs:subClassOf rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/BasicPropertyUnit"/>
        <dc:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2020-09-02T11:36:06Z</dcterms:created>
        <dcterms:identifier rdf:resource="urn:uuid:cc28d198-367c-4f99-ab3c-63a16405c6bd"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-23T06:47:14Z</dcterms:modified>
        <rdfs:label xml:lang="en">Basic Land And Property Unit</rdfs:label>
        <skos:altLabel xml:lang="en">BLPU</skos:altLabel>
        <skos:definition xml:lang="en">Area of land in uniform property rights or, in the absence of such ownership evidence or where required for administrative purposes, inferred from physical features, occupation or use</skos:definition>
        <skos:prefLabel xml:lang="en">Basic Land And Property Unit</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Basic Property Unit in the United Kingdom as defined under British Standard 7666-2</skos:scopeNote>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/BasicLandAndPropertyUnit"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#definition"/>
        <owl:annotatedTarget xml:lang="en">Area of land in uniform property rights or, in the absence of such ownership evidence or where required for administrative purposes, inferred from physical features, occupation or use</owl:annotatedTarget>
        <dcterms:source rdf:resource="urn:isbn:978-0-580-48723-1"/>
    </owl:Axiom>
    


    <!-- https://haddenindustries.com/ontology/universal/reference-data/BasicPropertyUnit -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/universal/reference-data/BasicPropertyUnit">
        <rdfs:subClassOf rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/GeographicFeature"/>
        <dc:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2017-04-11T10:18:30Z</dcterms:created>
        <dcterms:identifier rdf:resource="urn:uuid:5206582f-69e1-4190-963b-7a1ac1a2a583"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-04-23T07:53:00Z</dcterms:modified>
        <dcterms:source rdf:resource="http://inspire.ec.europa.eu/featureconcept/BasicPropertyUnit"/>
        <rdfs:label xml:lang="en">Basic Property Unit</rdfs:label>
        <skos:definition xml:lang="en">Basic unit of ownership that is recorded in the land books, land registers or equivalent. It is defined by unique ownership and homogeneous real property rights, and may consist of one or more adjacent or geographically separate parcels.</skos:definition>
        <skos:prefLabel xml:lang="en">Basic Property Unit</skos:prefLabel>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/BasicPropertyUnit"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#prefLabel"/>
        <owl:annotatedTarget xml:lang="en">Basic Property Unit</owl:annotatedTarget>
        <dcterms:alternative xml:lang="en">BPU</dcterms:alternative>
    </owl:Axiom>
    


    <!-- https://haddenindustries.com/ontology/universal/reference-data/BodyMassIndexRange -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/universal/reference-data/BodyMassIndexRange">
        <dc:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2022-04-17T12:52:07Z</dcterms:created>
        <dcterms:identifier rdf:resource="urn:uuid:84f70b5f-9f20-4de5-97be-a927818fdfa0"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-05-04T12:34:58Z</dcterms:modified>
        <rdfs:label xml:lang="en">Body Mass Index Range</rdfs:label>
        <skos:definition xml:lang="en">Area of variation between upper and lower limits on a simple index of weight-for-height that is commonly used to classify underweight, overweight and obesity in adults and defined as the weight in kilograms divided by the square of the height in meters (kg/m2)</skos:definition>
        <skos:prefLabel xml:lang="en">Body Mass Index Range</skos:prefLabel>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/BodyMassIndexRange"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#definition"/>
        <owl:annotatedTarget xml:lang="en">Area of variation between upper and lower limits on a simple index of weight-for-height that is commonly used to classify underweight, overweight and obesity in adults and defined as the weight in kilograms divided by the square of the height in meters (kg/m2)</owl:annotatedTarget>
        <dcterms:source rdf:resource="https://www.lexico.com/definition/range"/>
        <dcterms:source rdf:resource="urn:iso:std:iso:21856:ed-1:v1:en:term:3.7"/>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/BodyMassIndexRange"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#prefLabel"/>
        <owl:annotatedTarget xml:lang="en">Body Mass Index Range</owl:annotatedTarget>
        <dcterms:alternative xml:lang="en">BMI Range</dcterms:alternative>
        <dcterms:alternative xml:lang="en">Quetelet Index Range</dcterms:alternative>
    </owl:Axiom>
    


    <!-- https://haddenindustries.com/ontology/universal/reference-data/CalendarDayOfWeek -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/universal/reference-data/CalendarDayOfWeek">
        <dc:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2017-04-24T12:28:01Z</dcterms:created>
        <dcterms:identifier rdf:resource="urn:uuid:5cb4fd09-537c-496a-9dbd-2d0a19148c58"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-05-04T12:44:23Z</dcterms:modified>
        <dcterms:source rdf:resource="urn:iso:std:iso:34000:ed-1:v1:term:7.14"/>
        <rdfs:comment xml:lang="en">Days in a calendar week are often named or identified by its ordinal number, depending on the week calendar</rdfs:comment>
        <rdfs:label xml:lang="en">Calendar Day Of Week</rdfs:label>
        <skos:definition xml:lang="en">Identified calendar day amongst the sequence of days within a calendar week</skos:definition>
        <skos:prefLabel xml:lang="en">Calendar Day Of Week</skos:prefLabel>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/CalendarDayOfWeek"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#comment"/>
        <owl:annotatedTarget xml:lang="en">Days in a calendar week are often named or identified by its ordinal number, depending on the week calendar</owl:annotatedTarget>
        <rdfs:comment xml:lang="en">Note 1 to entry</rdfs:comment>
    </owl:Axiom>
    


    <!-- https://haddenindustries.com/ontology/universal/reference-data/CalendarMonth -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/universal/reference-data/CalendarMonth">
        <dc:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2020-04-02T12:15:36Z</dcterms:created>
        <dcterms:identifier rdf:resource="urn:uuid:4da3f0b9-291c-4109-9859-9f9cefbb530b"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-23T07:08:29Z</dcterms:modified>
        <dcterms:source rdf:resource="urn:iso:std:iso:34000:ed-1:v1:term:7.21"/>
        <rdfs:comment xml:lang="en">A calendar month is in common parlance often referred to as month, however in this document calendar month and month have different definitions</rdfs:comment>
        <rdfs:label xml:lang="en">Calendar Month</rdfs:label>
        <skos:definition xml:lang="en">Time scale unit resulting from a defined division of a calendar year, each containing a specific number of calendar days</skos:definition>
        <skos:hiddenLabel xml:lang="en">Month Of Year</skos:hiddenLabel>
        <skos:prefLabel xml:lang="en">Calendar Month</skos:prefLabel>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/CalendarMonth"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#comment"/>
        <owl:annotatedTarget xml:lang="en">A calendar month is in common parlance often referred to as month, however in this document calendar month and month have different definitions</owl:annotatedTarget>
        <rdfs:comment xml:lang="en">Note 1 to entry</rdfs:comment>
    </owl:Axiom>
    


    <!-- https://haddenindustries.com/ontology/universal/reference-data/CalendarSystem -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/universal/reference-data/CalendarSystem">
        <dc:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2016-10-14T12:00:00Z</dcterms:created>
        <dcterms:identifier rdf:resource="urn:uuid:3e5ee9bf-cf4e-4252-a9d7-4116bc797a23"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-23T08:31:44Z</dcterms:modified>
        <dcterms:source rdf:resource="urn:iso:std:iso:34000:ed-1:v1:term:6.1"/>
        <rdfs:comment xml:lang="en">Calendar month, calendar year, calendar day are time scale units often included in a calendar system</rdfs:comment>
        <rdfs:comment xml:lang="en">Calendar systems are defined by various authorities. Usage of particular calendar systems at a point in time or geographic location may be driven by culture or regulations.</rdfs:comment>
        <rdfs:comment xml:lang="en">The document uses the term “calendar system” to distinguish a calendar system from a calendar instance that someone may hang on their wall</rdfs:comment>
        <rdfs:label xml:lang="en">Calendar</rdfs:label>
        <rdfs:label xml:lang="en">Calendar System</rdfs:label>
        <skos:definition xml:lang="en">Time scale that uses the time scale unit of calendar day as its basic unit</skos:definition>
        <skos:example xml:lang="en">The Gregorian calendar is a type of calendar system</skos:example>
        <skos:prefLabel xml:lang="en">Calendar System</skos:prefLabel>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/CalendarSystem"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#comment"/>
        <owl:annotatedTarget xml:lang="en">Calendar month, calendar year, calendar day are time scale units often included in a calendar system</owl:annotatedTarget>
        <rdfs:comment xml:lang="en">Note 1 to entry</rdfs:comment>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/CalendarSystem"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#comment"/>
        <owl:annotatedTarget xml:lang="en">Calendar systems are defined by various authorities. Usage of particular calendar systems at a point in time or geographic location may be driven by culture or regulations.</owl:annotatedTarget>
        <rdfs:comment xml:lang="en">Note 3 to entry</rdfs:comment>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/CalendarSystem"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#comment"/>
        <owl:annotatedTarget xml:lang="en">The document uses the term “calendar system” to distinguish a calendar system from a calendar instance that someone may hang on their wall</owl:annotatedTarget>
        <rdfs:comment xml:lang="en">Note 2 to entry</rdfs:comment>
    </owl:Axiom>
    


