        <rdfs:seeAlso rdf:resource="https://www.wcotradetools.org/en/harmonized-system"/>
        <skos:definition xml:lang="en">Six-digit numerical code that identifies a specific commodity group within the international, multipurpose product nomenclature administered by the World Customs Organization, structured hierarchically to classify traded goods</skos:definition>
        <skos:prefLabel xml:lang="en">Harmonized System Code</skos:prefLabel>
    </owl:Class>
