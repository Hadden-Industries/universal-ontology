        <rdfs:label xml:lang="en">Title</rdfs:label>
        <skos:definition xml:lang="en">Word such as Lord or Dame that is used before someone&apos;s name, or a form that is used instead of someone&apos;s name, to indicate high social or official rank</skos:definition>
        <skos:prefLabel xml:lang="en">Title</skos:prefLabel>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/Title"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#definition"/>
        <owl:annotatedTarget xml:lang="en">Word such as Lord or Dame that is used before someone&apos;s name, or a form that is used instead of someone&apos;s name, to indicate high social or official rank</owl:annotatedTarget>
        <dcterms:source rdf:resource="https://www.lexico.com/definition/title"/>
    </owl:Axiom>
    


