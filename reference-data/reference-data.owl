    <!-- https://haddenindustries.com/ontology/universal/reference-data/AztecCode -->

    <owl:NamedIndividual rdf:about="https://haddenindustries.com/ontology/universal/reference-data/AztecCode">
        <rdf:type rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/MatrixBarcodeSymbology"/>
        <dc:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-08-28T21:09:53Z</dcterms:created>
        <dcterms:identifier rdf:resource="urn:uuid:f1d67357-e47f-4db8-8277-a84827980e13"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-05-11T20:25:25Z</dcterms:modified>
        <dcterms:source rdf:resource="urn:iso:std:iso-iec:24778:ed-1:v1:sec:intro"/>
        <rdfs:label xml:lang="en">Aztec Code</rdfs:label>
        <skos:definition xml:lang="en">Two-dimensional matrix symbology whose symbols are nominally square, made up of square modules on a square grid, with a square bullseye pattern at their center</skos:definition>
        <skos:prefLabel xml:lang="en">Aztec Code</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://haddenindustries.com/ontology/universal/reference-data/Code128 -->

    <owl:NamedIndividual rdf:about="https://haddenindustries.com/ontology/universal/reference-data/Code128">
        <rdf:type rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/LinearBarcodeSymbology"/>
        <dc:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2017-05-05T10:06:19Z</dcterms:created>
        <dcterms:identifier rdf:resource="urn:uuid:2c809e30-5c36-434e-b776-5f7cfde379b5"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-23T08:21:03Z</dcterms:modified>
        <dcterms:source rdf:resource="urn:iso:std:iso:22742:ed-3:v1:term:3.1"/>
        <rdfs:label xml:lang="en">Code 128</rdfs:label>
        <skos:definition xml:lang="en">Continuous, variable length, bar code symbology capable of encoding all 128 (code 0-127) ISO/IEC 646[1]IRV characters, the 128 upper characters of ISO/IEC 8859-1[14] (codes 128-255), and four non-data function characters</skos:definition>
        <skos:prefLabel xml:lang="en">Code 128</skos:prefLabel>
        <skos:scopeNote xml:lang="en">See ISO/IEC 15417[3] for the Code 128 symbology specification</skos:scopeNote>
    </owl:NamedIndividual>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/Code128"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#scopeNote"/>
        <owl:annotatedTarget xml:lang="en">See ISO/IEC 15417[3] for the Code 128 symbology specification</owl:annotatedTarget>
        <schema:position rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</schema:position>
    </owl:Axiom>
    


    <!-- https://haddenindustries.com/ontology/universal/reference-data/Code39 -->

    <owl:NamedIndividual rdf:about="https://haddenindustries.com/ontology/universal/reference-data/Code39">
        <rdf:type rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/LinearBarcodeSymbology"/>
        <dc:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2017-05-05T10:11:09Z</dcterms:created>
        <dcterms:identifier rdf:resource="urn:uuid:fd9066c7-016f-4dd7-b4d3-25cb522b7e34"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-23T07:07:43Z</dcterms:modified>
        <dcterms:source rdf:resource="urn:iso:std:iso:22742:ed-2:v1:term:3.1"/>
        <rdfs:comment xml:lang="en">Each Code 39 symbol consists of a leading quiet zone, a start symbol pattern, symbol characters representing data, a stop pattern, and a trailing quiet zone. Each Code 39 character has three wide elements out of a total of nine elements. Each symbol consists of a series of symbol characters, each represented by five bars and four intervening spaces. Characters are separated by an intercharacter gap. Each element (bar or space) is one of two widths. The values of the X-dimension (3.13) and wide-to-narrow ratio remain constant throughout the symbol. The particular pattern of wide and narrow elements determines the character being encoded. The intercharacter gaps are spaces with a minimum nominal width of 1X. See ISO/IEC 16388 for the Code 39 symbology specification.</rdfs:comment>
        <rdfs:label xml:lang="en">3 of 9 Code</rdfs:label>
        <rdfs:label xml:lang="en">Code 39</rdfs:label>
        <skos:definition xml:lang="en">Discrete, variable length, bar code symbology encoding the characters 0 to 9, A to Z, and the additional characters “-” (dash), “.” (period), space, “$” (dollar sign), “/” (slash), “+” (plus sign), and “%” (percent sign), as well as a special symbology character to denote the start and stop character, conventionally represented as an “*” (asterisk)</skos:definition>
        <skos:hiddenLabel xml:lang="en">Alpha39</skos:hiddenLabel>
        <skos:hiddenLabel xml:lang="en">Code 3 of 9</skos:hiddenLabel>
        <skos:hiddenLabel xml:lang="en">Code 3/9</skos:hiddenLabel>
        <skos:hiddenLabel xml:lang="en">Type 39</skos:hiddenLabel>
        <skos:hiddenLabel xml:lang="en">USD-3</skos:hiddenLabel>
        <skos:hiddenLabel xml:lang="en">USS Code 39</skos:hiddenLabel>
        <skos:prefLabel xml:lang="en">Code 39</skos:prefLabel>
    </owl:NamedIndividual>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/Code39"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#comment"/>
        <owl:annotatedTarget xml:lang="en">Each Code 39 symbol consists of a leading quiet zone, a start symbol pattern, symbol characters representing data, a stop pattern, and a trailing quiet zone. Each Code 39 character has three wide elements out of a total of nine elements. Each symbol consists of a series of symbol characters, each represented by five bars and four intervening spaces. Characters are separated by an intercharacter gap. Each element (bar or space) is one of two widths. The values of the X-dimension (3.13) and wide-to-narrow ratio remain constant throughout the symbol. The particular pattern of wide and narrow elements determines the character being encoded. The intercharacter gaps are spaces with a minimum nominal width of 1X. See ISO/IEC 16388 for the Code 39 symbology specification.</owl:annotatedTarget>
        <rdfs:comment xml:lang="en">Note 1 to entry</rdfs:comment>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/Code39"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#label"/>
        <owl:annotatedTarget xml:lang="en">3 of 9 Code</owl:annotatedTarget>
        <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
    </owl:Axiom>
    


