        <dcterms:source rdf:resource="urn:iso:std:iso:5127:ed-2:v1:term:3.1.6.11"/>
        <rdfs:comment xml:lang="en">For the form resulting from the conversion of one writing system (3.1.6.01) into another, see http://iso.i-term.dk/frames.php</rdfs:comment>
