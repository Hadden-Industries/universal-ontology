        <rdfs:label xml:lang="en">Language Region</rdfs:label>
        <skos:definition xml:lang="en">Specific country, territory, or region with which linguistic variations are associated or appropriate to, such as regional dialects or usage, or region-specific spelling conventions</skos:definition>
