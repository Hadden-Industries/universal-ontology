        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-19T06:57:44Z</dcterms:modified>
        <rdfs:label xml:lang="en">Central Product Classification</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://unstats.un.org/unsd/classifications/Econ/cpc"/>
        <skos:definition xml:lang="en">United Nations international standard classification for all products that are an output of economic activity, encompassing both goods and services, which groups products based on the physical characteristics of the goods or on the nature of the services rendered</skos:definition>
