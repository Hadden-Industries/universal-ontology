        <skos:prefLabel xml:lang="en">Product Or Service Status</skos:prefLabel>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/ProductOrServiceStatus"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#definition"/>
        <owl:annotatedTarget xml:lang="en">Situation at a particular time during the process following the creation of a product or service</owl:annotatedTarget>
        <dcterms:source rdf:resource="https://www.lexico.com/definition/status"/>
    </owl:Axiom>
    


    <!-- https://haddenindustries.com/ontology/universal/reference-data/ProductOrServiceUsageSetting -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/universal/reference-data/ProductOrServiceUsageSetting">
        <dc:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
