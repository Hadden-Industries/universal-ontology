            </owl:Restriction>
        </rdfs:subClassOf>
        <dc:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
        <dcterms:alternative xml:lang="en">Dial Out Code</dcterms:alternative>
        <dcterms:alternative xml:lang="en">Exit Code</dcterms:alternative>
        <dcterms:alternative xml:lang="en">IDD Prefix</dcterms:alternative>
        <dcterms:alternative xml:lang="en">International Access Code</dcterms:alternative>
        <dcterms:alternative xml:lang="en">International Call Prefix</dcterms:alternative>
        <dcterms:alternative xml:lang="en">International Direct Dialing Prefix</dcterms:alternative>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2020-04-06T09:39:10Z</dcterms:created>
        <dcterms:identifier rdf:resource="urn:uuid:687c0395-6653-4a34-b46c-f0b356e4dff4"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-23T07:30:22Z</dcterms:modified>
        <dcterms:source rdf:resource="https://www.itu.int/rec/dologin_pub.asp?lang=e&amp;id=T-REC-E.101-200911-I!!PDF-E&amp;type=items"/>
        <rdfs:label xml:lang="en">International Prefix</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://www.itu.int/rec/T-REC-E.101-200911-I/en"/>
        <skos:definition xml:lang="en">Digit or combination of digits used to indicate that the number following is an international E.164-number</skos:definition>
        <skos:prefLabel xml:lang="en">International Prefix</skos:prefLabel>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/InternationalPrefix"/>
        <owl:annotatedProperty rdf:resource="http://purl.org/dc/terms/source"/>
        <owl:annotatedTarget rdf:resource="https://www.itu.int/rec/dologin_pub.asp?lang=e&amp;id=T-REC-E.101-200911-I!!PDF-E&amp;type=items"/>
        <skos:note xml:lang="en">Section 5.3</skos:note>
    </owl:Axiom>
    


    <!-- https://haddenindustries.com/ontology/universal/reference-data/InternationalSystemOfUnitsPrefix -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/universal/reference-data/InternationalSystemOfUnitsPrefix">
        <dc:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
        <dcterms:alternative xml:lang="en">SI Prefix</dcterms:alternative>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2022-04-17T12:45:08Z</dcterms:created>
        <dcterms:identifier rdf:resource="urn:uuid:916c8b72-df78-479a-b2b7-bc4832523876"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-05-04T15:11:14Z</dcterms:modified>
        <dcterms:source rdf:resource="urn:isbn:978-92-822-2272-0"/>
        <rdfs:label xml:lang="en">International System Of Units Prefix</rdfs:label>
        <skos:definition xml:lang="en">Symbol specified by the Bureau International des Poids et Mesures (BIPM) for use in the International System of Units (SI), where designations of decimal multiples and subdivision of any unit may be arrived at by combining the symbol with the name of the unit</skos:definition>
        <skos:prefLabel xml:lang="en">International System Of Units Prefix</skos:prefLabel>
    </owl:Class>
    


    <!-- https://haddenindustries.com/ontology/universal/reference-data/InvestmentRiskAttitude -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/universal/reference-data/InvestmentRiskAttitude">
        <dc:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2022-11-28T10:38:50Z</dcterms:created>
        <dcterms:identifier rdf:resource="urn:uuid:a87391b0-a2d9-449b-a4fa-07e416bb94e3"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-05-11T20:33:45Z</dcterms:modified>
        <rdfs:label xml:lang="en">Investment Risk Attitude</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://www.finra.org/investors/investing/investing-basics/risk"/>
        <skos:definition xml:lang="en">Way one thinks and feels about any uncertainty with respect to one&apos;s investments that has the potential to negatively impact one&apos;s financial welfare</skos:definition>
        <skos:prefLabel xml:lang="en">Investment Risk Attitude</skos:prefLabel>
    </owl:Class>
