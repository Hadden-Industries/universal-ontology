    </owl:Axiom>
    


    <!-- https://haddenindustries.com/ontology/universal/reference-data/HarmonizedSystemCode -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/universal/reference-data/HarmonizedSystemCode">
