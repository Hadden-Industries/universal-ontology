    <!-- https://haddenindustries.com/ontology/universal/reference-data/CoordinateReferenceSystem -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/universal/reference-data/CoordinateReferenceSystem">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/hasCoordinateSystem"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/CoordinateSystem"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/hasDatum"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/Datum"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dc:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2017-05-10T17:33:56Z</dcterms:created>
        <dcterms:identifier rdf:resource="urn:uuid:caa7d84d-236d-4c10-a46f-893b6189b814"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-23T07:03:54Z</dcterms:modified>
        <dcterms:source rdf:resource="urn:iso:std:iso:19111:ed-3:v1:term:3.1.9"/>
        <rdfs:comment xml:lang="en">For geodetic and vertical reference frames, the object will be the Earth. In planetary applications, geodetic and vertical reference frames may be applied to other celestial bodies.</rdfs:comment>
        <rdfs:comment xml:lang="en">Geodetic and vertical datums are referred to as reference frames</rdfs:comment>
        <rdfs:label xml:lang="en">Coordinate Reference System</rdfs:label>
        <skos:definition xml:lang="en">Coordinate System that is related to an object by a Datum</skos:definition>
        <skos:hiddenLabel xml:lang="en">CRS</skos:hiddenLabel>
        <skos:hiddenLabel xml:lang="en">SRS</skos:hiddenLabel>
        <skos:hiddenLabel xml:lang="en">Spatial Reference System</skos:hiddenLabel>
        <skos:prefLabel xml:lang="en">Coordinate Reference System</skos:prefLabel>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/CoordinateReferenceSystem"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#comment"/>
        <owl:annotatedTarget xml:lang="en">For geodetic and vertical reference frames, the object will be the Earth. In planetary applications, geodetic and vertical reference frames may be applied to other celestial bodies.</owl:annotatedTarget>
        <rdfs:comment xml:lang="en">Note 2 to entry</rdfs:comment>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/CoordinateReferenceSystem"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#comment"/>
        <owl:annotatedTarget xml:lang="en">Geodetic and vertical datums are referred to as reference frames</owl:annotatedTarget>
        <rdfs:comment xml:lang="en">Note 1 to entry</rdfs:comment>
    </owl:Axiom>
    


