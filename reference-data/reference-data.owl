        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-05-04T16:04:29Z</dcterms:modified>
        <rdfs:label xml:lang="en">Standard International Trade Classification</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://unstats.un.org/unsd/trade/sitcrev4.htm"/>
        <skos:definition xml:lang="en">United Nations statistical classification that groups merchandise for the analytical comparison of international trade statistics, based on criteria such as the material of production, processing stage, and market use</skos:definition>
        <skos:prefLabel xml:lang="en">Standard International Trade Classification</skos:prefLabel>
    </owl:Class>
