                <owl:onProperty rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/InterimLegalDisposition_hasOffenceRemandStatus"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">0</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/OffenceRemandStatus"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/InterimLegalDisposition_hasOffenceRemandStatus"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/OffenceRemandStatus"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dc:creator rdf:resource="https://orcid.org/0000-0001-8017-8797"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-04-22T14:42:35Z</dcterms:created>
        <dcterms:identifier rdf:resource="urn:uuid:e633e962-e7a9-42ef-94a8-1c64b1eeb04a"/>
        <rdfs:label xml:lang="en">Interim Legal Disposition</rdfs:label>
        <skos:definition xml:lang="en">Legal Disposition that imposes temporary statutory conditions, restrictions, or rights upon an entity pending the final resolution of the matter</skos:definition>
        <skos:prefLabel xml:lang="en">Interim Legal Disposition</skos:prefLabel>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/InterimLegalDisposition"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#definition"/>
        <owl:annotatedTarget xml:lang="en">Legal Disposition that imposes temporary statutory conditions, restrictions, or rights upon an entity pending the final resolution of the matter</owl:annotatedTarget>
