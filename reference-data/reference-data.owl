        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#definition"/>
        <owl:annotatedTarget xml:lang="en">Way one thinks and feels about any uncertainty with respect to one&apos;s investments that has the potential to negatively impact one&apos;s financial welfare</owl:annotatedTarget>
        <dcterms:source rdf:resource="https://www.britannica.com/dictionary/attitude"/>
    </owl:Axiom>
    


