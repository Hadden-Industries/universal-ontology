        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2020-04-02T14:25:19Z</dcterms:created>
        <dcterms:identifier rdf:resource="urn:uuid:de53d3c2-bc06-436a-b0dd-604dbf4dd485"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-05-04T20:29:00Z</dcterms:modified>
        <rdfs:label xml:lang="en">Martin–Schultz Scale</rdfs:label>
        <skos:definition xml:lang="en">Descriptive information for an arrangement or division of perceived hues of the iris into groups based on criteria such as characteristics, which the objects have in common, created by the anthropologists Rudolf Martin and Bruno K Schultz in the first half of the 20th century</skos:definition>
        <skos:prefLabel xml:lang="en">Martin–Schultz Scale</skos:prefLabel>
    </owl:NamedIndividual>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/MartinSchultzScale"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#definition"/>
        <owl:annotatedTarget xml:lang="en">Descriptive information for an arrangement or division of perceived hues of the iris into groups based on criteria such as characteristics, which the objects have in common, created by the anthropologists Rudolf Martin and Bruno K Schultz in the first half of the 20th century</owl:annotatedTarget>
        <dcterms:source rdf:resource="https://gemini.google.com/app/52fadd764940bfc0"/>
        <dcterms:source rdf:resource="urn:iso:std:iso-iec:11179:-3:ed-4:v1:term:3.2.5"/>
    </owl:Axiom>
    


