        <skos:prefLabel xml:lang="en">Product Or Service Relationship Type</skos:prefLabel>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/ProductOrServiceRelationshipType"/>
