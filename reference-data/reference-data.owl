    <!-- https://haddenindustries.com/ontology/universal/reference-data/UniversalProductCodeA -->

    <owl:NamedIndividual rdf:about="https://haddenindustries.com/ontology/universal/reference-data/UniversalProductCodeA">
        <rdf:type rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/EuropeanArticleNumberUniversalProductCode"/>
        <dc:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-08-28T22:17:23Z</dcterms:created>
        <dcterms:identifier rdf:resource="urn:uuid:cb3f013c-e9a5-4b96-9dab-51aae9e53f0c"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-23T07:22:57Z</dcterms:modified>
        <dcterms:source rdf:resource="urn:iso:std:iso:22742:ed-2:v1:term:3.43"/>
        <rdfs:comment xml:lang="en">For international compatibility with EAN-13, a 13th digit can be represented as a derived 0 in the left-most position. See ISO/IEC 15420 for the EAN/UPC symbology specification.</rdfs:comment>
        <rdfs:label xml:lang="en">UPC-A</rdfs:label>
        <rdfs:label xml:lang="en">Universal Product Code-A</rdfs:label>
        <skos:altLabel xml:lang="en">Universal Product Code</skos:altLabel>
        <skos:definition xml:lang="en">Fixed-length, numeric 12-digit bar code symbol adopted by the retail industries, composed of a company prefix assigned by GS1, a product code assigned by the manufacturer, and a modulo 10 check digit as the right-most digit</skos:definition>
        <skos:prefLabel xml:lang="en">Universal Product Code-A</skos:prefLabel>
    </owl:NamedIndividual>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/UniversalProductCodeA"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#comment"/>
        <owl:annotatedTarget xml:lang="en">For international compatibility with EAN-13, a 13th digit can be represented as a derived 0 in the left-most position. See ISO/IEC 15420 for the EAN/UPC symbology specification.</owl:annotatedTarget>
        <rdfs:comment xml:lang="en">Note 1 to entry</rdfs:comment>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/UniversalProductCodeA"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#label"/>
        <owl:annotatedTarget xml:lang="en">UPC-A</owl:annotatedTarget>
        <skos:note xml:lang="en">This is the preferred label in ISO 22742:2010</skos:note>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/UniversalProductCodeA"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#label"/>
        <owl:annotatedTarget xml:lang="en">Universal Product Code-A</owl:annotatedTarget>
        <skos:note xml:lang="en">Not specified in ISO 22742:2010</skos:note>
    </owl:Axiom>
    


