    <owl:Class rdf:about="https://haddenindustries.com/ontology/universal/reference-data/KindOfNominalProperty">
        <dc:creator rdf:resource="https://orcid.org/0000-0001-8017-8797"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-09-22T13:59:32Z</dcterms:created>
        <dcterms:identifier rdf:resource="urn:uuid:17b68c30-d0ca-43fc-9b46-3f432be2a6c4"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-05-04T15:23:21Z</dcterms:modified>
        <dcterms:source rdf:resource="urn:doi:10.1515/pac-2011-0613"/>
        <rdfs:label xml:lang="en">Kind Of Nominal Property</rdfs:label>
        <skos:definition xml:lang="en">Defining aspect, common to mutually comparable nominal properties</skos:definition>
        <skos:example xml:lang="en">Colour at a specified lighting</skos:example>
        <skos:example xml:lang="en">Sequence variation</skos:example>
        <skos:example xml:lang="en">Shape</skos:example>
        <skos:example xml:lang="en">Taxon (2.4)</skos:example>
        <skos:note xml:lang="en">‘Kind-of-nominal-property’ is sometimes termed “attribute”, but not here</skos:note>
        <skos:prefLabel xml:lang="en">Kind Of Nominal Property</skos:prefLabel>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/KindOfNominalProperty"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#definition"/>
        <owl:annotatedTarget xml:lang="en">Defining aspect, common to mutually comparable nominal properties</owl:annotatedTarget>
        <dcterms:source rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/KindOfQuantity"/>
        <skos:note xml:lang="en">The definition of this concept is analogous to that of ‘kind of quantity’ in VIM 1.2</skos:note>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/KindOfNominalProperty"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#example"/>
        <owl:annotatedTarget xml:lang="en">Colour at a specified lighting</owl:annotatedTarget>
        <schema:position rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</schema:position>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/KindOfNominalProperty"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#example"/>
        <owl:annotatedTarget xml:lang="en">Sequence variation</owl:annotatedTarget>
        <schema:position rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</schema:position>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/KindOfNominalProperty"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#example"/>
        <owl:annotatedTarget xml:lang="en">Shape</owl:annotatedTarget>
        <schema:position rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</schema:position>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/KindOfNominalProperty"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#example"/>
        <owl:annotatedTarget xml:lang="en">Taxon (2.4)</owl:annotatedTarget>
        <schema:position rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</schema:position>
    </owl:Axiom>
    


    <!-- https://haddenindustries.com/ontology/universal/reference-data/KindOfQuantity -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/universal/reference-data/KindOfQuantity">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/KindOfQuantity_hasQuantity"/>
                <owl:someValuesFrom rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/Quantity"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dc:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2017-05-04T13:35:21Z</dcterms:created>
        <dcterms:identifier rdf:resource="urn:uuid:15e770c8-d8b7-44de-adcb-dd4df154e03b"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-23T07:49:03Z</dcterms:modified>
        <dcterms:source rdf:resource="https://jcgm.bipm.org/vim/en/1.2.html"/>
        <rdfs:label xml:lang="en">Kind Of Quantity</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://unece.org/trade/uncefact/cl-recommendations"/>
        <skos:altLabel xml:lang="en">Kind</skos:altLabel>
        <skos:definition xml:lang="en">Aspect common to mutually comparable quantities</skos:definition>
        <skos:note xml:lang="en">The term &quot;kind&quot; is mainly used in expressions such as &quot;quantities of the same kind.&quot; Two quantities of the same kind are mutually comparable, so that they can be placed in order of magnitude. Length and mass are quantities of different kinds because they are not mutually comparable.</skos:note>
        <skos:prefLabel xml:lang="en">Kind Of Quantity</skos:prefLabel>
        <skos:scopeNote xml:lang="en">In English, the terms for quantities in the left half of the table in 1.1, Note 1, are often used for the corresponding ‘kinds of quantity’. In French, the term “nature” is only used in expressions such as “grandeurs de même nature” (in English, “quantities of the same kind”).</skos:scopeNote>
        <skos:scopeNote xml:lang="en">Quantities of the same kind within a given system of quantities have the same quantity dimension. However, quantities of the same dimension are not necessarily of the same kind.</skos:scopeNote>
        <skos:scopeNote xml:lang="en">The division of ‘quantity’ according to ‘kind of quantity’ is to some extent arbitrary</skos:scopeNote>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/KindOfQuantity"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#note"/>
        <owl:annotatedTarget xml:lang="en">The term &quot;kind&quot; is mainly used in expressions such as &quot;quantities of the same kind.&quot; Two quantities of the same kind are mutually comparable, so that they can be placed in order of magnitude. Length and mass are quantities of different kinds because they are not mutually comparable.</owl:annotatedTarget>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2013-12-03</dcterms:modified>
        <skos:note xml:lang="en">informative</skos:note>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/KindOfQuantity"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#scopeNote"/>
        <owl:annotatedTarget xml:lang="en">In English, the terms for quantities in the left half of the table in 1.1, Note 1, are often used for the corresponding ‘kinds of quantity’. In French, the term “nature” is only used in expressions such as “grandeurs de même nature” (in English, “quantities of the same kind”).</owl:annotatedTarget>
        <schema:position rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</schema:position>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/KindOfQuantity"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#scopeNote"/>
        <owl:annotatedTarget xml:lang="en">Quantities of the same kind within a given system of quantities have the same quantity dimension. However, quantities of the same dimension are not necessarily of the same kind.</owl:annotatedTarget>
        <schema:position rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</schema:position>
        <skos:example xml:lang="en">The quantities moment of force and energy are, by convention, not regarded as being of the same kind, although they have the same dimension. Similarly for heat capacity and entropy, as well as for number of entities, relative permeability, and mass fraction.</skos:example>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/KindOfQuantity"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#scopeNote"/>
        <owl:annotatedTarget xml:lang="en">The division of ‘quantity’ according to ‘kind of quantity’ is to some extent arbitrary</owl:annotatedTarget>
        <schema:position rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</schema:position>
        <skos:example xml:lang="en">The quantities diameter, circumference, and wavelength are generally considered to be quantities of the same kind, namely of the kind of quantity called length</skos:example>
        <skos:example xml:lang="en">The quantities heat, kinetic energy, and potential energy are generally considered to be quantities of the same kind, namely of the kind of quantity called energy</skos:example>
    </owl:Axiom>
    


