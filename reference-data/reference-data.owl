        <rdfs:label xml:lang="en">Language Identification</rdfs:label>
        <skos:definition xml:lang="en">Composite datatype that serves as an identifier for a language, where the language is always defined as spoken (or written, signed or otherwise signaled) by human beings for communication of information to other human beings; computer languages such as programming languages are explicitly excluded</skos:definition>
        <skos:prefLabel xml:lang="en">Language Identification</skos:prefLabel>
    </owl:Class>
    


