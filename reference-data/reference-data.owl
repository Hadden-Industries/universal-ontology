        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/Synonymy"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#comment"/>
        <owl:annotatedTarget xml:lang="en">Designations in the relation of synonymy are called “synonyms”</owl:annotatedTarget>
        <rdfs:comment xml:lang="en">Note 1 to entry</rdfs:comment>
    </owl:Axiom>
    


