<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Export tool for generating a OMG UML XMI 2.1 representation of the Hadden Industries ontology.">
    <title>Ontology UML XMI Exporter</title>
    <!-- Link to our shared premium stylesheet -->
    <link rel="stylesheet" href="ontology_styles.css">
</head>
<body>

    <main class="exporter-wrapper">
        <div class="card">
            <h1 id="main-title" class="title">Ontology Exporter</h1>
            
            <div id="step-init" class="step">
                <div class="icon-container">
                    <div class="circle-placeholder"></div>
                    <svg class="spinner" viewBox="0 0 50 50"><circle class="path" cx="25" cy="25" r="20" fill="none" stroke-width="5"></circle></svg>
                    <svg class="check-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
                </div>
                <span>Initialising export sequence</span>
            </div>

            <div id="step-fetch" class="step">
                <div class="icon-container">
                    <div class="circle-placeholder"></div>
                    <svg class="spinner" viewBox="0 0 50 50"><circle class="path" cx="25" cy="25" r="20" fill="none" stroke-width="5"></circle></svg>
                    <svg class="check-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
                </div>
                <span>Fetching ontology and XSLT assets</span>
            </div>

            <div id="step-xmi" class="step">
                <div class="icon-container">
                    <div class="circle-placeholder"></div>
                    <svg class="spinner" viewBox="0 0 50 50"><circle class="path" cx="25" cy="25" r="20" fill="none" stroke-width="5"></circle></svg>
                    <svg class="check-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
                </div>
                <span>Generating UML XMI 2.1 payload</span>
            </div>

            <div id="step-download" class="step">
                <div class="icon-container">
                    <div class="circle-placeholder"></div>
                    <svg class="spinner" viewBox="0 0 50 50"><circle class="path" cx="25" cy="25" r="20" fill="none" stroke-width="5"></circle></svg>
                    <svg class="check-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
                </div>
                <span>Downloading .xmi file</span>
            </div>

            <div id="status-message-box" class="message-box"></div>
        </div>
    </main>

    <!-- Import the shared logic library -->
    <script src="ontology_processor.js"></script>
    <script>
        function setStepState(stepId, state) {
            document.getElementById(stepId).className = 'step ' + state;
        }

        function displayFinalMessage(text, type) {
            const msgBox = document.getElementById('status-message-box');
            msgBox.innerText = text;
            msgBox.className = `message-box ${type} show`;
        }

        async function orchestrateAutoDownload() {
            try {
                // Step 1: Initialising
                setStepState('step-init', 'active');
                await new Promise(r => setTimeout(r, 400)); // Brief UX delay 
                setStepState('step-init', 'complete');

                // Step 2: Fetch OWL Ontology and XSLT Stylesheet
                setStepState('step-fetch', 'active');
                
                const isLocalEnv = window.location.hostname === "localhost" || window.location.hostname === "127.0.0.1" || window.location.protocol === "file:";
                let targetUrl;
                let xsltUrl;

                if (isLocalEnv) {
                    targetUrl = "https://haddenindustries.com/ontology/universal/reference-data/latest";
                    xsltUrl = "owl_to_uml_xmi.xsl";
                } else {
                    const pathname = window.location.pathname;
                    const basePath = pathname.substring(0, pathname.lastIndexOf('/'));
                    targetUrl = window.location.origin + basePath;
                    xsltUrl = window.location.origin + basePath + "/owl_to_uml_xmi.xsl";
                }
                
                // Fetch the XML document
                const xmlDoc = await fetchOntologyAsXml(targetUrl);

                // Fetch XSLT stylesheet (with fallback to CDN)
                let xsltText;
                try {
                    const xsltResponse = await fetch(xsltUrl);
                    if (!xsltResponse.ok) throw new Error("Local XSLT fetch failed");
                    xsltText = await xsltResponse.text();
                } catch (xsltErr) {
                    console.warn("Could not fetch local XSLT, falling back to production CDN:", xsltErr);
                    const prodXsltUrl = "https://haddenindustries.com/ontology/owl_to_uml_xmi.xsl";
                    const xsltResponse = await fetch(prodXsltUrl);
                    if (!xsltResponse.ok) throw new Error("CDN XSLT fetch failed");
                    xsltText = await xsltResponse.text();
                }

                // Parse the ontology title to update the UI
                let baseTitle = "Ontology";
                const ontologyNode = xmlDoc.getElementsByTagNameNS("http://www.w3.org/2002/07/owl#", "Ontology")[0];
                if (ontologyNode) {
                    const titleNodes = Array.from(ontologyNode.children).filter(c => c.localName === "title" && c.namespaceURI === "http://purl.org/dc/terms/");
                    if (titleNodes.length > 0) {
                        const titleNode = titleNodes.find(t => t.getAttribute("xml:lang") === "en" || t.getAttributeNS("http://www.w3.org/XML/1998/namespace", "lang") === "en") || titleNodes[0];
                        baseTitle = titleNode.textContent.trim();
                    }
                }
                
                const suffix = baseTitle.endsWith("Ontology") ? " Data Exporter (.xmi)" : " Ontology Data Exporter (.xmi)";
                const exportTitle = baseTitle + suffix;
                
                document.title = exportTitle;
                document.getElementById('main-title').innerText = exportTitle;

                setStepState('step-fetch', 'complete');

                // Step 3: Package XMI (Apply XSLT)
                setStepState('step-xmi', 'active');
                await new Promise(r => setTimeout(r, 600)); // Brief UX delay
                setStepState('step-xmi', 'complete');

                // Step 4: Download
                setStepState('step-download', 'active');
                await new Promise(r => setTimeout(r, 400));
                
                let filename = "Ontology Vocabulary.xmi";
                if (baseTitle !== "Ontology") {
                    filename = `${baseTitle} Vocabulary`;
                    const modifiedNode = ontologyNode ? ontologyNode.getElementsByTagNameNS("http://purl.org/dc/terms/", "modified")[0] : null;
                    if (modifiedNode) {
                        filename += ` [${modifiedNode.textContent.trim()}]`;
                    }
                    filename += ".xmi";
                }
                
                exportXMI(xmlDoc, xsltText, filename);
                
                setStepState('step-download', 'complete');
                displayFinalMessage('Download complete. You may close this window.', 'success');

            } catch (error) {
                console.error("Auto-download sequence failed:", error);
                
                // Halt UI progress and show error state
                const activeStep = document.querySelector('.step.active');
                if (activeStep) activeStep.classList.remove('active');
                
                displayFinalMessage('An error occurred during the XMI extraction process.', 'error');
            }
        }

        // Start sequence automatically on load
        window.addEventListener('load', orchestrateAutoDownload);
    </script>
</body>
</html>
