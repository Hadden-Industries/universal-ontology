    <dct:creator rdf:resource="http://orcid.org/0000-0002-3884-3420"/>
    <rdfs:comment xml:lang="en">The set of months-of-the-year from the Gregorian calendar.</rdfs:comment>
    <rdfs:label xml:lang="en">The gregorian months</rdfs:label>
    <owl:imports rdf:resource="http://www.w3.org/2006/time"/>
  </owl:Ontology>
