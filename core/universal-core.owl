    <!-- https://haddenindustries.com/ontology/universal/core/Organisation -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/universal/core/Organisation">
        <rdfs:subClassOf rdf:resource="https://haddenindustries.com/ontology/iso-iec/11179/-3/ed-4/term/Organization"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2016-11-28T16:35:44Z</dcterms:created>
        <dcterms:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
        <dcterms:identifier rdf:resource="urn:uuid:06155ec9-e8a3-4323-af0d-d6f32687bb20"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-25T14:20:14Z</dcterms:modified>
        <dcterms:source rdf:resource="urn:iso:std:iso:9000:ed-4:v1:term:3.2.1"/>
        <rdfs:label xml:lang="en-gb">Organisation</rdfs:label>
        <rdfs:label xml:lang="en-us">Organization</rdfs:label>
        <skos:definition xml:lang="en">Person or group of people that has its own functions with responsibilities, authorities and relationships to achieve its objectives</skos:definition>
        <skos:prefLabel xml:lang="en-gb">Organisation</skos:prefLabel>
        <skos:prefLabel xml:lang="en-us">Organization</skos:prefLabel>
        <skos:scopeNote xml:lang="en-gb">The concept of organisation includes, but is not limited to, sole-trader, company, corporation, firm, enterprise, authority, partnership, association, charity or institution, or part or combination thereof, public or private, and excludes entities recognised by law as having legal rights and duties, able to make commitment(s), assume and fulfil resulting obligation(s), and able to be held accountable for its action(s)</skos:scopeNote>
        <skos:scopeNote xml:lang="en">This constitutes one of the common terms and core definitions for ISO management system standards given in Annex SL of the Consolidated ISO Supplement to the ISO/IEC Directives, Part 1. The original definition has been modified by modifying Note 1 to entry.</skos:scopeNote>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/core/Organisation"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#scopeNote"/>
        <owl:annotatedTarget xml:lang="en-gb">The concept of organisation includes, but is not limited to, sole-trader, company, corporation, firm, enterprise, authority, partnership, association, charity or institution, or part or combination thereof, public or private, and excludes entities recognised by law as having legal rights and duties, able to make commitment(s), assume and fulfil resulting obligation(s), and able to be held accountable for its action(s)</owl:annotatedTarget>
        <schema:position rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</schema:position>
        <skos:note xml:lang="en">Modified — &quot;, whether incorporated or not&quot; removed, &quot;, and excludes entities recognised by law as having legal rights and duties, able to make commitment(s), assume and fulfil resulting obligation(s), and able to be held accountable for its action(s)&quot; appended</skos:note>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/core/Organisation"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#scopeNote"/>
        <owl:annotatedTarget xml:lang="en">This constitutes one of the common terms and core definitions for ISO management system standards given in Annex SL of the Consolidated ISO Supplement to the ISO/IEC Directives, Part 1. The original definition has been modified by modifying Note 1 to entry.</owl:annotatedTarget>
        <schema:position rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</schema:position>
    </owl:Axiom>
    


