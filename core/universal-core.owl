        <dcterms:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
        <dcterms:identifier rdf:resource="urn:uuid:83c1f822-741e-44af-b011-799e4090e139"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-25T13:11:00Z</dcterms:modified>
        <rdfs:label xml:lang="en-gb">Address To Organisation Relationship</rdfs:label>
        <skos:definition xml:lang="en-gb">Association between an Address and an Organisation</skos:definition>
        <skos:prefLabel xml:lang="en-gb">Address To Organisation Relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- https://haddenindustries.com/ontology/universal/core/AddressToPersonRelationship -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/universal/core/AddressToPersonRelationship">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://haddenindustries.com/ontology/universal/core/AddressToPersonRelationship_hasAddress"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://haddenindustries.com/ontology/universal/core/Address"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://haddenindustries.com/ontology/universal/core/AddressToPersonRelationship_hasPerson"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://haddenindustries.com/ontology/universal/core/Person"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://haddenindustries.com/ontology/universal/core/hasAddressToPersonRelationshipType"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/AddressToPersonRelationshipType"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2020-04-22T15:29:39Z</dcterms:created>
        <dcterms:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
        <dcterms:identifier rdf:resource="urn:uuid:7d74e9b5-bb68-47ee-b8d1-aeda2369da67"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-25T13:11:00Z</dcterms:modified>
        <rdfs:label xml:lang="en">Address To Person Relationship</rdfs:label>
        <skos:definition xml:lang="en">Association between a Person and an Address</skos:definition>
        <skos:prefLabel xml:lang="en">Address To Person Relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- https://haddenindustries.com/ontology/universal/core/Agreement -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/universal/core/Agreement">
        <rdfs:subClassOf rdf:resource="https://haddenindustries.com/ontology/universal/core/Event"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://haddenindustries.com/ontology/universal/core/Agreement_confers"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">0</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="https://haddenindustries.com/ontology/universal/core/Commitment"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://haddenindustries.com/ontology/universal/core/Agreement_hasContractualElement"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">0</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="https://haddenindustries.com/ontology/universal/core/ContractualElement"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-05-09T20:46:48Z</dcterms:created>
        <dcterms:creator rdf:resource="https://orcid.org/0000-0001-8017-8797"/>
        <dcterms:identifier rdf:resource="urn:uuid:a005da90-2da3-4ac7-9872-26d8c710c98a"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-25T14:12:04Z</dcterms:modified>
        <dcterms:source rdf:resource="https://spec.edmcouncil.org/fibo/ontology/FND/Agreements/Agreements/Agreement"/>
        <rdfs:label xml:lang="en">Agreement</rdfs:label>
        <skos:definition xml:lang="en">Negotiated understanding between two or more parties, reflecting the offer and acceptance of commitments on the part of either party</skos:definition>
        <skos:prefLabel xml:lang="en">Agreement</skos:prefLabel>
        <skos:scopeNote xml:lang="en">All agreements are time bound, whether implicit or explicitly stated, and thus an agreement reflects a state of affairs that holds for some period of time</skos:scopeNote>
    </owl:Class>
    


    <!-- https://haddenindustries.com/ontology/universal/core/Brand -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/universal/core/Brand">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://haddenindustries.com/ontology/universal/core/Brand_hasPerson"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://haddenindustries.com/ontology/universal/core/Person"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2016-10-20T14:41:07Z</dcterms:created>
        <dcterms:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
        <dcterms:identifier rdf:resource="urn:uuid:5e730ef6-42fd-4a65-b939-3c061c7c5d36"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-24T18:25:00Z</dcterms:modified>
        <dcterms:source rdf:resource="urn:iso:std:iso:20671:-1:ed-1:v1:term:3.1"/>
        <rdfs:label xml:lang="en">Brand</rdfs:label>
        <skos:definition xml:lang="en">Intangible asset, including but not limited to, names, terms, signs, symbols, logos and designs, or a combination of these, intended to identify goods, services or entities, or a combination of these, creating distinctive images and associations in the minds of stakeholders, thereby generating economic benefit/values</skos:definition>
        <skos:prefLabel xml:lang="en">Brand</skos:prefLabel>
    </owl:Class>
    


    <!-- https://haddenindustries.com/ontology/universal/core/Building -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/universal/core/Building">
        <rdfs:subClassOf rdf:resource="https://haddenindustries.com/ontology/universal/core/Structure"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2017-04-13T09:47:15Z</dcterms:created>
        <dcterms:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
        <dcterms:identifier rdf:resource="urn:uuid:4f274149-80a2-4d5b-9749-79b591fa2cfd"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-24T18:25:00Z</dcterms:modified>
        <rdfs:label xml:lang="en">Building</rdfs:label>
        <skos:definition xml:lang="en">Structure with a roof and walls, such as a house or factory</skos:definition>
        <skos:prefLabel xml:lang="en">Building</skos:prefLabel>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/core/Building"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#definition"/>
        <owl:annotatedTarget xml:lang="en">Structure with a roof and walls, such as a house or factory</owl:annotatedTarget>
        <dcterms:source rdf:resource="https://www.oed.com/dictionary/building_n"/>
    </owl:Axiom>
    


    <!-- https://haddenindustries.com/ontology/universal/core/Claim -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/universal/core/Claim">
        <rdfs:subClassOf rdf:resource="https://haddenindustries.com/ontology/universal/core/Event"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://haddenindustries.com/ontology/universal/core/Claim_hasProductOrService"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">0</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="https://haddenindustries.com/ontology/universal/core/ProductOrService"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://haddenindustries.com/ontology/universal/core/hasComplaint"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">0</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="https://haddenindustries.com/ontology/universal/core/Complaint"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2017-01-16T13:31:24Z</dcterms:created>
        <dcterms:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
        <dcterms:identifier rdf:resource="urn:uuid:b405a4a7-646a-462f-9293-3223c658dff1"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-25T14:12:11Z</dcterms:modified>
        <dcterms:source rdf:resource="https://spec.edmcouncil.org/fibo/ontology/FND/Law/LegalCapacity/Claim"/>
        <rdfs:label xml:lang="en">Claim</rdfs:label>
        <skos:definition xml:lang="en">Demand or assertion made by one party on another, based on facts that, taken together, give rise to a legally enforceable right or judicial action</skos:definition>
        <skos:prefLabel xml:lang="en">Claim</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Claims arise from the existence of a formal commitment between the parties or as implicitly agreed upon through the operation of law or constitution</skos:scopeNote>
    </owl:Class>
    


    <!-- https://haddenindustries.com/ontology/universal/core/Commitment -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/universal/core/Commitment">
        <rdfs:subClassOf rdf:resource="https://haddenindustries.com/ontology/universal/core/Event"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-05-11T08:42:00Z</dcterms:created>
        <dcterms:creator rdf:resource="https://orcid.org/0000-0001-8017-8797"/>
        <dcterms:identifier rdf:resource="urn:uuid:45bc471b-16e1-4058-b226-db53740cdd6c"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-25T14:12:15Z</dcterms:modified>
        <dcterms:source rdf:resource="https://spec.edmcouncil.org/fibo/ontology/FND/Agreements/Agreements/Commitment"/>
        <rdfs:label xml:lang="en">Commitment</rdfs:label>
        <skos:definition xml:lang="en">Promise made by some party to act or refrain from acting in some manner</skos:definition>
        <skos:prefLabel xml:lang="en">Commitment</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Such a promise often results a corresponding right or obligation with respect to another party to the commitment. Thus, obligations and rights are considered as reciprocal aspects of a commitment.</skos:scopeNote>
    </owl:Class>
    


    <!-- https://haddenindustries.com/ontology/universal/core/Complaint -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/universal/core/Complaint">
        <rdfs:subClassOf rdf:resource="https://haddenindustries.com/ontology/universal/core/Event"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://haddenindustries.com/ontology/universal/core/Complaint_hasProductOrService"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">0</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="https://haddenindustries.com/ontology/universal/core/ProductOrService"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2016-12-19T12:55:25Z</dcterms:created>
        <dcterms:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
        <dcterms:identifier rdf:resource="urn:uuid:42fd815e-cd83-4d46-a489-9d9c72ec2eb1"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-25T13:58:00Z</dcterms:modified>
        <dcterms:source rdf:resource="urn:iso:std:iso:10002:ed-3:v1:term:3.2"/>
        <dcterms:source xml:lang="en">ISO 9000:2015, 3.9.3</dcterms:source>
        <rdfs:label xml:lang="en">Complaint</rdfs:label>
        <skos:definition xml:lang="en-gb">Expression of dissatisfaction made to an organisation, related to its product or service, or the complaints-handling process itself, where a response or resolution is explicitly or implicitly expected</skos:definition>
        <skos:prefLabel xml:lang="en">Complaint</skos:prefLabel>
        <skos:scopeNote xml:lang="en-gb">Complaints can be made directly or indirectly to the organisation</skos:scopeNote>
        <skos:scopeNote xml:lang="en-gb">Complaints can be made in relation to other processes where the organisation interacts with the customer</skos:scopeNote>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/core/Complaint"/>
        <owl:annotatedProperty rdf:resource="http://purl.org/dc/terms/source"/>
        <owl:annotatedTarget xml:lang="en">ISO 9000:2015, 3.9.3</owl:annotatedTarget>
        <skos:note xml:lang="en">modified — Notes 1 and 2 to entry have been added</skos:note>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/core/Complaint"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#scopeNote"/>
        <owl:annotatedTarget xml:lang="en-gb">Complaints can be made directly or indirectly to the organisation</owl:annotatedTarget>
        <schema:position rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</schema:position>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/core/Complaint"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#scopeNote"/>
        <owl:annotatedTarget xml:lang="en-gb">Complaints can be made in relation to other processes where the organisation interacts with the customer</owl:annotatedTarget>
        <schema:position rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</schema:position>
    </owl:Axiom>
    


    <!-- https://haddenindustries.com/ontology/universal/core/Contract -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/universal/core/Contract">
        <rdfs:subClassOf rdf:resource="https://haddenindustries.com/ontology/universal/core/Agreement"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://haddenindustries.com/ontology/universal/core/hasContractType"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/ContractType"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2016-09-30T12:00:00Z</dcterms:created>
        <dcterms:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
        <dcterms:identifier rdf:resource="urn:uuid:41cdbdc3-de73-48ca-810d-82e776da8af2"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-24T18:25:00Z</dcterms:modified>
        <dcterms:source rdf:resource="urn:iso:std:iso:10845:-1:ed-1:v1:term:3.9"/>
        <rdfs:label xml:lang="en">Contract</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://spec.edmcouncil.org/fibo/ontology/FND/Agreements/Contracts/Contract"/>
        <rdfs:seeAlso rdf:resource="urn:iso:std:iso:9000:ed-4:v1:term:3.4.7"/>
        <skos:definition xml:lang="en">Legally enforceable agreement to supply goods, execute work or provide services</skos:definition>
        <skos:prefLabel xml:lang="en">Contract</skos:prefLabel>
    </owl:Class>
    


    <!-- https://haddenindustries.com/ontology/universal/core/ContractualCommitment -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/universal/core/ContractualCommitment">
        <rdfs:subClassOf rdf:resource="https://haddenindustries.com/ontology/universal/core/ContractualElement"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-04-20T19:38:26Z</dcterms:created>
        <dcterms:creator rdf:resource="https://orcid.org/0000-0001-8017-8797"/>
        <dcterms:identifier rdf:resource="urn:uuid:6ae79f97-90b7-4381-900c-313915a7fe25"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-25T13:11:00Z</dcterms:modified>
        <dcterms:source rdf:resource="https://spec.edmcouncil.org/fibo/ontology/FND/Agreements/Contracts/ContractualCommitment"/>
        <rdfs:label xml:lang="en">Contractual Commitment</rdfs:label>
        <skos:definition xml:lang="en">Provision specifying something that the contracting parties agree to, i.e., a promise or pledge made by one of the parties to perform some action or fulfill some duty</skos:definition>
        <skos:prefLabel xml:lang="en">Contractual Commitment</skos:prefLabel>
    </owl:Class>
    


    <!-- https://haddenindustries.com/ontology/universal/core/ContractualElement -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/universal/core/ContractualElement">
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2022-03-22T12:02:53Z</dcterms:created>
        <dcterms:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
        <dcterms:identifier rdf:resource="urn:uuid:c9d7cc4b-1604-4410-b2ca-9081370b5e62"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-25T13:11:00Z</dcterms:modified>
        <dcterms:references rdf:resource="https://spec.edmcouncil.org/fibo/ontology/FND/Agreements/Contracts/ContractualElement"/>
        <rdfs:label xml:lang="en">Contractual Element</rdfs:label>
        <skos:definition xml:lang="en">Element, such as an arrangement, provision, requirement, rule, specification, and standard that forms an integral part of an agreement</skos:definition>
        <skos:prefLabel xml:lang="en">Contractual Element</skos:prefLabel>
    </owl:Class>
    


    <!-- https://haddenindustries.com/ontology/universal/core/Device -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/universal/core/Device">
        <rdfs:subClassOf rdf:resource="https://haddenindustries.com/ontology/universal/core/Machine"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2016-10-14T12:00:00Z</dcterms:created>
        <dcterms:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
        <dcterms:identifier rdf:resource="urn:uuid:d8bdff75-51b7-43a5-8f2a-b6c5cb5e1c1e"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-24T18:25:00Z</dcterms:modified>
        <rdfs:label xml:lang="en">Device</rdfs:label>
        <skos:definition xml:lang="en">Mechanical or electronic Machine that is typically portable</skos:definition>
        <skos:prefLabel xml:lang="en">Device</skos:prefLabel>
    </owl:Class>
    


    <!-- https://haddenindustries.com/ontology/universal/core/Document -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/universal/core/Document">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://haddenindustries.com/ontology/universal/core/hasDocumentType"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/DocumentType"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2016-10-14T12:00:00Z</dcterms:created>
        <dcterms:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
        <dcterms:identifier rdf:resource="urn:uuid:2dc05ab0-a47f-4799-839e-e3d4c7e04086"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-25T13:58:00Z</dcterms:modified>
        <dcterms:source rdf:resource="urn:iso:std:iso:5127:ed-2:v1:term:3.1.1.38"/>
        <rdfs:label xml:lang="en">Document</rdfs:label>
        <rdfs:seeAlso rdf:resource="urn:iso:std:iso:9000:ed-4:v1:term:3.8.5"/>
        <skos:definition xml:lang="en">Recorded information or material object which can be treated as a unit in a documentation process</skos:definition>
        <skos:prefLabel xml:lang="en">Document</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Documents often are the manifestations of works.They can differ extensively in form and characteristics.</skos:scopeNote>
        <skos:scopeNote xml:lang="en">In some professional usage, documents are sometimes referred to as “medium”, “title” or “item”</skos:scopeNote>
        <skos:scopeNote xml:lang="en">See also ISO 25964-1:2011, definition 2.15; ISO 11005:2010, definition 3.1; ISO 15489-1:2016, definition 3.10; IEC 82045-1:2001, definition 3.2.3; ISO 9000:2015, definition 3.7.2</skos:scopeNote>
        <skos:scopeNote xml:lang="en">This definition refers not only to written and printed materials in paper or microform versions (for example, conventional books, journals, diagrams, maps), but also to non-printed media such as machine-readable and digitised records, Internet and intranet resources, films, sound recordings, people and organisations as knowledge resources, buildings, sites, monuments, three-dimensional objects or realia; and to collections of such items or parts of such items. (Note taken from ISO 25964-1:2011, definition 2.15.) Also, software, since recorded, can be considered a document.</skos:scopeNote>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/core/Document"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#scopeNote"/>
        <owl:annotatedTarget xml:lang="en">Documents often are the manifestations of works.They can differ extensively in form and characteristics.</owl:annotatedTarget>
        <schema:position rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</schema:position>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/core/Document"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#scopeNote"/>
        <owl:annotatedTarget xml:lang="en">In some professional usage, documents are sometimes referred to as “medium”, “title” or “item”</owl:annotatedTarget>
        <schema:position rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</schema:position>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/core/Document"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#scopeNote"/>
        <owl:annotatedTarget xml:lang="en">See also ISO 25964-1:2011, definition 2.15; ISO 11005:2010, definition 3.1; ISO 15489-1:2016, definition 3.10; IEC 82045-1:2001, definition 3.2.3; ISO 9000:2015, definition 3.7.2</owl:annotatedTarget>
        <schema:position rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</schema:position>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/core/Document"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#scopeNote"/>
        <owl:annotatedTarget xml:lang="en">This definition refers not only to written and printed materials in paper or microform versions (for example, conventional books, journals, diagrams, maps), but also to non-printed media such as machine-readable and digitised records, Internet and intranet resources, films, sound recordings, people and organisations as knowledge resources, buildings, sites, monuments, three-dimensional objects or realia; and to collections of such items or parts of such items. (Note taken from ISO 25964-1:2011, definition 2.15.) Also, software, since recorded, can be considered a document.</owl:annotatedTarget>
        <schema:position rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</schema:position>
    </owl:Axiom>
    


