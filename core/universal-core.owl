    <!-- https://haddenindustries.com/ontology/universal/core/Address -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/universal/core/Address">
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2016-09-30T12:00:00Z</dcterms:created>
        <dcterms:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
        <dcterms:identifier rdf:resource="urn:uuid:623ea210-aed1-4788-b0c1-55a970288274"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-25T13:58:00Z</dcterms:modified>
        <dcterms:source rdf:resource="urn:iso:std:iso:19160:-1:ed-1:v1:term:4.1"/>
        <rdfs:label xml:lang="en">Address</rdfs:label>
        <skos:definition xml:lang="en">Structured information that allows the unambiguous determination of an object for purposes of identification and location</skos:definition>
        <skos:example xml:lang="en">Address where the object is a building group, such as a school or large apartment area: 228-dong 404-ho, 26 Kyunghee-daero, Dongdaemun-gu, Seoul 130–701, South Korea</skos:example>
        <skos:example xml:lang="en">Address where the object is a building: Lombardy House, 809 Lombardy Street, The Hills, 0039, South Africa</skos:example>
        <skos:example xml:lang="en">Address where the object is a business: 611 Fifth Avenue, New York NY 10022</skos:example>
        <skos:example xml:lang="en">Address where the object is a land parcel for a building: San 4–5, Munjae-ro, Songpa-gu, Seoul, 13144, South Korea</skos:example>
        <skos:prefLabel xml:lang="en">Address</skos:prefLabel>
        <skos:scopeNote xml:lang="en-gb">In addition to the addressable object, there may be a multitude of people, organizations, addressees or other objects associated with an address. These are external to the address model (refer to Annex C and Annex F for examples).</skos:scopeNote>
        <skos:scopeNote xml:lang="en">The object is identifiable in the real world, i.e. electronic and virtual addresses are excluded</skos:scopeNote>
        <skos:scopeNote xml:lang="en">There can be many addresses for an object, but at any moment (or lifecycle stage), an address unambiguously determines a single object (see Annex D for examples)</skos:scopeNote>
        <skos:scopeNote xml:lang="en">Two addresses for the same addressable object and from the same address class, but in two different languages are two different addresses (refer to Annex E for more examples)</skos:scopeNote>
        <skos:scopeNote xml:lang="en">Two addresses from two different address classes (4.4) (i.e. they have different sets of components) for the same addressable object are two different addresses (refer to Annex E for more examples)</skos:scopeNote>
        <skos:scopeNote xml:lang="en">“Identification” refers to the fact that the structured information in the address unambiguously determines the object, i.e. it helps the human to identify the object. In other words, “identification” here does not refer to unique identifiers in a database or dataset.</skos:scopeNote>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/core/Address"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#example"/>
        <owl:annotatedTarget xml:lang="en">Address where the object is a building group, such as a school or large apartment area: 228-dong 404-ho, 26 Kyunghee-daero, Dongdaemun-gu, Seoul 130–701, South Korea</owl:annotatedTarget>
        <schema:position rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</schema:position>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/core/Address"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#example"/>
        <owl:annotatedTarget xml:lang="en">Address where the object is a building: Lombardy House, 809 Lombardy Street, The Hills, 0039, South Africa</owl:annotatedTarget>
        <schema:position rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</schema:position>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/core/Address"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#example"/>
        <owl:annotatedTarget xml:lang="en">Address where the object is a business: 611 Fifth Avenue, New York NY 10022</owl:annotatedTarget>
        <schema:position rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</schema:position>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/core/Address"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#example"/>
        <owl:annotatedTarget xml:lang="en">Address where the object is a land parcel for a building: San 4–5, Munjae-ro, Songpa-gu, Seoul, 13144, South Korea</owl:annotatedTarget>
        <schema:position rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</schema:position>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/core/Address"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#scopeNote"/>
        <owl:annotatedTarget xml:lang="en-gb">In addition to the addressable object, there may be a multitude of people, organizations, addressees or other objects associated with an address. These are external to the address model (refer to Annex C and Annex F for examples).</owl:annotatedTarget>
        <schema:position rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">6</schema:position>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/core/Address"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#scopeNote"/>
        <owl:annotatedTarget xml:lang="en">The object is identifiable in the real world, i.e. electronic and virtual addresses are excluded</owl:annotatedTarget>
        <schema:position rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</schema:position>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/core/Address"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#scopeNote"/>
        <owl:annotatedTarget xml:lang="en">There can be many addresses for an object, but at any moment (or lifecycle stage), an address unambiguously determines a single object (see Annex D for examples)</owl:annotatedTarget>
        <schema:position rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</schema:position>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/core/Address"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#scopeNote"/>
        <owl:annotatedTarget xml:lang="en">Two addresses for the same addressable object and from the same address class, but in two different languages are two different addresses (refer to Annex E for more examples)</owl:annotatedTarget>
        <schema:position rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">5</schema:position>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/core/Address"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#scopeNote"/>
        <owl:annotatedTarget xml:lang="en">Two addresses from two different address classes (4.4) (i.e. they have different sets of components) for the same addressable object are two different addresses (refer to Annex E for more examples)</owl:annotatedTarget>
        <schema:position rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</schema:position>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/core/Address"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#scopeNote"/>
        <owl:annotatedTarget xml:lang="en">“Identification” refers to the fact that the structured information in the address unambiguously determines the object, i.e. it helps the human to identify the object. In other words, “identification” here does not refer to unique identifiers in a database or dataset.</owl:annotatedTarget>
        <schema:position rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</schema:position>
    </owl:Axiom>
    


