    <!-- https://haddenindustries.com/ontology/universal/core/QuantityValue -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/universal/core/QuantityValue">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://haddenindustries.com/ontology/universal/core/hasMeasurementUnit"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">0</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/MeasurementUnit"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2017-05-04T13:43:44Z</dcterms:created>
        <dcterms:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
        <dcterms:identifier rdf:resource="urn:uuid:4a1fe34f-9ee0-4509-92d0-f5d17383b108"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-25T13:53:09Z</dcterms:modified>
        <dcterms:source rdf:resource="https://jcgm.bipm.org/vim/en/1.19.html"/>
        <rdfs:label xml:lang="en">Quantity Value</rdfs:label>
        <skos:altLabel xml:lang="en">Dimension</skos:altLabel>
        <skos:altLabel xml:lang="en">Value</skos:altLabel>
        <skos:altLabel xml:lang="en">Value of a quantity</skos:altLabel>
        <skos:definition xml:lang="en">Number and reference together expressing magnitude of a Quantity</skos:definition>
        <skos:example xml:lang="en">Arbitrary amount-of-substance concentration of lutropin in a given sample of human blood plasma (WHO International Standard 80/552 used as a calibrator):
5.0 IU/l, where “IU” stands for “WHO International Unit&quot;</skos:example>
        <skos:example xml:lang="en">Celsius temperature of a given sample:
−5 °C</skos:example>
        <skos:example xml:lang="en">Curvature of a given arc:
112 m−1</skos:example>
        <skos:example xml:lang="en">Electric impedance of a given circuit element at a given frequency, where j is the imaginary unit:
(7 + 3j) Ω</skos:example>
        <skos:example xml:lang="en">Length of a given rod:
5.34 m or 534 cm</skos:example>
        <skos:example xml:lang="en">Mass fraction of cadmium in a given sample of copper:
3 µg/kg or 3 ·10−9</skos:example>
        <skos:example xml:lang="en">Mass of a given body:
0.152 kg or 152 g</skos:example>
        <skos:example xml:lang="en">Molality of Pb2+ in a given sample of water:
1.76 µmol/kg</skos:example>
        <skos:example xml:lang="en">Refractive index of a given sample of glass:
1.32</skos:example>
        <skos:example xml:lang="en">Rockwell C hardness of a given sample:
43.5 HRC</skos:example>
        <skos:prefLabel xml:lang="en">Quantity Value</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A quantity value can be presented in more than one way (see Examples 1, 2 and 8)</skos:scopeNote>
        <skos:scopeNote xml:lang="en">According to the type of reference, a quantity value is either
- a product of a number and a measurement unit (see Examples 1, 2, 3, 4, 5, 8 and 9); the measurement unit one is generally not indicated for quantities of dimension one (see Examples 6 and 8), or
- a number and a reference to a measurement procedure (see Example 7), or
- a number and a reference material (see Example 10)</skos:scopeNote>
        <skos:scopeNote xml:lang="en">In the case of vector or tensor quantities, each component has a quantity value</skos:scopeNote>
        <skos:scopeNote xml:lang="en">The number can be complex (see Example 5)</skos:scopeNote>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/core/QuantityValue"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#example"/>
        <owl:annotatedTarget xml:lang="en">Arbitrary amount-of-substance concentration of lutropin in a given sample of human blood plasma (WHO International Standard 80/552 used as a calibrator):
5.0 IU/l, where “IU” stands for “WHO International Unit&quot;</owl:annotatedTarget>
        <schema:position rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">10</schema:position>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/core/QuantityValue"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#example"/>
        <owl:annotatedTarget xml:lang="en">Celsius temperature of a given sample:
−5 °C</owl:annotatedTarget>
        <schema:position rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</schema:position>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/core/QuantityValue"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#example"/>
        <owl:annotatedTarget xml:lang="en">Curvature of a given arc:
112 m−1</owl:annotatedTarget>
        <schema:position rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</schema:position>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/core/QuantityValue"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#example"/>
        <owl:annotatedTarget xml:lang="en">Electric impedance of a given circuit element at a given frequency, where j is the imaginary unit:
(7 + 3j) Ω</owl:annotatedTarget>
        <schema:position rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">5</schema:position>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/core/QuantityValue"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#example"/>
        <owl:annotatedTarget xml:lang="en">Length of a given rod:
5.34 m or 534 cm</owl:annotatedTarget>
        <schema:position rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</schema:position>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/core/QuantityValue"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#example"/>
        <owl:annotatedTarget xml:lang="en">Mass fraction of cadmium in a given sample of copper:
3 µg/kg or 3 ·10−9</owl:annotatedTarget>
        <schema:position rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">8</schema:position>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/core/QuantityValue"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#example"/>
        <owl:annotatedTarget xml:lang="en">Mass of a given body:
0.152 kg or 152 g</owl:annotatedTarget>
        <schema:position rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</schema:position>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/core/QuantityValue"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#example"/>
        <owl:annotatedTarget xml:lang="en">Molality of Pb2+ in a given sample of water:
1.76 µmol/kg</owl:annotatedTarget>
        <schema:position rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">9</schema:position>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/core/QuantityValue"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#example"/>
        <owl:annotatedTarget xml:lang="en">Refractive index of a given sample of glass:
1.32</owl:annotatedTarget>
        <schema:position rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">6</schema:position>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/core/QuantityValue"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#example"/>
        <owl:annotatedTarget xml:lang="en">Rockwell C hardness of a given sample:
43.5 HRC</owl:annotatedTarget>
        <schema:position rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">7</schema:position>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/core/QuantityValue"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#scopeNote"/>
        <owl:annotatedTarget xml:lang="en">A quantity value can be presented in more than one way (see Examples 1, 2 and 8)</owl:annotatedTarget>
        <schema:position rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</schema:position>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/core/QuantityValue"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#scopeNote"/>
        <owl:annotatedTarget xml:lang="en">According to the type of reference, a quantity value is either
- a product of a number and a measurement unit (see Examples 1, 2, 3, 4, 5, 8 and 9); the measurement unit one is generally not indicated for quantities of dimension one (see Examples 6 and 8), or
- a number and a reference to a measurement procedure (see Example 7), or
- a number and a reference material (see Example 10)</owl:annotatedTarget>
        <schema:position rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</schema:position>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/core/QuantityValue"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#scopeNote"/>
        <owl:annotatedTarget xml:lang="en">In the case of vector or tensor quantities, each component has a quantity value</owl:annotatedTarget>
        <schema:position rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</schema:position>
        <skos:example xml:lang="en">Force acting on a given particle, e.g. in Cartesian components (Fx; Fy; Fz) = (−31.5; 43.2; 17.0) N</skos:example>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/core/QuantityValue"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#scopeNote"/>
        <owl:annotatedTarget xml:lang="en">The number can be complex (see Example 5)</owl:annotatedTarget>
        <schema:position rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</schema:position>
    </owl:Axiom>
    


