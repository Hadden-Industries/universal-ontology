    <!-- https://haddenindustries.com/ontology/universal/core/Offer -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/universal/core/Offer">
        <rdfs:subClassOf rdf:resource="https://haddenindustries.com/ontology/universal/core/Event"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://haddenindustries.com/ontology/universal/core/Offer_hasOffering"/>
                <owl:someValuesFrom rdf:resource="https://haddenindustries.com/ontology/universal/core/Offering"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2016-10-14T12:00:00Z</dcterms:created>
        <dcterms:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
        <dcterms:identifier rdf:resource="urn:uuid:270ee6a4-0c9b-4ce8-bf5a-907e872e4a3e"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-25T14:17:02Z</dcterms:modified>
        <dcterms:source rdf:resource="urn:isbn:9780421634503"/>
        <rdfs:label xml:lang="en">Offer</rdfs:label>
        <skos:definition xml:lang="en">Expression of willingness to contract on certain terms, made with the intention that it shall become binding as soon as it is accepted by the person to whom it is addressed</skos:definition>
        <skos:prefLabel xml:lang="en">Offer</skos:prefLabel>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/core/Offer"/>
        <owl:annotatedProperty rdf:resource="http://purl.org/dc/terms/source"/>
        <owl:annotatedTarget rdf:resource="urn:isbn:9780421634503"/>
        <skos:note xml:lang="en">Chapter 2, Section 1</skos:note>
    </owl:Axiom>
    


