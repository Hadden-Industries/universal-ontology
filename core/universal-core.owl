        <rdfs:label xml:lang="en">Material Object Relationship</rdfs:label>
        <skos:definition xml:lang="en">Way in which material objects are connected</skos:definition>
        <skos:prefLabel xml:lang="en">Material Object Relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- https://haddenindustries.com/ontology/universal/core/MeansOfTransport -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/universal/core/MeansOfTransport">
