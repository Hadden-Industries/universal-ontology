        <dcterms:source rdf:resource="http://www.heppnetz.de/ontologies/goodrelations/v1.html#Offering"/>
        <rdfs:label xml:lang="en">Offering</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://spec.edmcouncil.org/fibo/ontology/FBC/ProductsAndServices/FinancialProductsAndServices/Offering"/>
        <skos:altLabel xml:lang="en">Invitation To Treat</skos:altLabel>
        <skos:altLabel xml:lang="en">Proposition</skos:altLabel>
        <skos:definition xml:lang="en">Public, not necessarily binding, not necessarily exclusive, announcement by a business entity to provide (or seek) a certain business function for a certain product or service to a specified target audience</skos:definition>
        <skos:prefLabel xml:lang="en">Offering</skos:prefLabel>
    </owl:Class>
    


