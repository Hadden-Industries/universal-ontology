    <!-- https://haddenindustries.com/ontology/universal/core/Position -->

    <rdfs:Datatype rdf:about="https://haddenindustries.com/ontology/universal/core/Position">
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2020-09-11T16:42:16Z</dcterms:created>
        <dcterms:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
        <dcterms:identifier rdf:resource="urn:uuid:b36ab6fb-3317-47c8-87c1-8451ebeaf45a"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-25T13:58:00Z</dcterms:modified>
        <dcterms:source rdf:resource="urn:iso:std:iso:19133:ed-1:v1:term:4.18"/>
        <rdfs:label xml:lang="en">Position</rdfs:label>
        <skos:definition xml:lang="en">Data type that describes a point or geometry potentially occupied by an object or person</skos:definition>
        <skos:prefLabel xml:lang="en">Position</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A direct position is a semantic subtype of position. Direct positions as described can only define a point and therefore not all positions can be represented by a direct position. That is consistent with the “is type of” relation. An ISO 19107 geometry is also a position, just not a direct position.</skos:scopeNote>
    </rdfs:Datatype>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/core/Position"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#scopeNote"/>
        <owl:annotatedTarget xml:lang="en">A direct position is a semantic subtype of position. Direct positions as described can only define a point and therefore not all positions can be represented by a direct position. That is consistent with the “is type of” relation. An ISO 19107 geometry is also a position, just not a direct position.</owl:annotatedTarget>
        <schema:position rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</schema:position>
    </owl:Axiom>
    


