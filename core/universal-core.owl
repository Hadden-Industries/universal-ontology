        <skos:altLabel xml:lang="en">Agency</skos:altLabel>
        <skos:altLabel xml:lang="en">Business</skos:altLabel>
        <skos:altLabel xml:lang="en">Company</skos:altLabel>
        <skos:altLabel xml:lang="en">Corporation</skos:altLabel>
        <skos:altLabel xml:lang="en">Enterprise</skos:altLabel>
        <skos:altLabel xml:lang="en">Firm</skos:altLabel>
        <skos:altLabel xml:lang="en">Legal Entity</skos:altLabel>
        <skos:definition xml:lang="en">Entity, that is not a natural person, recognised by law as having legal rights and duties, able to make commitment(s), assume and fulfil resulting obligation(s), and able to be held accountable for its action(s)</skos:definition>
