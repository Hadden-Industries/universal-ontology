                <owl:onProperty rdf:resource="https://haddenindustries.com/ontology/universal/core/hasMaterialObjectType"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/MaterialObjectType"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2016-10-17T12:00:00Z</dcterms:created>
        <dcterms:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
        <dcterms:identifier rdf:resource="urn:uuid:3a074d33-b750-4992-8d96-5cd627b625d3"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-25T13:58:00Z</dcterms:modified>
        <dcterms:source rdf:resource="urn:iso:std:iso:5127:ed-2:v1:term:3.1.1.60"/>
        <rdfs:label xml:lang="en">Material Object</rdfs:label>
        <skos:altLabel xml:lang="en">Physical Object</skos:altLabel>
        <skos:definition xml:lang="en">Object which has physical extension in space and time</skos:definition>
        <skos:prefLabel xml:lang="en">Material Object</skos:prefLabel>
        <skos:scopeNote xml:lang="en">See also “naturafact”, “artefact (1) &lt;man-made object&gt;; ISO 21127:2014, classes “E 18” and “E 19”</skos:scopeNote>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/core/MaterialObject"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#scopeNote"/>
        <owl:annotatedTarget xml:lang="en">See also “naturafact”, “artefact (1) &lt;man-made object&gt;; ISO 21127:2014, classes “E 18” and “E 19”</owl:annotatedTarget>
        <schema:position rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</schema:position>
    </owl:Axiom>
    


    <!-- https://haddenindustries.com/ontology/universal/core/MaterialObjectRelationship -->

