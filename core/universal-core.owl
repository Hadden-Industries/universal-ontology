                <owl:onProperty rdf:resource="https://haddenindustries.com/ontology/universal/core/hasPriceSpecification"/>
                <owl:someValuesFrom rdf:resource="https://haddenindustries.com/ontology/universal/core/PriceSpecification"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2016-10-24T10:04:25Z</dcterms:created>
        <dcterms:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
        <dcterms:identifier rdf:resource="urn:uuid:dbe0e629-c5d7-4c8a-bed1-c83c70b32a80"/>
