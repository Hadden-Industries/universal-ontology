    <!-- https://haddenindustries.com/ontology/universal/core/Person -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/universal/core/Person">
        <owl:equivalentClass>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://haddenindustries.com/ontology/universal/core/JuridicalPerson"/>
                    <rdf:Description rdf:about="https://haddenindustries.com/ontology/universal/core/NaturalPerson"/>
                </owl:unionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://haddenindustries.com/ontology/universal/core/hasPersonType"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/PersonType"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2016-09-30T12:00:00Z</dcterms:created>
        <dcterms:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
        <dcterms:identifier rdf:resource="urn:uuid:1ef827ec-12a3-43e6-88de-d149d3be2b8e"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-25T13:58:00Z</dcterms:modified>
        <dcterms:source rdf:resource="urn:iso:std:iso-iec:14662:ed-3:v1:term:3.24"/>
        <rdfs:label xml:lang="en">Person</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://www.law.cornell.edu/wex/legal_person"/>
        <skos:definition xml:lang="en-gb">Entity, i.e. a natural or legal person, recognised by law as having legal rights and duties, able to make commitment(s), assume and fulfil resulting obligation(s), and able to be held accountable for its action(s)</skos:definition>
        <skos:prefLabel xml:lang="en">Person</skos:prefLabel>
        <skos:scopeNote xml:lang="en-gb">Minimum and common external constraints applicable to a business transaction often require one to differentiate among three common sub-types of Person, namely &quot;individual&quot;, &quot;organisation&quot;, and &quot;public administration&quot;</skos:scopeNote>
        <skos:scopeNote xml:lang="en-gb">Person is capitalised to indicate that it is being utilised as formally defined in the standards and to differentiate it from its day-to-day use</skos:scopeNote>
        <skos:scopeNote xml:lang="en">Synonyms for &quot;legal person&quot; include &quot;artificial person&quot;, &quot;body corporate&quot;, etc., depending on the terminology used in competent jurisdictions</skos:scopeNote>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/core/Person"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#scopeNote"/>
        <owl:annotatedTarget xml:lang="en-gb">Minimum and common external constraints applicable to a business transaction often require one to differentiate among three common sub-types of Person, namely &quot;individual&quot;, &quot;organisation&quot;, and &quot;public administration&quot;</owl:annotatedTarget>
        <schema:position rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</schema:position>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/core/Person"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#scopeNote"/>
        <owl:annotatedTarget xml:lang="en-gb">Person is capitalised to indicate that it is being utilised as formally defined in the standards and to differentiate it from its day-to-day use</owl:annotatedTarget>
        <schema:position rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</schema:position>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/core/Person"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#scopeNote"/>
        <owl:annotatedTarget xml:lang="en">Synonyms for &quot;legal person&quot; include &quot;artificial person&quot;, &quot;body corporate&quot;, etc., depending on the terminology used in competent jurisdictions</owl:annotatedTarget>
        <schema:position rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</schema:position>
    </owl:Axiom>
    


