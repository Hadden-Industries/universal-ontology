                <owl:onClass rdf:resource="https://haddenindustries.com/ontology/universal/reference-data/MeansOfTransportType"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2016-10-14T12:00:00Z</dcterms:created>
        <dcterms:creator rdf:resource="http://orcid.org/0000-0001-8017-8797"/>
        <dcterms:identifier rdf:resource="urn:uuid:a6d9b70e-3a55-431f-8345-edd4389c32a6"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-25T14:16:42Z</dcterms:modified>
        <rdfs:label xml:lang="en">Means Of Transport</rdfs:label>
        <skos:definition xml:lang="en">Particular aircraft, vehicle, vessel or other device used for the transport of goods or persons</skos:definition>
        <skos:prefLabel xml:lang="en">Means Of Transport</skos:prefLabel>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/core/MeansOfTransport"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#definition"/>
