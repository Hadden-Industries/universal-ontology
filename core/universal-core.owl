    <!-- https://haddenindustries.com/ontology/universal/core/WrittenContract -->

    <owl:Class rdf:about="https://haddenindustries.com/ontology/universal/core/WrittenContract">
        <rdfs:subClassOf rdf:resource="https://haddenindustries.com/ontology/universal/core/Contract"/>
        <rdfs:subClassOf rdf:resource="https://haddenindustries.com/ontology/universal/core/Document"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-05-10T08:55:53Z</dcterms:created>
        <dcterms:creator rdf:resource="https://orcid.org/0000-0001-8017-8797"/>
        <dcterms:identifier rdf:resource="urn:uuid:3ed1126b-ccde-415c-8d54-2be6dade8abc"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-25T13:11:00Z</dcterms:modified>
        <rdfs:label xml:lang="en">Written Contract</rdfs:label>
        <skos:definition xml:lang="en">Contract whose constituent terms and conditions are explicitly recorded using a legible, orthographic format upon a physical or electronic medium</skos:definition>
        <skos:prefLabel xml:lang="en">Written Contract</skos:prefLabel>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://haddenindustries.com/ontology/universal/core/WrittenContract"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2004/02/skos/core#definition"/>
