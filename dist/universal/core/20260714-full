    <skos:prefLabel xml:lang="en">Code 39</skos:prefLabel>
    <dcterms:source rdf:resource="urn:iso:std:iso:22742:ed-2:v1:term:3.1"/>
    <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2017-05-05T10:11:09+00:00</dcterms:created>
    <skos:definition xml:lang="en">Discrete, variable length, bar code symbology encoding the characters 0 to 9, A to Z, and the additional characters “-” (dash), “.” (period), space, “$” (dollar sign), “/” (slash), “+” (plus sign), and “%” (percent sign), as well as a special symbology character to denote the start and stop character, conventionally represented as an “*” (asterisk)</skos:definition>
