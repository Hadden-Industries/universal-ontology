<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Export tool for generating a JSON-LD representation of the Hadden Industries ontology.">
    <title>Ontology Data Exporter</title>
    <!-- Link to our shared premium stylesheet -->
    <link rel="stylesheet" href="ontology_styles.css">
</head>
<body>

    <main class="exporter-wrapper">
        <div class="card">
            <h1 id="main-title" class="title">Ontology Exporter</h1>
            
            <div id="step-init" class="step">
                <div class="icon-container">
                    <div class="circle-placeholder"></div>
                    <svg class="spinner" viewBox="0 0 50 50"><circle class="path" cx="25" cy="25" r="20" fill="none" stroke-width="5"></circle></svg>
                    <svg class="check-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
                </div>
                <span>Initialising export sequence</span>
            </div>

            <div id="step-fetch" class="step">
                <div class="icon-container">
                    <div class="circle-placeholder"></div>
                    <svg class="spinner" viewBox="0 0 50 50"><circle class="path" cx="25" cy="25" r="20" fill="none" stroke-width="5"></circle></svg>
                    <svg class="check-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
                </div>
                <span>Fetching and mapping XML objects</span>
            </div>

            <div id="step-json" class="step">
                <div class="icon-container">
                    <div class="circle-placeholder"></div>
                    <svg class="spinner" viewBox="0 0 50 50"><circle class="path" cx="25" cy="25" r="20" fill="none" stroke-width="5"></circle></svg>
                    <svg class="check-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
                </div>
                <span>Generating JSON-LD payload</span>
            </div>

            <div id="step-download" class="step">
                <div class="icon-container">
                    <div class="circle-placeholder"></div>
                    <svg class="spinner" viewBox="0 0 50 50"><circle class="path" cx="25" cy="25" r="20" fill="none" stroke-width="5"></circle></svg>
                    <svg class="check-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
                </div>
                <span>Downloading .json file</span>
            </div>

            <div id="status-message-box" class="message-box"></div>
        </div>
    </main>

    <!-- Import the shared logic library -->
    <script src="ontology_processor.js"></script>
    <script>
        function setStepState(stepId, state) {
            document.getElementById(stepId).className = 'step ' + state;
        }

        function displayFinalMessage(text, type) {
            const msgBox = document.getElementById('status-message-box');
            msgBox.innerText = text;
            msgBox.className = `message-box ${type} show`;
        }

        async function orchestrateAutoDownload() {
            let ontologyResult = null;

            try {
                // Step 1: Initialising
                setStepState('step-init', 'active');
                await new Promise(r => setTimeout(r, 400)); // Brief UX delay 
                setStepState('step-init', 'complete');

                // Step 2: Fetch and Process XML
                setStepState('step-fetch', 'active');
                
                const isLocalEnv = window.location.hostname === "localhost" || window.location.hostname === "127.0.0.1" || window.location.protocol === "file:";
                let targetUrl;

                if (isLocalEnv) {
                    targetUrl = "https://haddenindustries.com/ontology/universal/reference-data/latest";
                } else {
                    const pathname = window.location.pathname;
                    const basePath = pathname.substring(0, pathname.lastIndexOf('/'));
                    targetUrl = window.location.origin + basePath;
                }
                
                const result = await fetchOntologyAsJsonLd(targetUrl);
                
                if (!result || !result["@graph"] || result["@graph"].length === 0) {
                    throw new Error("No data retrieved or parsing failed.");
                }

                ontologyResult = result; // Store for the export step

                // Dynamically update UI titles based on the fetched data (using language map)
                const titleMap = result["dcterms:title"];
                let baseTitle = "Ontology";
                if (titleMap && typeof titleMap === 'object') {
                    baseTitle = titleMap["en-GB"] || titleMap["en"] || Object.values(titleMap)[0] || "Ontology";
                }
                
                // Prevent duplicate "Ontology" if the XML title already includes it
                const suffix = baseTitle.endsWith("Ontology") ? " Data Exporter (.json)" : " Ontology Data Exporter (.json)";
                const exportTitle = baseTitle + suffix;
                
                document.title = exportTitle;
                document.getElementById('main-title').innerText = exportTitle;

                setStepState('step-fetch', 'complete');

                // Step 3: Package JSON-LD
                setStepState('step-json', 'active');
                await new Promise(r => setTimeout(r, 600)); // Brief UX delay
                setStepState('step-json', 'complete');

                // Step 4: Download
                setStepState('step-download', 'active');
                await new Promise(r => setTimeout(r, 400));
                
                let filename = "Ontology Vocabulary.json";
                if (titleMap) {
                    const titleText = titleMap["en-GB"] || titleMap["en"] || Object.values(titleMap)[0] || "Ontology";
                    filename = `${titleText} Vocabulary`;
                    const modified = result["dcterms:modified"];
                    if (modified) {
                        filename += ` [${modified}]`;
                    }
                    filename += ".json";
                }
                
                exportJSON(ontologyResult, filename);
                
                setStepState('step-download', 'complete');
                displayFinalMessage('Download complete. You may close this window.', 'success');

            } catch (error) {
                console.error("Auto-download sequence failed:", error);
                
                // Halt UI progress and show error state
                const activeStep = document.querySelector('.step.active');
                if (activeStep) activeStep.classList.remove('active');
                
                displayFinalMessage('An error occurred during the extraction process.', 'error');
            }
        }

        // Start sequence automatically on load
        window.addEventListener('load', orchestrateAutoDownload);
    </script>
</body>
</html>
